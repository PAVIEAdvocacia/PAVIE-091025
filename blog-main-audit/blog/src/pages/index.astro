---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildFaqSchema, LEGAL_SERVICE_BASE_SCHEMA, toAbsoluteUrl } from '../lib/seo';
import { MAIN_SITE_URL } from '../consts';
import '../styles/site-home.css';

const title = 'PAVIE | Advocacia | Clareza jurídica para decisões importantes';
const description =
	'Sede institucional da PAVIE | Advocacia para orientar decisões em família, patrimônio, contratos e relações civis com clareza, método e conversão ética.';

const proofItems = [
	{
		title: 'OAB/RJ 134.947',
		text: 'Atuação com responsabilidade técnica, contratação formal e condução profissional identificável.',
	},
	{
		title: 'Atendimento online e presencial',
		text: 'O primeiro passo e organizado de acordo com o contexto do caso e a necessidade pratica de cada pessoa.',
	},
	{
		title: 'Mais de 20 anos de experiência jurídica',
		text: 'Leitura madura de situações patrimoniais, familiares, contratuais e conflitos civis relevantes.',
	},
	{
		title: 'Dados tratados com confidencialidade',
		text: 'A triagem pede apenas o necessário para entender o problema e orientar os próximos passos.',
	},
	{
		title: 'Retorno inicial organizado',
		text: 'Sem promessa indevida: a expectativa do primeiro contato é clara desde o início.',
	},
];

const methodPoints = [
	{
		title: 'Clareza antes da estratégia',
		text: 'O atendimento começa pela leitura do contexto, da urgência prática e dos documentos que realmente importam.',
	},
	{
		title: 'Diagnóstico jurídico responsável',
		text: 'Riscos, caminhos possíveis e limites do caso são explicados com linguagem compreensível e enquadramento técnico.',
	},
	{
		title: 'Condução com previsibilidade',
		text: 'Escopo, etapas, honorários e forma de acompanhamento são apresentados de modo direto e formal.',
	},
];

const serviceClusters = [
	{
		title: 'Família, Sucessões e Patrimônio',
		lead: 'Quando a dúvida envolve divórcio com filhos, inventário, partilha ou reorganização patrimonial da família.',
		description:
			'Demandas que envolvem relações familiares, reorganização patrimonial e decisões com impacto pessoal duradouro.',
		items: [
			'Divórcio, guarda, alimentos e convivência.',
			'Inventário, partilha, testamento e planejamento sucessório.',
			'Proteção patrimonial e prevenção de conflito.',
		],
		blogHref: '/blog/areas/familia-sucessoes-patrimonio/',
	},
	{
		title: 'Contratos, Obrigações e Responsabilidade Civil',
		lead: 'Quando um contrato precisa de revisão, uma cobrança saiu do controle ou um dano já exige resposta técnica.',
		description:
			'Atuação em compromissos jurídicos que exigem leitura precisa de escopo, cumprimento, dano e reparação.',
		items: [
			'Elaboração, revisão e negociação contratual.',
			'Inadimplemento, cobrança e execução de obrigações.',
			'Reparação de danos e estratégia em conflitos civis.',
		],
		blogHref: '/blog/areas/contratos-obrigacoes-responsabilidade-civil/',
	},
	{
		title: 'Imobiliário, Regularização e Condomínios',
		lead: 'Quando o problema passa por matrícula, posse, regularização documental, locação ou uso do imóvel.',
		description:
			'Situações ligadas a imóveis, documentos, posse, uso e relações condominiais que pedem segurança jurídica.',
		items: [
			'Compra e venda, locação e cláusulas críticas.',
			'Regularização documental e registral.',
			'Condomínios, posse e conflitos sobre uso do imóvel.',
		],
		blogHref: '/blog/areas/imobiliario-regularizacao-condominios/',
	},
	{
		title: 'Consumidor, Saúde e Previdência',
		lead: 'Quando há negativa de cobertura, falha de serviço, cobrança indevida ou dúvida sobre benefício e proteção social.',
		description:
			'Casos em que a relação com empresas, operadoras ou benefícios exige resposta técnica e orientação clara.',
		items: [
			'Falha de serviço e problemas em relações de consumo.',
			'Negativa de cobertura e questões ligadas à saúde.',
			'Benefícios, revisões e organização previdenciária.',
		],
		blogHref: '/blog/areas/consumidor-saude-previdencia/',
	},
	{
		title: 'Compliance, Integridade e Atuação Empresarial',
		lead: 'Quando a decisão empresarial pede governança, controles internos, prevenção de risco ou leitura jurídica de operação.',
		description:
			'Suporte jurídico para operações, rotinas internas e decisões empresariais que pedem governança e controle.',
		items: [
			'Políticas, protocolos e rotinas de integridade.',
			'Conduta, governança e prevenção de risco.',
			'Contratos empresariais e apoio jurídico a operações.',
		],
		blogHref: '/blog/areas/compliance-integridade-atuacao-empresarial/',
	},
];

const processSteps = [
	{
		title: 'Contato inicial',
		text: 'Você apresenta a situação principal, a urgência prática e o objetivo do contato.',
	},
	{
		title: 'Triagem e documentos',
		text: 'O escritório identifica o que precisa ser compreendido antes de avançar para análise mais profunda.',
	},
	{
		title: 'Análise inicial ou consulta',
		text: 'Quando necessário, o caso passa por consulta ou leitura técnica para enquadramento do caminho adequado.',
	},
	{
		title: 'Proposta e contratação formal',
		text: 'Escopo, etapas, honorários e forma de acompanhamento são apresentados com transparência.',
	},
	{
		title: 'Condução jurídica',
		text: 'A atuação segue com comunicação objetiva, responsabilidade técnica e registro do que foi definido.',
	},
];

const faq = [
	{
		q: 'Quando vale buscar um diagnóstico jurídico?',
		a: 'Quando há decisão relevante a tomar, risco patrimonial, conflito em curso, dúvida documental ou urgência prática que não deve ser tratada no improviso.',
	},
	{
		q: 'A primeira conversa já significa contratação?',
		a: 'Não. O primeiro contato serve para triagem e orientação inicial. A contratação só acontece se houver aderência, escopo definido e proposta formal.',
	},
	{
		q: 'O atendimento pode ser online?',
		a: 'Sim. O atendimento pode ocorrer online ou presencialmente, conforme o caso, a localização e a necessidade prática da situação.',
	},
	{
		q: 'O que devo informar no primeiro contato?',
		a: 'A situação principal, desde quando ela ocorre, quem está envolvido, quais documentos existem e se há prazo, audiência ou urgência concreta.',
	},
	{
		q: 'Como os honorários são definidos?',
		a: 'Os honorários dependem do tipo de demanda, do escopo, da complexidade, da urgência e da necessidade de acompanhamento. A proposta é sempre formal e clara.',
	},
];

const faqSchema = buildFaqSchema(
	faq.map((item) => ({
		question: item.q,
		answer: item.a,
	})),
);

const localBusinessSchema = {
	...LEGAL_SERVICE_BASE_SCHEMA,
	description,
	image: toAbsoluteUrl('/uploads/foto_001-ffundddo-escrit%C3%B3rio.png'),
};
---

<BaseLayout title={title} description={description} canonical={`${MAIN_SITE_URL}/`}>
	<div class="container site-home">
		<section class="site-hero surface-card" aria-labelledby="hero-title">
			<div class="site-hero__content">
				<span class="badge">PAVIE | Advocacia | OAB/RJ 134.947</span>
				<h1 id="hero-title">
					Clareza jurídica para decidir com segurança em questões de família, patrimônio,
					contratos e relações civis.
				</h1>
				<p class="site-hero__lead">
					Divórcio com filhos, inventário, regularização de imóvel, revisão contratual,
					cobrança, dano civil ou negativa de cobertura pedem leitura técnica antes do
					próximo passo.
				</p>
				<div class="site-hero__cta">
					<a class="btn btn-primary" href="/contato/">Solicitar Diagnóstico Jurídico</a>
					<a class="btn btn-secondary" href="#servicos">Conheça os Serviços</a>
				</div>
				<p class="site-hero__microcopy">
					O primeiro contato serve para entender o contexto, identificar urgências e orientar
					os próximos passos possíveis. Não há promessa de resultado.
				</p>
			</div>

			<aside class="site-hero__panel" aria-labelledby="hero-panel-title">
				<span class="section-kicker">Primeiro passo</span>
				<h2 id="hero-panel-title">O que você recebe na etapa inicial</h2>
				<ul class="hero-list">
					<li>Leitura objetiva da situação apresentada.</li>
					<li>Identificação de risco, prazo e necessidade documental.</li>
					<li>Orientação sobre consulta, proposta ou condução adequada.</li>
				</ul>
				<p>
					Descreva sua situação. O primeiro passo é entender o contexto. Se houver aderência,
					a contratação é formalizada com escopo claro, etapas definidas e honorários compatíveis com o caso.
				</p>
			</aside>
		</section>

		<section class="proof-strip" aria-label="Barra de prova institucional">
			{proofItems.map((item) => (
				<article class="proof-item">
					<strong>{item.title}</strong>
					<p>{item.text}</p>
				</article>
			))}
		</section>

		<section id="advogado" class="site-section" aria-labelledby="advogado-title">
			<div class="section-title">
				<div>
					<span class="section-kicker">Quem conduz</span>
					<h2 id="advogado-title">
						Fabio Mathias Pavie conduz o atendimento com leitura técnica, linguagem clara
						e responsabilidade profissional.
					</h2>
				</div>
			</div>

			<div class="professional-layout">
				<article class="surface-card professional-section">
					<img
						src="/uploads/foto_001-ffundddo-escrit%C3%B3rio.png"
						alt="Foto profissional do advogado Fabio Mathias Pavie"
						loading="lazy"
					/>
					<div class="professional-copy">
						<p class="professional-meta">Advogado | OAB/RJ 134.947</p>
						<h3>Fabio Mathias Pavie</h3>
						<p>
							Atua em direito de família, sucessões, patrimônio, contratos, imobiliário e
							conflitos civis com foco em orientar decisões relevantes com método e sobriedade.
						</p>
						<p>
							A proposta institucional da PAVIE não é vender urgência. É transformar dúvida
							jurídica em caminho compreensível, com enquadramento técnico e previsibilidade.
						</p>
						<ul class="professional-highlights">
							<li>Mais de 20 anos de experiência jurídica.</li>
							<li>Membro do Instituto Brasileiro de Direito de Família.</li>
							<li>Condução ética, escopo claro e comunicação objetiva.</li>
						</ul>
						<div class="site-hero__cta">
							<a class="btn btn-primary" href="/contato/">Solicitar Diagnóstico Jurídico</a>
							<a class="btn btn-ghost" href="/blog/areas/">Leia conteúdos desta área</a>
						</div>
					</div>
				</article>

				<div class="method-grid">
					{methodPoints.map((point) => (
						<article class="surface-card method-card">
							<h3>{point.title}</h3>
							<p>{point.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section id="servicos" class="site-section" aria-labelledby="servicos-title">
			<div class="section-title">
				<div>
					<span class="section-kicker">Áreas de atuação</span>
					<h2 id="servicos-title">As áreas de atuação ajudam a localizar a situação e o melhor ponto de partida</h2>
				</div>
				<a class="btn btn-ghost" href="/areas/">Conheça os Serviços</a>
			</div>

			<div class="service-cluster-grid">
				{serviceClusters.map((cluster) => (
					<article class="surface-card service-cluster">
						<h3>{cluster.title}</h3>
						<p class="service-cluster__lead">{cluster.lead}</p>
						<p>{cluster.description}</p>
						<ul>
							{cluster.items.map((item) => (
								<li>{item}</li>
							))}
						</ul>
						<a class="service-cluster__link" href={cluster.blogHref}>Leia conteúdos desta área</a>
					</article>
				))}
			</div>

			<p class="coherence-note">
				Se a sua dúvida ainda precisa ser melhor localizada, o blog aprofunda situações
				reais antes do contato. Quando o caso já está claro, a página de serviços ajuda a
				enquadrar a atuação correspondente.
			</p>

			<article class="surface-card site-bridge">
				<div>
					<span class="section-kicker">Leitura útil antes do contato</span>
					<h3>Nem toda dúvida começa pronta para uma contratação. Às vezes, o melhor primeiro passo é entender melhor o tema.</h3>
					<p>
						O blog reúne orientações por assunto para ajudar você a reconhecer a área
						jurídica do problema, separar o que é dúvida geral do que já exige análise do
						caso concreto e chegar ao contato com mais clareza.
					</p>
				</div>
				<div class="site-hero__cta">
					<a class="btn btn-primary" href="/blog/areas/">Leia conteúdos por área</a>
					<a class="btn btn-secondary" href="/blog/">Ir para o blog</a>
				</div>
			</article>
		</section>

		<section id="como-contratar" class="site-section" aria-labelledby="contratacao-title">
			<div class="section-title">
				<div>
					<span class="section-kicker">Como contratar</span>
					<h2 id="contratacao-title">O processo de contratação é explicado antes de qualquer decisão</h2>
				</div>
			</div>

			<ol class="process-list">
				{processSteps.map((step, index) => (
					<li class="surface-card process-step">
						<span class="process-step__number">{index + 1}</span>
						<h3>{step.title}</h3>
						<p>{step.text}</p>
					</li>
				))}
			</ol>
		</section>

		<section id="honorarios" class="site-section split" aria-labelledby="honorarios-title">
			<article class="surface-card info-card">
				<span class="section-kicker">Honorarios</span>
				<h2 id="honorarios-title">Como os honorários são definidos</h2>
				<p>
					Os honorários dependem do tipo de demanda, do escopo, da complexidade, da urgência
					e da necessidade de acompanhamento. Não há tabela promocional no site.
				</p>
				<ul class="info-list">
					<li>Análise técnica do problema apresentado.</li>
					<li>Definição clara do que será feito e do que não está incluído.</li>
					<li>Proposta formal, compatível com as normas éticas da advocacia.</li>
				</ul>
			</article>

			<article class="surface-card info-card">
				<span class="section-kicker">Contratação formal</span>
				<h2>O que você recebe antes de contratar</h2>
				<p>
					Antes de qualquer início de trabalho, a PAVIE esclarece escopo, etapas, forma de
					acompanhamento, honorários e documentos necessários para a condução jurídica.
				</p>
				<ul class="info-list">
					<li>Escopo e objetivos do trabalho.</li>
					<li>Etapas, prazos práticos e responsabilidades.</li>
					<li>Forma de comunicação e registro da contratação.</li>
				</ul>
			</article>
		</section>

		<section id="faq" class="site-section" aria-labelledby="faq-title">
			<div class="section-title">
				<div>
					<span class="section-kicker">Perguntas frequentes</span>
					<h2 id="faq-title">Respostas curtas para atritos reais do primeiro contato</h2>
				</div>
			</div>

			<div class="faq-list">
				{faq.map((item) => (
					<details class="surface-card">
						<summary>{item.q}</summary>
						<p>{item.a}</p>
					</details>
				))}
			</div>
		</section>

		<section id="contato" class="site-contact surface-card" aria-labelledby="contato-title">
			<div>
				<span class="section-kicker">Contato final</span>
				<h2 id="contato-title">
					Descreva sua situação. O primeiro passo é entender o contexto com o mínimo necessário para triagem.
				</h2>
				<p>
					O contato institucional pode seguir por formulário, e-mail ou WhatsApp. O objetivo do
					primeiro retorno é entender o contexto, e não prometer desfecho antecipado.
				</p>
			</div>

			<div class="site-contact__grid">
				<article class="site-contact__panel">
					<h3>O que informar</h3>
					<ul>
						<li>Situação principal e desde quando ela ocorre.</li>
						<li>Pessoas, documentos ou contratos envolvidos.</li>
						<li>Se existe prazo, audiência ou urgência prática.</li>
					</ul>
				</article>

				<article class="site-contact__panel">
					<h3>O que acontece depois</h3>
					<ul>
						<li>A equipe faz a triagem inicial do que foi enviado.</li>
						<li>Se necessário, orienta consulta, envio complementar ou proposta.</li>
						<li>A contratação só ocorre com escopo definido e aceite formal.</li>
					</ul>
				</article>
			</div>

			<div class="site-contact__actions">
				<a class="btn btn-primary" href="/contato/">Enviar Solicitação</a>
			</div>

			<p class="site-contact__note">
				A PAVIE promete leitura inicial responsável, confidencialidade e orientação adequada ao
				contexto apresentado. Não promete resultado, prazo judicial fechado ou admissão automática do caso.
			</p>
		</section>
	</div>

	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
</BaseLayout>
