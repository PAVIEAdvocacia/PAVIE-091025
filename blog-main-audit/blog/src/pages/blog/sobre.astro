---
import Breadcrumbs from '../../components/blog/Breadcrumbs.astro';
import { BLOG_SITE_URL } from '../../consts';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { buildBreadcrumbSchema } from '../../lib/seo';

const title = 'Sobre o autor | Blog PAVIE | Advocacia';
const description =
	'Perfil profissional de Fabio Mathias Pavie, advogado responsável pelos conteúdos jurídicos do blog da PAVIE | Advocacia.';
const canonicalUrl = `${BLOG_SITE_URL}/blog/sobre/`;
const breadcrumbs = [
	{ label: 'Início', href: '/' },
	{ label: 'Publicações', href: '/blog/' },
	{ label: 'Sobre o autor' },
];
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);
---

<BlogLayout title={title} description={description} canonical={canonicalUrl}>
	<div class="container blog-home">
		<Breadcrumbs items={breadcrumbs} />
		<section class="surface-card blog-author-spotlight" aria-label="Perfil do autor do blog">
			<img
				src="/uploads/foto_001-ffundddo-escrit%C3%B3rio.png"
				alt="Foto profissional do advogado Fabio Mathias Pavie"
				loading="eager"
			/>
			<div>
				<span class="section-kicker">Autor do blog</span>
				<h1>Fabio Mathias Pavie</h1>
				<p>Advogado | OAB/RJ 134.947</p>
				<p>
					Atuação em direito de família, sucessões, patrimônio e conflitos cíveis, com foco em
					clareza jurídica, prevenção de risco e condução responsável.
				</p>
				<p>Mais de 20 anos de experiência jurídica.</p>
				<div class="site-hero__cta">
					<a class="btn btn-primary" href="/areas/">Conheça os Serviços</a>
					<a class="btn btn-ghost" href="/blog/">Explorar temas</a>
				</div>
			</div>
		</section>
	</div>

	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BlogLayout>
