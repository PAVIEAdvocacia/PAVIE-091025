---
import type { BlogPost } from '../../lib/posts';

interface Props {
	posts: BlogPost[];
	title?: string;
	emptyHref?: string;
	emptyLabel?: string;
}

const { posts, title = 'Leituras relacionadas', emptyHref = '/blog/areas/', emptyLabel = 'Explorar temas' } = Astro.props;
---

<section class="related-posts" aria-labelledby="related-posts-title">
	<h3 id="related-posts-title">{title}</h3>
	{posts.length > 0 ? (
		posts.map((post) => (
			<article>
				<p class="related-posts__meta">{post.area} · Leitura de {post.readingTime} min</p>
				<h4>
					<a href={post.url}>{post.title}</a>
				</h4>
				<p>{post.excerpt}</p>
			</article>
		))
	) : (
		<div class="related-posts__empty">
			<p class="text-muted">Novos artigos desta área entram aos poucos. Enquanto isso, você pode seguir pela navegação por assunto.</p>
			<a class="btn btn-ghost" href={emptyHref}>{emptyLabel}</a>
		</div>
	)}
</section>
