---
interface Props {
	audioUrl?: string;
	transcriptUrl?: string;
	audioStatus: 'none' | 'planned' | 'published';
}

const { audioUrl, transcriptUrl, audioStatus } = Astro.props;

const hasPlayableAudio = audioStatus === 'published' && Boolean(audioUrl);
---

<section class="audio-player" aria-labelledby="audio-player-title">
	<div class="audio-player__meta">
		<span id="audio-player-title">Narracao do artigo</span>
		<span>{hasPlayableAudio ? 'Disponivel' : audioStatus === 'planned' ? 'Em producao' : 'Nao disponivel'}</span>
	</div>

	{hasPlayableAudio ? (
		<audio controls preload="none" src={audioUrl}>
			Seu navegador nao suporta audio HTML5.
		</audio>
	) : (
		<p class="text-muted">A versao em audio sera publicada nesta pagina quando finalizada.</p>
	)}

	{transcriptUrl && (
		<a href={transcriptUrl}>
			Acessar transcricao
		</a>
	)}
</section>
