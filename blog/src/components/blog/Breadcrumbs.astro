---
interface BreadcrumbItem {
	label: string;
	href?: string;
}

interface Props {
	items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb">
	<ol class="breadcrumbs">
		{items.map((item) => (
			<li>
				{item.href ? <a href={item.href}>{item.label}</a> : <span aria-current="page">{item.label}</span>}
			</li>
		))}
	</ol>
</nav>
