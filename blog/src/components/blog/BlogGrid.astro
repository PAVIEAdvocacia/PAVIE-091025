---
import type { BlogPost } from '../../lib/posts';
import type { EditorialAnalyticsEventName, EditorialSurface } from '../../lib/editorial-analytics';
import BlogCard from './BlogCard.astro';

interface Props {
	id?: string;
	title: string;
	kicker?: string;
	posts?: BlogPost[];
	compact?: boolean;
	emptyTitle?: string;
	emptyText?: string;
	emptyHref?: string;
	emptyLabel?: string;
	analyticsSurfaceOrigin?: EditorialSurface;
	articleEventName?: EditorialAnalyticsEventName;
	categoryEventName?: EditorialAnalyticsEventName;
}

const {
	id,
	title,
	kicker,
	posts = [],
	compact = false,
	emptyTitle = 'Acervo em preparação',
	emptyText = 'Esta seleção já está estruturada e receberá textos conforme avançarem por revisão editorial e jurídica.',
	emptyHref = '/blog/',
	emptyLabel = 'Voltar ao blog',
	analyticsSurfaceOrigin,
	articleEventName,
	categoryEventName,
} = Astro.props;

const safePosts = Array.isArray(posts) ? posts : [];
const hasPosts = safePosts.length > 0;
---

<section id={id} class="blog-grid" aria-label={title}>
	<div class="section-title">
		<div>
			{kicker && <span class="section-kicker">{kicker}</span>}
			<h2>{title}</h2>
		</div>
	</div>

	<div class:list={['blog-grid', compact ? 'blog-grid--compact' : 'blog-grid--cards']}>
		{hasPosts ? (
			safePosts.map((post) => (
				<BlogCard
					post={post}
					analyticsSurfaceOrigin={analyticsSurfaceOrigin}
					articleEventName={articleEventName}
					categoryEventName={categoryEventName}
				/>
			))
		) : (
			<article class="surface-card empty-state blog-grid__empty">
				<h3>{emptyTitle}</h3>
				<p>{emptyText}</p>
				<a class="btn btn-ghost" href={emptyHref}>{emptyLabel}</a>
			</article>
		)}
	</div>
</section>
