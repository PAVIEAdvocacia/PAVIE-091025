---
import type { BlogPost } from '../../lib/posts';
import BlogCard from './BlogCard.astro';

interface Props {
	id?: string;
	title: string;
	kicker?: string;
	posts?: BlogPost[];
	compact?: boolean;
	emptyTitle?: string;
	emptyText?: string;
	emptyHref?: string;
	emptyLabel?: string;
}

const {
	id,
	title,
	kicker,
	posts = [],
	compact = false,
	emptyTitle = 'Acervo em preparacao',
	emptyText = 'Esta selecao ja esta estruturada e recebera textos conforme avancarem por revisao editorial e juridica.',
	emptyHref = '/blog/categoria/',
	emptyLabel = 'Explorar temas',
} = Astro.props;

const safePosts = Array.isArray(posts) ? posts : [];
const hasPosts = safePosts.length > 0;
---

<section id={id} class="blog-grid" aria-label={title}>
	<div class="section-title">
		<div>
			{kicker && <span class="section-kicker">{kicker}</span>}
			<h2>{title}</h2>
		</div>
	</div>

	<div class:list={['blog-grid', compact ? 'blog-grid--compact' : 'blog-grid--cards']}>
		{hasPosts ? (
			safePosts.map((post) => <BlogCard post={post} />)
		) : (
			<article class="surface-card empty-state blog-grid__empty">
				<h3>{emptyTitle}</h3>
				<p>{emptyText}</p>
				<a class="btn btn-ghost" href={emptyHref}>{emptyLabel}</a>
			</article>
		)}
	</div>
</section>
