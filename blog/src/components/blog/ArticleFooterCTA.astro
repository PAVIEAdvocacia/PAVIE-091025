---
interface Props {
	href: string;
	description: string;
	label?: string;
	intent?: string;
	analyticsAttributes?: Record<string, string>;
}

const {
	href,
	description,
	label = 'Conheça a área correspondente',
	intent = 'area',
	analyticsAttributes = {},
} = Astro.props;
---

<section
	class="reading-next-step"
	aria-label="Próximo passo após a leitura"
	data-experiment-key="b3-cta-tonal-band"
	data-base-variant="standard"
>
	<div>
		<span class="section-kicker">Transição para o site</span>
		<h2>Quando a leitura já localiza o tema, o próximo passo é consultar a área correspondente.</h2>
		<p>{description}</p>
	</div>
	<div class="reading-bridge__actions">
		<a
			class="btn btn-primary"
			href={href}
			data-cta-origin="article-final"
			data-cta-intent={intent}
			data-link-origin="article-final"
			data-link-target="area"
			{...analyticsAttributes}
		>
			{label}
		</a>
	</div>
	<p class="reading-ethics-note">Conteúdo informativo. Cada caso exige análise técnica individual.</p>
</section>
