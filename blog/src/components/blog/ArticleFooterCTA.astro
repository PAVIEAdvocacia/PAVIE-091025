---
interface Props {
	href: string;
	description: string;
	label?: string;
	intent?: string;
	target?: string;
	analyticsAttributes?: Record<string, string>;
}

const {
	href,
	description,
	label = 'Ver próximo passo',
	intent = 'area',
	target,
	analyticsAttributes = {},
} = Astro.props;

const dataLinkTarget = target ?? (intent === 'area' ? 'area' : 'site-contact');
---

<section class="reading-next-step" aria-label="Próximo passo após a leitura" data-b3-final-cta="true">
	<div>
		<span class="section-kicker">Próximo passo</span>
		<h2>Use a leitura como ponto de partida para organizar a análise.</h2>
		<p>{description}</p>
	</div>
	<div class="reading-bridge__actions">
		<a
			class="btn btn-primary"
			href={href}
			data-cta-origin="article-final"
			data-cta-intent={intent}
			data-link-origin="article-final"
			data-link-target={dataLinkTarget}
			{...analyticsAttributes}
		>
			{label}
		</a>
	</div>
	<p class="reading-ethics-note">Este conteúdo tem caráter informativo. Para o caso concreto, é preciso avaliar fatos, documentos, contexto e estratégia.</p>
</section>
