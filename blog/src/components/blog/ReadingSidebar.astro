---
import type { TocItem } from '../../lib/toc';
import type { CanonicalAreaDirectoryItem } from '../../lib/canonical-directory';
import type { BlogPost } from '../../lib/posts';
import ReadingTOC from './ReadingTOC.astro';

interface Props {
	toc: TocItem[];
	supportPosts?: BlogPost[];
	categories?: CanonicalAreaDirectoryItem[];
	currentCategoryCode?: string;
}

const {
	toc,
	supportPosts = [],
	categories = [],
	currentCategoryCode,
} = Astro.props;
---

<aside class="reading-sidebar" aria-label="Apoio de leitura">
	{toc.length > 1 && <ReadingTOC items={toc} />}

	{categories.length > 0 && (
		<section class="reading-panel reading-sidebar-block" aria-labelledby="sidebar-categories-title">
			<h2 id="sidebar-categories-title">Categorias</h2>
			<ul class="reading-sidebar-list">
				{categories.map((category) => (
					<li>
						<a
							href={category.categoryHref}
							aria-current={category.code === currentCategoryCode ? 'page' : undefined}
							data-link-origin="article-sidebar"
							data-link-target="category"
						>
							<span>{category.code}</span>
							<strong>{category.displayTitle}</strong>
						</a>
					</li>
				))}
			</ul>
		</section>
	)}

	{supportPosts.length > 0 && (
		<section class="reading-panel reading-sidebar-block" aria-labelledby="support-posts-title">
			<h2 id="support-posts-title">Leituras da mesma categoria</h2>
			<ol class="reading-sidebar-list">
				{supportPosts.map((post) => (
					<li>
						<a
							href={post.url}
							data-link-origin="article-sidebar"
							data-link-target="related-article"
						>
							<span>{post.area}</span>
							<strong>{post.title}</strong>
						</a>
					</li>
				))}
			</ol>
		</section>
	)}
</aside>
