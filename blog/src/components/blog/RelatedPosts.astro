---
import type { BlogPost } from '../../lib/posts';
import RelatedReads from './RelatedReads.astro';

interface Props {
	posts: BlogPost[];
	title?: string;
	emptyHref?: string;
	emptyLabel?: string;
}

const { posts, title, emptyHref, emptyLabel } = Astro.props;
---

<RelatedReads posts={posts} title={title} emptyHref={emptyHref} emptyLabel={emptyLabel} />
