---
import type { BlogPost } from '../../lib/posts';
import {
	editorialAnalyticsAttributes,
	postAnalyticsContext,
	type EditorialAnalyticsEventName,
	type EditorialSurface,
} from '../../lib/editorial-analytics';

interface Props {
	post: BlogPost;
	analyticsSurfaceOrigin?: EditorialSurface;
	articleEventName?: EditorialAnalyticsEventName;
	categoryEventName?: EditorialAnalyticsEventName;
}

const { post, analyticsSurfaceOrigin, articleEventName, categoryEventName } = Astro.props;
const dateLabel = post.publishedAt
	? post.publishedAt.toLocaleDateString('pt-BR', { dateStyle: 'medium' })
	: 'Sem data';
const baseAnalyticsContext = postAnalyticsContext(post);
const articleAnalyticsAttrs =
	analyticsSurfaceOrigin && articleEventName
		? editorialAnalyticsAttributes({
				eventName: articleEventName,
				surfaceOrigin: analyticsSurfaceOrigin,
				surfaceTarget: 'B3',
				linkType: 'article-link',
				...baseAnalyticsContext,
			})
		: {};
const categoryAnalyticsAttrs =
	analyticsSurfaceOrigin && categoryEventName
		? editorialAnalyticsAttributes({
				eventName: categoryEventName,
				surfaceOrigin: analyticsSurfaceOrigin,
				surfaceTarget: 'B2',
				linkType: 'category-link',
				...baseAnalyticsContext,
			})
		: {};
---

<article class="blog-card">
	<a
		class="blog-card__media blog-card__media-link"
		href={post.url}
		aria-label={`Ler artigo: ${post.title}`}
		data-link-origin="blog-card"
		data-link-target="article"
		{...articleAnalyticsAttrs}
	>
		{post.image ? (
			<img src={post.image} alt={post.imageAlt} loading="lazy" />
		) : (
			<div class="blog-card__placeholder" role="presentation">
				PAVIE
			</div>
		)}
	</a>
	<div class="blog-card__body">
		{post.categoryUrl ? (
			<a
				class="badge blog-card__category"
				href={post.categoryUrl}
				data-link-origin="blog-card"
				data-link-target="category"
				{...categoryAnalyticsAttrs}
			>
				{post.area}
			</a>
		) : (
			<span class="badge">{post.area}</span>
		)}
		<h3 class="blog-card__title">
			<a
				class="blog-card__title-link"
				href={post.url}
				data-link-origin="blog-card"
				data-link-target="article"
				{...articleAnalyticsAttrs}
			>
				{post.title}
			</a>
		</h3>
		<p class="blog-card__excerpt">{post.excerpt}</p>
		<div class="blog-card__meta">
			<span>{dateLabel}</span>
			<span>{post.readingTime} min</span>
		</div>
		<a
			class="blog-card__arrow"
			href={post.url}
			data-link-origin="blog-card"
			data-link-target="article"
			{...articleAnalyticsAttrs}
		>
			Ler artigo completo <span aria-hidden="true">-&gt;</span>
		</a>
	</div>
</article>
