---
import type { BlogPost } from '../../lib/posts';

interface Props {
	post: BlogPost;
}

const { post } = Astro.props;
const dateLabel = post.publishedAt
	? post.publishedAt.toLocaleDateString('pt-BR', { dateStyle: 'medium' })
	: 'Sem data';
---

<article class="blog-card">
	<a
		class="blog-card__media blog-card__media-link"
		href={post.url}
		aria-label={`Ler artigo: ${post.title}`}
		data-link-origin="blog-card"
		data-link-target="article"
	>
		{post.image ? (
			<img src={post.image} alt={post.imageAlt} loading="lazy" />
		) : (
			<div class="blog-card__placeholder" role="presentation">
				PAVIE
			</div>
		)}
	</a>
	<div class="blog-card__body">
		{post.categoryUrl ? (
			<a
				class="badge blog-card__category"
				href={post.categoryUrl}
				data-link-origin="blog-card"
				data-link-target="category"
			>
				{post.area}
			</a>
		) : (
			<span class="badge">{post.area}</span>
		)}
		<h3 class="blog-card__title">
			<a
				class="blog-card__title-link"
				href={post.url}
				data-link-origin="blog-card"
				data-link-target="article"
			>
				{post.title}
			</a>
		</h3>
		<p class="blog-card__excerpt">{post.excerpt}</p>
		<div class="blog-card__meta">
			<span>{dateLabel}</span>
			<span>{post.readingTime} min</span>
		</div>
		<a
			class="blog-card__arrow"
			href={post.url}
			data-link-origin="blog-card"
			data-link-target="article"
		>
			Ler artigo completo <span aria-hidden="true">-&gt;</span>
		</a>
	</div>
</article>
