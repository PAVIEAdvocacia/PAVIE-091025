---
import type { BlogPost } from '../../lib/posts';

interface Props {
	post: BlogPost;
}

const { post } = Astro.props;
const dateLabel = post.publishedAt
	? post.publishedAt.toLocaleDateString('pt-BR', { dateStyle: 'medium' })
	: 'Sem data';
---

<a class="blog-card" href={post.url} aria-label={`Ler artigo: ${post.title}`}>
	<div class="blog-card__media">
		{post.image ? (
			<img src={post.image} alt={post.imageAlt} loading="lazy" />
		) : (
			<div class="blog-card__placeholder" role="presentation">
				PAVIE
			</div>
		)}
	</div>
	<div class="blog-card__body">
		<span class="badge">{post.area}</span>
		<h3 class="blog-card__title">{post.title}</h3>
		<p class="blog-card__excerpt">{post.excerpt}</p>
		<div class="blog-card__meta">
			<span>{dateLabel}</span>
			<span>{post.readingTime} min</span>
		</div>
		<span class="blog-card__arrow">Ler artigo completo <span aria-hidden="true">-&gt;</span></span>
	</div>
</a>
