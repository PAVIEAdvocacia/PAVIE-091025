---
import type { CanonicalAreaDirectoryItem } from '../../lib/canonical-directory';

interface Props {
	categories: CanonicalAreaDirectoryItem[];
	title?: string;
	kicker?: string;
}

const {
	categories,
	title = 'Categorias canônicas do blog',
	kicker = 'Classificação temática',
} = Astro.props;
---

<section class="category-grid-block" aria-labelledby="category-grid-title">
	<div class="section-title">
		<div>
			<span class="section-kicker">{kicker}</span>
			<h2 id="category-grid-title">{title}</h2>
		</div>
	</div>

	<div class="category-grid">
		{categories.map((category, index) => (
			<article class="category-card">
				<span class="category-card__code">{String(index + 1).padStart(2, '0')}</span>
				<h3>{category.displayTitle}</h3>
				<p>{category.shortDescription}</p>
				<div class="category-card__meta">
					<span>
						{category.postCount > 0
							? `${category.postCount} leitura${category.postCount === 1 ? '' : 's'}`
							: 'acervo em preparação'}
					</span>
				</div>
				<div class="category-card__actions">
					<a class="btn btn-primary" href={category.categoryHref}>Explorar categoria</a>
					<a class="btn btn-ghost" href={category.href}>Conhecer área</a>
				</div>
			</article>
		))}
	</div>
</section>
