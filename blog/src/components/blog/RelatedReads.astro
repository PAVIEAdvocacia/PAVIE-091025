---
import type { BlogPost } from '../../lib/posts';
import {
	EDITORIAL_ANALYTICS_EVENTS,
	editorialAnalyticsAttributes,
	postAnalyticsContext,
} from '../../lib/editorial-analytics';

interface Props {
	posts: BlogPost[];
	title?: string;
	emptyHref?: string;
	emptyLabel?: string;
	sourcePost?: BlogPost;
}

const {
	posts,
	title = 'Leituras relacionadas',
	emptyHref = '/blog/',
	emptyLabel = 'Voltar ao blog',
	sourcePost,
} = Astro.props;
const sourceContext = sourcePost ? postAnalyticsContext(sourcePost) : undefined;
---

<section class="related-posts" aria-labelledby="related-posts-title">
	<h3 id="related-posts-title">{title}</h3>
	{posts.length > 0 ? (
		posts.map((post) => (
			<article>
				<p class="related-posts__meta">{post.area} · Leitura de {post.readingTime} min</p>
				<h4>
					<a
						href={post.url}
						data-link-origin="article-related"
						data-link-target="related-article"
						{...editorialAnalyticsAttributes({
							eventName: EDITORIAL_ANALYTICS_EVENTS.B3_RELATED_READ_CLICK,
							surfaceOrigin: 'B3',
							surfaceTarget: 'B3',
							linkType: 'related-read',
							...postAnalyticsContext(post),
							categoryCode: sourceContext?.categoryCode ?? post.categoryCode,
							categorySlug: sourceContext?.categorySlug ?? post.categorySlug,
						})}
					>
						{post.title}
					</a>
				</h4>
				<p>{post.excerpt}</p>
			</article>
		))
	) : (
		<div class="related-posts__empty">
			<p class="text-muted">
				Novos artigos desta área entram aos poucos. Enquanto isso, siga pela navegação por assunto.
			</p>
			<a
				class="btn btn-ghost"
				href={emptyHref}
				data-link-origin="article-related-empty"
				data-link-target={emptyHref.startsWith('/blog/categoria/') ? 'category' : 'blog-home'}
			>
				{emptyLabel}
			</a>
		</div>
	)}
</section>
