---
import type { BlogPost } from '../../lib/posts';

interface Props {
	post: BlogPost;
}

const { post } = Astro.props;
---

<section class="author-card" aria-label="Informacoes do autor">
	<img
		class="author-card__photo"
		src="/uploads/foto_001-ffundddo-escrit%C3%B3rio.png"
		alt={`Foto do advogado ${post.authorName}`}
		loading="lazy"
	/>
	<div class="author-card__body">
		<span class="section-kicker">Responsavel pelo conteudo</span>
		<h3>{post.authorName}</h3>
		<p>{post.authorRole}</p>
		<p class="author-card__note">
			Conteudo produzido no ecossistema de PAVIE | Advocacia para orientar com clareza,
			sem substituir a analise individual do caso.
		</p>
		<a class="author-card__link" href={post.authorUrl ?? '/sobre/'}>Conheca o autor</a>
	</div>
</section>
