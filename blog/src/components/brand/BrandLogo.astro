---
interface Props {
	variant?: 'horizontal' | 'square';
	theme?: 'dark' | 'light';
	width?: number | string;
	alt?: string;
	class?: string;
}

const {
	variant = 'horizontal',
	theme = 'light',
	width = variant === 'square' ? 150 : 190,
	alt = 'PAVIE | Advocacia',
	class: className = '',
} = Astro.props;

const src = `/brand/pavie-logo-${variant}${theme === 'dark' ? '-light' : ''}.png`;
const logoWidth = typeof width === 'number' ? `${width}px` : width;
---

<img
	class:list={['brand-logo', `brand-logo--${variant}`, `brand-logo--${theme}`, className]}
	src={src}
	alt={alt}
	loading="eager"
	decoding="async"
	style={`--brand-logo-width: ${logoWidth};`}
/>

<style>
	.brand-logo {
		display: block;
		inline-size: var(--brand-logo-width);
		max-inline-size: 100%;
		block-size: auto;
	}

	.brand-logo--square {
		inline-size: min(var(--brand-logo-width), 190px);
	}
</style>
