---
import { BLOG_SITE_URL, MAIN_SITE_URL } from '../../consts';
import BrandLogo from '../brand/BrandLogo.astro';
---

<footer class="site-footer" role="contentinfo">
	<div class="container site-footer__grid">
		<section class="site-footer__brand">
			<BrandLogo variant="square" theme="dark" width={165} />
			<p>
				Atendimento jurídico estratégico, técnico e humano para questões que exigem clareza,
				organização documental e direção responsável.
			</p>
			<ul class="site-footer__contact" aria-label="Canais de contato">
				<li><a href="mailto:contato@pavieadvocacia.com.br">contato@pavieadvocacia.com.br</a></li>
				<li><a href="tel:+5521964382263">(21) 96438-2263</a></li>
			</ul>
		</section>

		<nav aria-label="Navegação institucional">
			<h2>Institucional</h2>
			<ul>
				<li><a href={`${MAIN_SITE_URL}/`}>Início</a></li>
				<li><a href={`${MAIN_SITE_URL}/#areas`}>Áreas</a></li>
				<li><a href={`${MAIN_SITE_URL}/#metodo`}>Método</a></li>
				<li><a href={`${MAIN_SITE_URL}/#contato`}>Contato</a></li>
			</ul>
		</nav>

		<nav aria-label="Navegação editorial">
			<h2>Camada editorial</h2>
			<ul>
				<li><a href={`${BLOG_SITE_URL}/blog/`}>Conteúdo do Advogado</a></li>
				<li><a href={`${BLOG_SITE_URL}/blog/categoria/`}>Categorias do blog</a></li>
				<li><a href={`${BLOG_SITE_URL}/autor/fabio-pavie/`}>Autor</a></li>
				<li><a href="/legal/politica-de-privacidade-pavie-advocacia.pdf">Política de privacidade</a></li>
				<li><a href="/legal/termos-de-servico-pavie-advocacia.pdf">Termos de serviço</a></li>
			</ul>
		</nav>
	</div>

	<div class="container site-footer__bottom">
		<p>OAB/RJ 134.947 · Sede no Rio de Janeiro · Atendimento em todo o Brasil</p>
		<p>&copy; 2026 PAVIE | Advocacia. Todos os direitos reservados.</p>
	</div>
</footer>

<style>
	.site-footer {
		padding: clamp(3rem, 7vw, 5rem) 0 var(--space-lg);
		background: linear-gradient(150deg, #002f31, #032425);
		color: var(--text-contrast);
	}

	.site-footer__grid {
		display: grid;
		grid-template-columns: minmax(260px, 1.25fr) minmax(160px, 0.55fr) minmax(190px, 0.72fr);
		gap: clamp(2.25rem, 6vw, 5rem);
		align-items: start;
	}

	.site-footer__brand {
		display: grid;
		gap: var(--space-md);
		max-width: 36ch;
	}

	.site-footer__brand :global(.brand-logo) {
		margin-bottom: 0.1rem;
	}

	.site-footer__brand p,
	.site-footer li,
	.site-footer__bottom p {
		font-size: 0.88rem;
		line-height: 1.65;
		color: color-mix(in srgb, var(--text-contrast) 78%, var(--color-soft));
	}

	.site-footer h2 {
		margin-bottom: var(--space-sm);
		font-family: var(--font-sans);
		font-size: 0.78rem;
		letter-spacing: 0;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--color-sand) 78%, white);
	}

	.site-footer ul {
		list-style: none;
		display: grid;
		gap: 0.42rem;
	}

	.site-footer a {
		color: color-mix(in srgb, var(--text-contrast) 86%, var(--color-soft));
		text-decoration: none;
	}

	.site-footer a:hover,
	.site-footer a:focus-visible {
		color: white;
		text-decoration: underline;
		text-decoration-color: rgba(204, 176, 147, 0.5);
	}

	.site-footer span {
		color: color-mix(in srgb, var(--text-contrast) 66%, var(--color-soft));
	}

	.site-footer__contact {
		padding-top: var(--space-xs);
	}

	.site-footer__bottom {
		margin-top: clamp(2rem, 5vw, 4rem);
		padding-top: var(--space-md);
		border-top: 1px solid rgba(143, 164, 167, 0.2);
		display: flex;
		justify-content: space-between;
		gap: var(--space-md);
		flex-wrap: wrap;
	}

	@media (max-width: 820px) {
		.site-footer__grid {
			grid-template-columns: 1fr;
			gap: var(--space-xl);
		}

		.site-footer__bottom {
			display: grid;
		}
	}
</style>
