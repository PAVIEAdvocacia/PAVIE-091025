---
import {
	BLOG_SITE_URL,
	BUSINESS_ADDRESS,
	BUSINESS_EMAIL,
	BUSINESS_PHONE_DISPLAY,
	BUSINESS_PHONE_E164,
	MAIN_SITE_URL,
} from '../../consts';
import BrandLogo from '../brand/BrandLogo.astro';

interface Props {
	currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const isBlogSurface = currentPath.startsWith('/blog') || currentPath.startsWith('/autor');

const blogLinks = [
	{ label: 'Conteúdos', href: `${BLOG_SITE_URL}/blog/` },
	{ label: 'Categorias', href: `${BLOG_SITE_URL}/blog/categoria/` },
	{ label: 'Autor', href: `${BLOG_SITE_URL}/autor/fabio-pavie/` },
];

const institutionalLinks = [
	{ label: 'Início do site', href: `${MAIN_SITE_URL}/` },
	{ label: 'Áreas de atuação', href: `${MAIN_SITE_URL}/#areas` },
	{ label: 'Contato institucional', href: `${MAIN_SITE_URL}/#contato` },
];

const legalLinks = [
	{ label: 'Política de privacidade', href: '/legal/politica-de-privacidade-pavie-advocacia.pdf' },
	{ label: 'Termos de serviço', href: '/legal/termos-de-servico-pavie-advocacia.pdf' },
];

const siteLinks = [
	{ label: 'Início', href: `${MAIN_SITE_URL}/` },
	{ label: 'Áreas', href: `${MAIN_SITE_URL}/#areas` },
	{ label: 'Método', href: `${MAIN_SITE_URL}/#metodo` },
	{ label: 'Contato', href: `${MAIN_SITE_URL}/#contato` },
];

const blogBridgeLinks = [
	{ label: 'Conteúdo do advogado', href: `${BLOG_SITE_URL}/blog/` },
	{ label: 'Categorias do blog', href: `${BLOG_SITE_URL}/blog/categoria/` },
	{ label: 'Autor', href: `${BLOG_SITE_URL}/autor/fabio-pavie/` },
];

const addressLine = `${BUSINESS_ADDRESS.streetAddress}, ${BUSINESS_ADDRESS.addressLocality} - ${BUSINESS_ADDRESS.addressRegion}`;
---

<footer class:list={['site-footer', isBlogSurface && 'site-footer--blog']} role="contentinfo">
	{isBlogSurface ? (
		<>
			<div class="container site-footer__grid site-footer__grid--blog">
				<section class="site-footer__brand" aria-labelledby="blog-footer-brand">
					<BrandLogo variant="square" theme="dark" width={165} />
					<h2 id="blog-footer-brand" class="site-footer__signature">PAVIE | Advocacia</h2>
					<p>
						Camada editorial para descoberta, maturação temática e retorno disciplinado ao site institucional.
					</p>
				</section>

				<nav aria-label="Links essenciais do blog">
					<h2>Blog</h2>
					<ul>
						{blogLinks.map((link) => (
							<li><a href={link.href}>{link.label}</a></li>
						))}
					</ul>
				</nav>

				<nav aria-label="Ponte para o site institucional">
					<h2>Site institucional</h2>
					<ul>
						{institutionalLinks.map((link) => (
							<li><a href={link.href}>{link.label}</a></li>
						))}
						{legalLinks.map((link) => (
							<li><a href={link.href}>{link.label}</a></li>
						))}
					</ul>
				</nav>

				<section class="site-footer__contact" aria-labelledby="blog-footer-contact">
					<h2 id="blog-footer-contact">Contato</h2>
					<ul>
						<li><a href={`mailto:${BUSINESS_EMAIL}`}>{BUSINESS_EMAIL}</a></li>
						<li><a href={`tel:${BUSINESS_PHONE_E164}`}>{BUSINESS_PHONE_DISPLAY}</a></li>
						<li>{addressLine}</li>
					</ul>
				</section>
			</div>

			<div class="container site-footer__notice" role="note">
				<p>Conteúdo público e informativo. Não substitui análise jurídica individual.</p>
			</div>
		</>
	) : (
		<div class="container site-footer__grid">
			<section class="site-footer__brand" aria-labelledby="site-footer-brand">
				<BrandLogo variant="square" theme="dark" width={165} />
				<h2 id="site-footer-brand" class="site-footer__signature">PAVIE | Advocacia</h2>
				<p>
					Atendimento jurídico estratégico, técnico e humano para questões que exigem clareza,
					organização documental e direção responsável.
				</p>
				<ul class="site-footer__compact-list" aria-label="Canais de contato">
					<li><a href={`mailto:${BUSINESS_EMAIL}`}>{BUSINESS_EMAIL}</a></li>
					<li><a href={`tel:${BUSINESS_PHONE_E164}`}>{BUSINESS_PHONE_DISPLAY}</a></li>
				</ul>
			</section>

			<nav aria-label="Navegação institucional">
				<h2>Institucional</h2>
				<ul>
					{siteLinks.map((link) => (
						<li><a href={link.href}>{link.label}</a></li>
					))}
				</ul>
			</nav>

			<nav aria-label="Navegação editorial">
				<h2>Camada editorial</h2>
				<ul>
					{blogBridgeLinks.map((link) => (
						<li><a href={link.href}>{link.label}</a></li>
					))}
					{legalLinks.map((link) => (
						<li><a href={link.href}>{link.label}</a></li>
					))}
				</ul>
			</nav>
		</div>
	)}

	<div class="container site-footer__bottom">
		<p>OAB/RJ 134.947 · Sede no Rio de Janeiro · Atendimento em todo o Brasil</p>
		<p>&copy; 2026 PAVIE | Advocacia. Todos os direitos reservados.</p>
	</div>
</footer>

<style>
	.site-footer {
		position: relative;
		overflow: hidden;
		padding: clamp(3rem, 7vw, 5rem) 0 var(--space-lg);
		background: #2c2c2c;
		color: var(--text-contrast);
	}

	.site-footer::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background-image:
			linear-gradient(135deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px),
			linear-gradient(45deg, rgba(151, 29, 37, 0.045) 1px, transparent 1px);
		background-size: 16px 16px;
		opacity: 0.18;
	}

	.site-footer__grid,
	.site-footer__notice,
	.site-footer__bottom {
		position: relative;
		z-index: 1;
	}

	.site-footer__grid {
		display: grid;
		grid-template-columns: minmax(260px, 1.25fr) minmax(160px, 0.55fr) minmax(190px, 0.72fr);
		gap: clamp(2.25rem, 6vw, 5rem);
		align-items: start;
	}

	.site-footer__grid--blog {
		grid-template-columns: minmax(260px, 1.25fr) minmax(150px, 0.5fr) minmax(190px, 0.7fr) minmax(190px, 0.68fr);
	}

	.site-footer__brand {
		display: grid;
		gap: var(--space-sm);
		max-width: 38ch;
	}

	.site-footer__brand :global(.brand-logo) {
		margin-bottom: 0.15rem;
	}

	.site-footer__signature {
		font-family: var(--font-serif);
		font-size: 1.22rem;
		letter-spacing: 0;
		text-transform: none;
		color: white;
	}

	.site-footer__brand p,
	.site-footer li,
	.site-footer__notice p,
	.site-footer__bottom p {
		font-size: 0.88rem;
		line-height: 1.65;
		color: color-mix(in srgb, var(--text-contrast) 78%, var(--color-soft));
	}

	.site-footer h2 {
		margin-bottom: var(--space-sm);
		font-family: var(--font-sans);
		font-size: 0.78rem;
		letter-spacing: 0;
		text-transform: uppercase;
		color: color-mix(in srgb, white 82%, var(--color-mist));
	}

	.site-footer ul {
		list-style: none;
		display: grid;
		gap: 0.42rem;
	}

	.site-footer a {
		color: color-mix(in srgb, var(--text-contrast) 86%, var(--color-soft));
		text-decoration: none;
		text-underline-offset: 0.18em;
	}

	.site-footer a:hover,
	.site-footer a:focus-visible {
		color: white;
		text-decoration: underline;
		text-decoration-color: rgba(151, 29, 37, 0.5);
	}

	.site-footer__compact-list {
		padding-top: var(--space-xs);
	}

	.site-footer__contact {
		display: grid;
		gap: var(--space-sm);
	}

	.site-footer__notice {
		margin-top: clamp(2rem, 4vw, 3rem);
		padding-top: var(--space-md);
		border-top: 1px solid rgba(143, 164, 167, 0.22);
	}

	.site-footer__notice p {
		position: relative;
		max-width: 62ch;
		padding-left: 0.85rem;
	}

	.site-footer__notice p::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.45em;
		width: 0.22rem;
		height: 0.22rem;
		border-radius: 50%;
		background: var(--color-accent);
	}

	.site-footer__bottom {
		margin-top: clamp(1.2rem, 3vw, 2rem);
		padding-top: var(--space-md);
		border-top: 1px solid rgba(143, 164, 167, 0.2);
		display: flex;
		justify-content: space-between;
		gap: var(--space-md);
		flex-wrap: wrap;
	}

	@media (max-width: 980px) {
		.site-footer__grid,
		.site-footer__grid--blog {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: var(--space-xl);
		}
	}

	@media (max-width: 680px) {
		.site-footer__grid,
		.site-footer__grid--blog {
			grid-template-columns: 1fr;
		}

		.site-footer__bottom {
			display: grid;
		}
	}
</style>
