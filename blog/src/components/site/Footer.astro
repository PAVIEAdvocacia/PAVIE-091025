---
import {
	BLOG_SITE_URL,
	BUSINESS_ADDRESS,
	BUSINESS_EMAIL,
	BUSINESS_PHONE_DISPLAY,
	BUSINESS_PHONE_E164,
	MAIN_SITE_URL,
} from '../../consts';
import BrandLogo from '../brand/BrandLogo.astro';

interface Props {
	currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const isBlogSurface = currentPath.startsWith('/blog');

const institutionalLinks = [
	{ label: 'Inicio do site', href: `${MAIN_SITE_URL}/` },
	{ label: 'Areas de atuacao', href: `${MAIN_SITE_URL}/#areas` },
	{ label: 'Metodo', href: `${MAIN_SITE_URL}/#metodo` },
	{ label: 'Contato institucional', href: `${MAIN_SITE_URL}/contato/` },
];

const editorialLinks = [
	{ label: 'Home de conteudos', href: `${BLOG_SITE_URL}/blog/` },
	{ label: 'Autor', href: `${BLOG_SITE_URL}/blog/autor/fabio-pavie/` },
];

const legalLinks = [
	{ label: 'Politica de privacidade', href: '/legal/politica-de-privacidade-pavie-advocacia.pdf' },
	{ label: 'Termos de servico', href: '/legal/termos-de-servico-pavie-advocacia.pdf' },
];

const addressLine = `${BUSINESS_ADDRESS.streetAddress}, ${BUSINESS_ADDRESS.addressLocality} - ${BUSINESS_ADDRESS.addressRegion}`;
const signatureText = isBlogSurface
	? 'Camada editorial para descoberta, organizacao de contexto e retorno disciplinado ao site institucional.'
	: 'Sede institucional para areas, metodo, honorarios, fluxo de entrada e contato tecnico inicial.';
const noticeText = isBlogSurface
	? 'Conteudo publico e informativo. O blog qualifica a leitura; a analise individual acontece na camada institucional.'
	: 'Contato inicial nao e contratacao automatica. Toda orientacao depende de triagem, documentos e analise tecnica proporcional.';
---

<footer
	class="site-footer"
	role="contentinfo"
	data-experiment-key="r1-footer-accent-soft"
	data-base-variant="standard"
>
	<div class="container site-footer__grid">
		<section class="site-footer__brand" aria-labelledby="site-footer-brand">
			<BrandLogo variant="square" theme="dark" width={165} />
			<h2 id="site-footer-brand" class="site-footer__signature">PAVIE | Advocacia</h2>
			<p>{signatureText}</p>
		</section>

		<nav aria-label="Navegacao institucional">
			<h2>Institucional</h2>
			<ul>
				{institutionalLinks.map((link) => (
					<li><a href={link.href}>{link.label}</a></li>
				))}
			</ul>
		</nav>

		<nav aria-label="Ponte editorial">
			<h2>Conteudos</h2>
			<ul>
				{editorialLinks.map((link) => (
					<li><a href={link.href}>{link.label}</a></li>
				))}
			</ul>
		</nav>

		<section class="site-footer__contact" aria-labelledby="site-footer-contact">
			<h2 id="site-footer-contact">Contato e base legal</h2>
			<ul>
				<li><a href={`mailto:${BUSINESS_EMAIL}`}>{BUSINESS_EMAIL}</a></li>
				<li><a href={`tel:${BUSINESS_PHONE_E164}`}>{BUSINESS_PHONE_DISPLAY}</a></li>
				<li><a href={`${MAIN_SITE_URL}/contato/`}>Fluxo de entrada institucional</a></li>
				<li>{addressLine}</li>
				{legalLinks.map((link) => (
					<li><a href={link.href}>{link.label}</a></li>
				))}
			</ul>
		</section>
	</div>

	<div class="container site-footer__notice" role="note">
		<p>{noticeText}</p>
	</div>

	<div class="container site-footer__bottom">
		<p>OAB/RJ 134.947 · Sede no Rio de Janeiro · Atendimento em todo o Brasil</p>
		<p>&copy; 2026 PAVIE | Advocacia. Todos os direitos reservados.</p>
	</div>
</footer>

<style>
	.site-footer {
		position: relative;
		overflow: hidden;
		padding: clamp(3rem, 7vw, 5rem) 0 var(--space-lg);
		background: #2c2c2c;
		color: var(--text-contrast);
	}

	.site-footer::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background-image:
			linear-gradient(135deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px),
			linear-gradient(45deg, rgba(151, 29, 37, 0.045) 1px, transparent 1px);
		background-size: 16px 16px;
		opacity: 0.18;
	}

	.site-footer__grid,
	.site-footer__notice,
	.site-footer__bottom {
		position: relative;
		z-index: 1;
	}

	.site-footer__grid {
		display: grid;
		grid-template-columns: minmax(260px, 1.25fr) repeat(3, minmax(170px, 0.62fr));
		gap: clamp(2.25rem, 6vw, 4.2rem);
		align-items: start;
	}

	.site-footer__brand {
		display: grid;
		gap: var(--space-sm);
		max-width: 38ch;
	}

	.site-footer__brand :global(.brand-logo) {
		margin-bottom: 0.15rem;
	}

	.site-footer__signature {
		font-family: var(--font-serif);
		font-size: 1.22rem;
		letter-spacing: 0;
		text-transform: none;
		color: white;
	}

	.site-footer__brand p,
	.site-footer li,
	.site-footer__notice p,
	.site-footer__bottom p {
		font-size: 0.88rem;
		line-height: 1.65;
		color: color-mix(in srgb, var(--text-contrast) 78%, var(--color-soft));
	}

	.site-footer h2 {
		margin-bottom: var(--space-sm);
		font-family: var(--font-sans);
		font-size: 0.78rem;
		letter-spacing: 0;
		text-transform: uppercase;
		color: color-mix(in srgb, white 82%, var(--color-mist));
	}

	.site-footer ul {
		list-style: none;
		display: grid;
		gap: 0.42rem;
	}

	.site-footer a {
		color: color-mix(in srgb, var(--text-contrast) 86%, var(--color-soft));
		text-decoration: none;
		text-underline-offset: 0.18em;
	}

	.site-footer a:hover,
	.site-footer a:focus-visible {
		color: white;
		text-decoration: underline;
		text-decoration-color: rgba(151, 29, 37, 0.5);
	}

	.site-footer__contact {
		display: grid;
		gap: var(--space-sm);
	}

	.site-footer__notice {
		margin-top: clamp(2rem, 4vw, 3rem);
		padding-top: var(--space-md);
		border-top: 1px solid rgba(143, 164, 167, 0.22);
	}

	.site-footer__notice p {
		position: relative;
		max-width: 72ch;
		padding-left: 0.85rem;
	}

	.site-footer__notice p::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.45em;
		width: 0.22rem;
		height: 0.22rem;
		border-radius: 50%;
		background: var(--color-accent);
	}

	.site-footer__bottom {
		margin-top: clamp(1.2rem, 3vw, 2rem);
		padding-top: var(--space-md);
		border-top: 1px solid rgba(143, 164, 167, 0.2);
		display: flex;
		justify-content: space-between;
		gap: var(--space-md);
		flex-wrap: wrap;
	}

	@media (max-width: 980px) {
		.site-footer__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: var(--space-xl);
		}
	}

	@media (max-width: 680px) {
		.site-footer__grid {
			grid-template-columns: 1fr;
		}

		.site-footer__bottom {
			display: grid;
		}
	}

	:global(body.exp-r1-footer-accent-soft) .site-footer {
		background:
			linear-gradient(180deg, rgba(28, 31, 33, 0.98), rgba(21, 24, 25, 1)),
			#1b1e20;
	}

	:global(body.exp-r1-footer-accent-soft) .site-footer::before {
		background-image:
			linear-gradient(135deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px),
			linear-gradient(45deg, rgba(204, 176, 147, 0.035) 1px, transparent 1px);
		background-size: 18px 18px;
		opacity: 0.12;
	}

	:global(body.exp-r1-footer-accent-soft) .site-footer h2 {
		color: color-mix(in srgb, white 78%, var(--color-sand));
	}

	:global(body.exp-r1-footer-accent-soft) .site-footer a:hover,
	:global(body.exp-r1-footer-accent-soft) .site-footer a:focus-visible {
		text-decoration-color: rgba(204, 176, 147, 0.42);
	}

	:global(body.exp-r1-footer-accent-soft) .site-footer__notice,
	:global(body.exp-r1-footer-accent-soft) .site-footer__bottom {
		border-top-color: rgba(204, 176, 147, 0.16);
	}

	:global(body.exp-r1-footer-accent-soft) .site-footer__notice p::before {
		background: color-mix(in srgb, var(--color-sand) 72%, var(--color-accent));
	}
</style>
