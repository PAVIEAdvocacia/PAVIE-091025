---
import BrandLogo from '../brand/BrandLogo.astro';

interface Props {
	currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navItems = [
	{ href: '/', label: 'Início' },
	{ href: '/areas/', label: 'Áreas' },
	{ href: '/#metodo', label: 'Método' },
	{ href: '/contato/', label: 'Contato' },
];

function isActive(href: string): boolean {
	if (href.includes('#')) return false;
	return currentPath === href || currentPath.startsWith(`${href.replace(/\/$/, '')}/`);
}
---

<header class="site-header" role="banner">
	<div class="site-header__bar container">
		<a class="site-header__brand" href="/" aria-label="PAVIE | Advocacia, início do site institucional">
			<BrandLogo variant="compact" width={124} />
		</a>

		<nav class="site-nav" aria-label="Navegação principal">
			{navItems.map((item) => (
				<a
					href={item.href}
					class:list={['site-nav__link', { 'is-active': isActive(item.href) }]}
				>
					{item.label}
				</a>
			))}
		</nav>

		<a class="site-header__blog-link" href="/blog/">
			Conteúdo do Advogado
			<span aria-hidden="true">+</span>
		</a>

		<details class="site-mobile-nav">
			<summary aria-label="Abrir menu de navegação">Menu</summary>
			<div class="site-mobile-nav__panel">
				{navItems.map((item) => (
					<a href={item.href}>
						{item.label}
					</a>
				))}
				<a href="/blog/">Conteúdo do Advogado</a>
			</div>
		</details>
	</div>
</header>

<style>
	.site-header {
		background: color-mix(in srgb, var(--surface-page) 92%, white);
		border-bottom: 1px solid rgba(216, 208, 198, 0.72);
		position: sticky;
		top: 0;
		z-index: 50;
		backdrop-filter: blur(8px);
	}

	.site-header__bar {
		min-height: 54px;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: var(--space-md);
	}

	.site-header__brand {
		display: inline-flex;
		align-items: center;
		text-decoration: none;
		color: var(--color-graphite);
	}

	.site-nav {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: clamp(1.1rem, 2.4vw, 2.4rem);
	}

	.site-nav__link {
		position: relative;
		padding: 0.25rem 0;
		text-decoration: none;
		font-size: 0.78rem;
		font-weight: 700;
		color: color-mix(in srgb, var(--color-graphite) 84%, var(--color-mist));
	}

	.site-nav__link::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		bottom: -0.28rem;
		height: 1px;
		background: transparent;
	}

	.site-nav__link.is-active {
		color: var(--color-petrol);
	}

	.site-nav__link.is-active::after {
		background: var(--color-accent);
	}

	.site-nav__link:hover,
	.site-nav__link:focus-visible,
	.site-header__blog-link:hover,
	.site-header__blog-link:focus-visible {
		color: var(--color-petrol);
	}

	.site-header__blog-link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.78rem;
		font-weight: 800;
		color: var(--color-petrol);
		text-decoration: none;
		white-space: nowrap;
	}

	.site-header__blog-link span {
		color: var(--color-accent);
		font-size: 0.92rem;
		line-height: 1;
	}

	.site-mobile-nav {
		display: none;
		position: relative;
	}

	.site-mobile-nav summary {
		list-style: none;
		font-weight: 800;
		font-size: 0.9rem;
		cursor: pointer;
		color: var(--color-petrol);
	}

	.site-mobile-nav summary::-webkit-details-marker {
		display: none;
	}

	.site-mobile-nav__panel {
		position: absolute;
		top: 2rem;
		right: 0;
		display: grid;
		gap: var(--space-2xs);
		padding: var(--space-sm);
		min-width: 220px;
		background: var(--surface-card);
		border: 1px solid var(--color-line);
		border-radius: var(--radius-xs);
		box-shadow: var(--shadow-soft);
	}

	.site-mobile-nav__panel a {
		padding: 0.45rem 0.5rem;
		border-radius: var(--radius-xs);
		text-decoration: none;
		font-size: 0.92rem;
		color: var(--color-graphite);
	}

	.site-mobile-nav__panel a:hover,
	.site-mobile-nav__panel a:focus-visible {
		background: color-mix(in srgb, var(--color-soft) 78%, white);
	}

	@media (max-width: 860px) {
		.site-header__bar {
			grid-template-columns: 1fr auto;
		}

		.site-nav,
		.site-header__blog-link {
			display: none;
		}

		.site-mobile-nav {
			display: inline-block;
		}
	}
</style>
