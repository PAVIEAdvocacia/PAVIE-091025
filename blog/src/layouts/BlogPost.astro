---
import type { BlogPost } from '../lib/posts';
import type { TocItem } from '../lib/toc';
import ReadingLayout from './ReadingLayout.astro';

interface Props {
	post: BlogPost;
	toc?: TocItem[];
	noIndex?: boolean;
}

const { post, toc = [], noIndex = false } = Astro.props;
---

<ReadingLayout post={post} toc={toc} noIndex={noIndex}>
	<slot />
</ReadingLayout>
