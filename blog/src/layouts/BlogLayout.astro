---
import '../styles/blog.css';
import BaseLayout from './BaseLayout.astro';

interface Props {
	title: string;
	description: string;
	canonical?: string;
	noIndex?: boolean;
}

const { title, description, canonical, noIndex = false } = Astro.props;
---

<BaseLayout title={title} description={description} canonical={canonical} noIndex={noIndex}>
	<slot />
</BaseLayout>
