---
import type { BlogPost } from '../lib/posts';
import type { TocItem } from '../lib/toc';
import '../styles/reading.css';
import ArticleFooterCTA from '../components/blog/ArticleFooterCTA.astro';
import ArticleHero from '../components/blog/ArticleHero.astro';
import AuthorBox from '../components/blog/AuthorBox.astro';
import Breadcrumbs from '../components/blog/Breadcrumbs.astro';
import ReadingSidebar from '../components/blog/ReadingSidebar.astro';
import RelatedReads from '../components/blog/RelatedReads.astro';
import BaseLayout from './BaseLayout.astro';
import { getAreaEntries } from '../lib/blog-content';
import { buildCanonicalAreaDirectory, getAreaEntryByCategoryCode } from '../lib/canonical-directory';
import { buildBreadcrumbSchema, PUBLISHER_SCHEMA, toAbsoluteUrl } from '../lib/seo';

interface Props {
	post: BlogPost;
	toc: TocItem[];
	related: BlogPost[];
	allPosts?: BlogPost[];
	noIndex?: boolean;
}

const { post, toc, related, allPosts = [], noIndex = false } = Astro.props;
const areaEntries = await getAreaEntries();
const canonicalCategoryCode = post.canonicalCategory ?? post.categoryCode;
const currentArea = getAreaEntryByCategoryCode(areaEntries, canonicalCategoryCode);
const supportPosts = allPosts
	.filter((item) => item.slug !== post.slug)
	.filter((item) => {
		if (!canonicalCategoryCode) return true;
		return item.categoryCode === canonicalCategoryCode || item.canonicalCategory === canonicalCategoryCode;
	})
	.slice(0, 5);
const categoryDirectory = buildCanonicalAreaDirectory(areaEntries, allPosts);
const hasCanonicalTaxonomy =
	post.publicSurfaceStatus === 'allowed' && Boolean(canonicalCategoryCode) && Boolean(post.categoryUrl);
const canonicalUrl = post.canonicalUrl ?? toAbsoluteUrl(post.url);

const breadcrumbs = [
	{ label: 'Início', href: '/' },
	{ label: 'Blog', href: '/blog/' },
	...(hasCanonicalTaxonomy && post.categoryUrl ? [{ label: post.area, href: post.categoryUrl }] : []),
	{ label: post.title },
];

const introText = post.excerpt || post.description;
const introTags = post.temas.slice(0, 3);
const showIntroTags = introTags.length > 0;
const showIntroBlock = Boolean(introText) || showIntroTags;
const hasReadingSidebar = toc.length > 1 || supportPosts.length > 0 || categoryDirectory.length > 0;
const categoryHref = post.categoryUrl ?? '/blog/';
const areaHref = post.areaUrl ?? '/#areas';
const finalCtaCopyByType: Record<string, string> = {
	area:
		'A leitura situa o tema. A página da área mostra como esse recorte se conecta ao atendimento institucional da PAVIE.',
	contact:
		'A área correspondente ajuda a separar informação editorial, limites do texto e caminhos institucionais para o caso concreto.',
	'article-series':
		'Depois da leitura, a área correspondente organiza o lugar deste tema no ecossistema institucional da PAVIE.',
	'document-review':
		'Antes de solicitar qualquer análise, veja como a área correspondente organiza documentos, limites e próximos passos.',
};
const finalCta =
	hasCanonicalTaxonomy && post.areaUrl
		? {
				label: 'Conheça a área correspondente',
				href: areaHref,
				description: finalCtaCopyByType[post.ctaType ?? 'area'] ?? finalCtaCopyByType.area,
			}
		: post.cta;

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: post.title,
	description: post.description,
	url: canonicalUrl,
	image: post.image ? [toAbsoluteUrl(post.image)] : undefined,
	author: {
		'@type': 'Person',
		name: post.authorName,
		url: post.authorUrl ? toAbsoluteUrl(post.authorUrl) : undefined,
	},
	publisher: PUBLISHER_SCHEMA,
	datePublished: post.publishedAt?.toISOString(),
	dateModified: (post.updatedAt ?? post.publishedAt)?.toISOString(),
	mainEntityOfPage: canonicalUrl,
	inLanguage: 'pt-BR',
	articleSection: hasCanonicalTaxonomy ? post.area : undefined,
	about:
		hasCanonicalTaxonomy && currentArea
			? {
					'@type': 'Thing',
					name: currentArea.data.title,
					url: toAbsoluteUrl(areaHref),
				}
			: undefined,
};
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);

const faqSchema =
	post.faqItems.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'FAQPage',
				mainEntity: post.faqItems.map((item) => ({
					'@type': 'Question',
					name: item.question,
					acceptedAnswer: {
						'@type': 'Answer',
						text: item.answer,
					},
				})),
			}
		: undefined;
---

<BaseLayout
	title={`${post.seoTitle ?? post.title} | PAVIE | Advocacia`}
	description={post.description}
	canonical={canonicalUrl}
	image={post.image}
	type="article"
	noIndex={noIndex}
	publishedTime={post.publishedAt}
	modifiedTime={post.updatedAt ?? post.publishedAt}
	author={post.authorName}
>
	<div class="container reading-page">
		<Breadcrumbs items={breadcrumbs} />
		<ArticleHero post={post} />
		<div class="reading-progress" aria-hidden="true"><span data-reading-progress></span></div>

		<div class:list={['reading-shell', { 'reading-shell--single': !hasReadingSidebar }]}>
			<article class="reading-content" aria-labelledby="reading-hero-title">
				{showIntroBlock && (
					<section class="reading-intro" aria-label="Introdução do artigo">
						{introText && <p class="reading-intro__lead">{introText}</p>}
						{showIntroTags && (
							<div class="reading-summary__tags">
								{introTags.map((tema) => (
									<span class="reading-tag">{tema}</span>
								))}
							</div>
						)}
					</section>
				)}

				<div class="article-content">
					<slot />
				</div>

				{post.faqItems.length > 0 && (
					<section class="reading-summary" aria-label="Perguntas frequentes do artigo">
						<h2>Perguntas frequentes</h2>
						<div class="faq-list">
							{post.faqItems.map((item) => (
								<details class="surface-card">
									<summary>{item.question}</summary>
									<p>{item.answer}</p>
								</details>
							))}
						</div>
					</section>
				)}

				<div class="reading-footer">
					<ArticleFooterCTA
						href={finalCta.href}
						label={finalCta.label}
						description={finalCta.description}
						intent={post.ctaType ?? 'area'}
					/>

					<AuthorBox post={post} />

					<RelatedReads
						posts={related}
						title={hasCanonicalTaxonomy ? 'Leituras relacionadas da categoria' : 'Leituras relacionadas'}
						emptyHref={categoryHref}
						emptyLabel="Explorar categoria"
					/>
				</div>
			</article>

			{hasReadingSidebar && (
				<ReadingSidebar
					toc={toc}
					supportPosts={supportPosts}
					categories={categoryDirectory}
					currentCategoryCode={canonicalCategoryCode}
				/>
			)}
		</div>
	</div>

	<script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
	<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	{faqSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
	<script>
		const progress = document.querySelector('[data-reading-progress]');
		if (progress) {
			const update = () => {
				const max = document.documentElement.scrollHeight - window.innerHeight;
				const value = max > 0 ? (window.scrollY / max) * 100 : 0;
				if (progress instanceof HTMLElement) {
					progress.style.width = `${Math.min(100, Math.max(0, value))}%`;
				}
			};
			update();
			window.addEventListener('scroll', update, { passive: true });
		}
	</script>
</BaseLayout>
