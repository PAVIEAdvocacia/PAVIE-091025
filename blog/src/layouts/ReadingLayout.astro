---
import type { BlogPost } from '../lib/posts';
import type { TocItem } from '../lib/toc';
import '../styles/reading.css';
import AudioPlayer from '../components/blog/AudioPlayer.astro';
import AuthorCard from '../components/blog/AuthorCard.astro';
import Breadcrumbs from '../components/blog/Breadcrumbs.astro';
import ReadingHero from '../components/blog/ReadingHero.astro';
import ReadingSidebar from '../components/blog/ReadingSidebar.astro';
import RelatedPosts from '../components/blog/RelatedPosts.astro';
import BaseLayout from './BaseLayout.astro';
import { blogClusterHref, getBlogClusterForPost } from '../lib/blog-clusters';
import { buildBreadcrumbSchema, PUBLISHER_SCHEMA, toAbsoluteUrl } from '../lib/seo';
import { temaHref } from '../lib/taxonomy';

interface Props {
	post: BlogPost;
	toc: TocItem[];
	related: BlogPost[];
	noIndex?: boolean;
}

const { post, toc, related, noIndex = false } = Astro.props;
const cluster = getBlogClusterForPost(post);
const canonicalUrl = post.canonicalUrl ?? toAbsoluteUrl(post.url);

const breadcrumbs = [
	{ label: 'Início', href: '/' },
	{ label: 'Publicações', href: '/blog/' },
	{ label: cluster.title, href: blogClusterHref(cluster.key) },
	{ label: post.title },
];

const appliesTo = [
	'postos em que você precisa entender risco antes de agir',
	'cenários com decisão patrimonial ou familiar relevante',
	'situações em que uma orientação inicial evita retrabalho jurídico',
];

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: post.title,
	description: post.description,
	url: canonicalUrl,
	image: post.image ? [toAbsoluteUrl(post.image)] : undefined,
	author: {
		'@type': 'Person',
		name: post.authorName,
	},
	publisher: PUBLISHER_SCHEMA,
	datePublished: post.publishedAt?.toISOString(),
	dateModified: (post.updatedAt ?? post.publishedAt)?.toISOString(),
	mainEntityOfPage: canonicalUrl,
	inLanguage: 'pt-BR',
};
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);

const faqSchema =
	post.faqItems.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'FAQPage',
				mainEntity: post.faqItems.map((item) => ({
					'@type': 'Question',
					name: item.question,
					acceptedAnswer: {
						'@type': 'Answer',
						text: item.answer,
					},
				})),
			}
		: undefined;
---

<BaseLayout
	title={`${post.seoTitle ?? post.title} | PAVIE`}
	description={post.description}
	canonical={canonicalUrl}
	image={post.image}
	type="article"
	noIndex={noIndex}
	publishedTime={post.publishedAt}
	modifiedTime={post.updatedAt ?? post.publishedAt}
	author={post.authorName}
>
	<div class="container reading-page">
		<Breadcrumbs items={breadcrumbs} />
		<ReadingHero post={post} />
		<div class="reading-progress" aria-hidden="true"><span data-reading-progress></span></div>

		<div class="reading-shell">
			<article class="reading-content" aria-labelledby="reading-hero-title">
				<section class="reading-summary" aria-label="Resumo do artigo">
					<h2>Resumo prático</h2>
					<p>{post.excerpt}</p>
					{post.temas.length > 0 && (
						<div class="reading-summary__tags">
							{post.temas.slice(0, 5).map((tema) => (
								<a class="reading-tag" href={temaHref(tema)}>{tema}</a>
							))}
						</div>
					)}
				</section>

				<section class="reading-summary" aria-label="Quando este conteúdo se aplica">
					<h2>Quando este conteúdo se aplica</h2>
					<ul>
						{appliesTo.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</section>

				<section class="reading-bridge" aria-label="Ponte entre artigo, area e contato">
					<span class="section-kicker">Area correspondente</span>
					<h2>Este conteudo faz parte da trilha {cluster.title}</h2>
					<p>{cluster.description}</p>
					<ul>
						{cluster.typicalSituations.slice(0, 3).map((item) => (
							<li>{item}</li>
						))}
					</ul>
					<div class="reading-bridge__actions">
						<a class="btn btn-secondary" href={blogClusterHref(cluster.key)}>Explorar temas</a>
						<a class="btn btn-ghost" href={cluster.institutionalHref}>Conheça os Serviços</a>
						<a class="btn btn-primary" href={cluster.contactHref}>Solicitar orientação inicial</a>
					</div>
				</section>

				<AudioPlayer
					audioStatus={post.audioStatus}
					audioUrl={post.audioUrl}
					transcriptUrl={post.transcriptUrl}
				/>
				<div class="article-content">
					<slot />
				</div>
				{post.faqItems.length > 0 && (
					<section class="reading-summary" aria-label="Perguntas frequentes do artigo">
						<h2>Perguntas frequentes</h2>
						<div class="faq-list">
							{post.faqItems.map((item) => (
								<details class="surface-card">
									<summary>{item.question}</summary>
									<p>{item.answer}</p>
								</details>
							))}
						</div>
					</section>
				)}
				<div class="reading-footer">
					<AuthorCard post={post} />
					<section class="reading-panel" aria-label="Chamada final">
						<h3>Precisa de orientação aplicada ao seu caso?</h3>
						<p class="text-muted">{post.cta.description}</p>
						<a class="btn btn-primary" href={post.cta.href}>
							{post.cta.label}
						</a>
						<p class="reading-ethics-note">Conteúdo informativo. Cada caso exige análise técnica individual.</p>
					</section>
					<RelatedPosts
						posts={related}
						title="Continue nesta trilha editorial"
						emptyHref={blogClusterHref(cluster.key)}
						emptyLabel="Explorar temas"
					/>
				</div>
			</article>

			<ReadingSidebar post={post} toc={toc} related={related} />
		</div>

		<div class="mobile-reading-cta" aria-label="Acao rapida no mobile">
			<a class="btn btn-primary" href={post.cta.href}>{post.cta.label}</a>
		</div>
	</div>

	<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
	<script>
		const progress = document.querySelector('[data-reading-progress]');
		if (progress) {
			const update = () => {
				const max = document.documentElement.scrollHeight - window.innerHeight;
				const value = max > 0 ? (window.scrollY / max) * 100 : 0;
				progress.style.width = `${Math.min(100, Math.max(0, value))}%`;
			};
			update();
			window.addEventListener('scroll', update, { passive: true });
		}
	</script>
</BaseLayout>
