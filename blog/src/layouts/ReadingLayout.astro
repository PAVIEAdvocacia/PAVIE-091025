---
import type { BlogPost } from '../lib/posts';
import type { TocItem } from '../lib/toc';
import '../styles/reading.css';
import AuthorCard from '../components/blog/AuthorCard.astro';
import Breadcrumbs from '../components/blog/Breadcrumbs.astro';
import ReadingHero from '../components/blog/ReadingHero.astro';
import ReadingSidebar from '../components/blog/ReadingSidebar.astro';
import RelatedPosts from '../components/blog/RelatedPosts.astro';
import BaseLayout from './BaseLayout.astro';
import { getAreaEntries } from '../lib/blog-content';
import { getAreaEntryByCategoryCode } from '../lib/canonical-directory';
import { buildBreadcrumbSchema, PUBLISHER_SCHEMA, toAbsoluteUrl } from '../lib/seo';

interface Props {
	post: BlogPost;
	toc: TocItem[];
	related: BlogPost[];
	noIndex?: boolean;
}

const { post, toc, related, noIndex = false } = Astro.props;
const areaEntries = await getAreaEntries();
const currentArea = getAreaEntryByCategoryCode(areaEntries, post.categoryCode);
const hasCanonicalTaxonomy =
	post.publicSurfaceStatus === 'allowed' && Boolean(post.categoryCode) && Boolean(post.categoryUrl);
const canonicalUrl = post.canonicalUrl ?? toAbsoluteUrl(post.url);

const breadcrumbs = [
	{ label: 'Inicio', href: '/' },
	{ label: 'Publicacoes', href: '/blog/' },
	...(hasCanonicalTaxonomy && post.categoryUrl ? [{ label: post.area, href: post.categoryUrl }] : []),
	{ label: post.title },
];

const articleFocusPoints = [
	'Quando a decisao ja envolve documento, contrato, patrimonio ou registro relevante.',
	'Quando existe prazo, audiencia, urgencia pratica ou risco que nao convem tratar no improviso.',
	'Quando a leitura informa bem o tema, mas a estrategia ainda depende das particularidades do caso.',
];
const introText = post.excerpt && post.excerpt !== post.description ? post.excerpt : '';
const showIntroTags = post.temas.length > 0;
const showIntroBlock = Boolean(introText) || showIntroTags;
const categoryHref = post.categoryUrl ?? '/blog/categoria/';
const areaHref = post.areaUrl ?? '/#areas';
const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: post.title,
	description: post.description,
	url: canonicalUrl,
	image: post.image ? [toAbsoluteUrl(post.image)] : undefined,
	author: {
		'@type': 'Person',
		name: post.authorName,
		url: post.authorUrl ? toAbsoluteUrl(post.authorUrl) : undefined,
	},
	publisher: PUBLISHER_SCHEMA,
	datePublished: post.publishedAt?.toISOString(),
	dateModified: (post.updatedAt ?? post.publishedAt)?.toISOString(),
	mainEntityOfPage: canonicalUrl,
	inLanguage: 'pt-BR',
	articleSection: hasCanonicalTaxonomy ? post.area : undefined,
	about:
		hasCanonicalTaxonomy && currentArea
			? {
					'@type': 'Thing',
					name: currentArea.data.title,
					url: toAbsoluteUrl(areaHref),
				}
			: undefined,
};
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);

const faqSchema =
	post.faqItems.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'FAQPage',
				mainEntity: post.faqItems.map((item) => ({
					'@type': 'Question',
					name: item.question,
					acceptedAnswer: {
						'@type': 'Answer',
						text: item.answer,
					},
				})),
			}
		: undefined;
---

<BaseLayout
	title={`${post.seoTitle ?? post.title} | PAVIE | Advocacia`}
	description={post.description}
	canonical={canonicalUrl}
	image={post.image}
	type="article"
	noIndex={noIndex}
	publishedTime={post.publishedAt}
	modifiedTime={post.updatedAt ?? post.publishedAt}
	author={post.authorName}
>
	<div class="container reading-page">
		<Breadcrumbs items={breadcrumbs} />
		<ReadingHero post={post} />
		<div class="reading-progress" aria-hidden="true"><span data-reading-progress></span></div>

		<div class="reading-shell">
			<article class="reading-content" aria-labelledby="reading-hero-title">
				{showIntroBlock && (
					<section class="reading-intro" aria-label="Introducao do artigo">
						{introText && <p class="reading-intro__lead">{introText}</p>}
						{showIntroTags && (
							<div class="reading-summary__tags">
								{post.temas.slice(0, 5).map((tema) => (
									<span class="reading-tag">{tema}</span>
								))}
							</div>
						)}
					</section>
				)}

				<div class="article-content">
					<slot />
				</div>
				<section class="reading-context" aria-label="Quando este tema costuma exigir analise do caso concreto">
					<span class="section-kicker">Quando a leitura pede um proximo passo</span>
					<h2>Este tema costuma exigir analise individual quando a decisao ja envolve documento, prazo, risco ou impacto relevante.</h2>
					<ul>
						{articleFocusPoints.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</section>

				{post.faqItems.length > 0 && (
					<section class="reading-summary" aria-label="Perguntas frequentes do artigo">
						<h2>Perguntas frequentes</h2>
						<div class="faq-list">
							{post.faqItems.map((item) => (
								<details class="surface-card">
									<summary>{item.question}</summary>
									<p>{item.answer}</p>
								</details>
							))}
						</div>
					</section>
				)}
				<div class="reading-footer">
					<RelatedPosts
						posts={related}
						title={hasCanonicalTaxonomy ? 'Continue por leituras desta categoria' : 'Continue a leitura'}
						emptyHref={categoryHref}
						emptyLabel="Explorar categorias"
					/>
					<AuthorCard post={post} />
					<section class="reading-next-step surface-card" aria-label="Proximo passo apos a leitura">
						<div>
							<span class="section-kicker">Proximo passo possivel</span>
							<h2>Se a leitura nao basta sozinha, o primeiro passo e descrever a situacao concreta com clareza.</h2>
							<p>{post.cta.description}</p>
						</div>
						<div class="reading-bridge__actions">
							<a
								class="btn btn-primary"
								href={post.cta.href}
								data-contact-origin="article-final"
								data-contact-intent="orientacao-inicial"
							>
								{post.cta.label}
							</a>
						</div>
						<p class="reading-ethics-note">Conteudo informativo. Cada caso exige analise tecnica individual.</p>
					</section>
				</div>
			</article>

			<ReadingSidebar toc={toc} related={related} />
		</div>
	</div>

	<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
	<script>
		const progress = document.querySelector('[data-reading-progress]');
		if (progress) {
			const update = () => {
				const max = document.documentElement.scrollHeight - window.innerHeight;
				const value = max > 0 ? (window.scrollY / max) * 100 : 0;
				if (progress instanceof HTMLElement) {
					progress.style.width = `${Math.min(100, Math.max(0, value))}%`;
				}
			};
			update();
			window.addEventListener('scroll', update, { passive: true });
		}
	</script>
</BaseLayout>
