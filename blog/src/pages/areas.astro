---
import { getCollection } from 'astro:content';
import { MAIN_SITE_URL } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildHubDirectory } from '../lib/service-hubs';
import { isPublicPost, normalizePost, sortPostsByDate } from '../lib/posts';
import '../styles/institutional-pages.css';

const title = 'Áreas de Atuação | PAVIE Advocacia';
const description =
	'Mapa institucional de serviços jurídicos da PAVIE, organizado por hubs de atuação, temas e trilhas editoriais.';

const entries = await getCollection('blog');
const posts = sortPostsByDate(entries.map((entry) => normalizePost(entry))).filter(isPublicPost);
const hubDirectory = buildHubDirectory(posts);
---

<BaseLayout title={title} description={description} canonical={`${MAIN_SITE_URL}/areas/`}>
	<div class="container-md institutional-page">
		<span class="badge">Áreas de atuação</span>
		<h1>Serviços jurídicos organizados por hubs, com trilhas de conteúdo por área e tema.</h1>
		<p class="institutional-page__lead">
			Esta estrutura mantém coerência entre atendimento, páginas institucionais e publicação editorial.
			Cada hub abaixo conecta escopo jurídico, situações comuns e conteúdo de apoio no blog.
		</p>

		<div class="hub-grid">
			{hubDirectory.map((hub) => (
				<article class="surface-card hub-card">
					<h2>{hub.title}</h2>
					<p>{hub.summary}</p>
					<ul class="institutional-list">
						{hub.situations.map((situation) => (
							<li>{situation}</li>
						))}
					</ul>
					<div class="hub-tag-list">
						{hub.themes.map((theme) => (
							<a class:list={['hub-tag', { 'is-muted': !theme.available }]} href={theme.href}>
								{theme.label}
							</a>
						))}
					</div>
					<div class="hub-card__meta">
						<span>{hub.postCount} conteúdos publicados</span>
						<a href={hub.areaUrl}>Abrir trilha da área</a>
					</div>
					<div class="institutional-actions">
						<a class="btn btn-primary" href="/contato/">Solicitar orientação</a>
						<a class="btn btn-ghost" href="/blog/temas/">Explorar temas</a>
					</div>
				</article>
			))}
		</div>
	</div>
</BaseLayout>
