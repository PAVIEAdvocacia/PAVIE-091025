---
import { MAIN_SITE_URL } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAreaEntries, getBlogEntries } from '../lib/blog-content';
import { buildCanonicalAreaDirectory } from '../lib/canonical-directory';
import { isPublicPost, normalizePost, sortPostsByDate } from '../lib/posts';
import '../styles/institutional-pages.css';

const title = 'Areas de Atuacao | PAVIE | Advocacia';
const description =
	'Camada canonica de areas da PAVIE, organizada pelos 7 rotulos aprovados e conectada ao acervo editorial homologado.';

const [areaEntries, blogEntries] = await Promise.all([getAreaEntries(), getBlogEntries()]);
const posts = sortPostsByDate(blogEntries.map((entry) => normalizePost(entry))).filter(isPublicPost);
const areaDirectory = buildCanonicalAreaDirectory(areaEntries, posts);
---

<BaseLayout title={title} description={description} canonical={`${MAIN_SITE_URL}/areas/`}>
	<div class="container-md institutional-page">
		<span class="badge">Areas canonicas</span>
		<h1>As areas de atuacao da PAVIE seguem apenas os 7 rotulos canonicos aprovados.</h1>
		<p class="institutional-page__lead">
			Esta camada organiza a navegacao institucional por area, conecta cada pagina ao acervo editorial compativel
			e evita reaproveitamento da taxonomia legada como estrutura publica.
		</p>

		<div class="meta-list" aria-label="Panorama das areas canonicas">
			<span><span class="meta-dot" aria-hidden="true"></span>{areaDirectory.length} areas ativas</span>
			<span><span class="meta-dot" aria-hidden="true"></span>{posts.length} publicacoes homologadas no acervo atual</span>
			<span><span class="meta-dot" aria-hidden="true"></span>Navegacao institucional e editorial alinhadas</span>
		</div>

		<div class="hub-grid">
			{areaDirectory.map((area) => (
				<article class="surface-card hub-card institutional-card">
					<span class="section-kicker">Area canonica</span>
					<h2>{area.title}</h2>
					<p>{area.shortDescription}</p>
					<ul class="institutional-list">
						<li>{area.headline}</li>
						<li>
							{area.postCount > 0
								? `${area.postCount} publicacao${area.postCount > 1 ? 'oes' : ''} homologada${area.postCount > 1 ? 's' : ''} nesta area.`
								: 'O acervo editorial desta area segue ciclo proprio de homologacao.'}
						</li>
						<li>A pagina de area e a categoria do blog apontam para o mesmo eixo canonico.</li>
					</ul>
					{area.latestPosts.length > 0 && (
						<div class="cluster-directory-posts">
							<p class="cluster-directory-meta">Leituras relacionadas</p>
							<ul>
								{area.latestPosts.map((post) => (
									<li><a href={post.url}>{post.title}</a></li>
								))}
							</ul>
						</div>
					)}
					<div class="institutional-actions">
						<a class="btn btn-primary" href={area.href}>Conheca esta area</a>
						<a class="btn btn-ghost" href={area.categoryHref}>Explorar categoria no blog</a>
					</div>
				</article>
			))}
		</div>
	</div>
</BaseLayout>
