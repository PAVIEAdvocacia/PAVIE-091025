---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/institutional-pages.css';

const title = 'Áreas de Atuação | PAVIE Advocacia';
const description =
	'Campos de atuação da PAVIE organizados por situações reais, com foco em clareza, prevenção de risco e condução jurídica responsável.';

const areas = [
	{
		title: 'Família e Sucessões',
		text: 'Divórcio, guarda, alimentos, inventário, partilha e planejamento sucessório com foco em proteção patrimonial e segurança documental.',
		blog: '/blog/areas/familia/',
	},
	{
		title: 'Patrimônio e Imóveis',
		text: 'Regularização, análise de risco em compra e venda, contratos imobiliários e organização jurídica de ativos.',
		blog: '/blog/temas/partilha/',
	},
	{
		title: 'Contratos e Negócios',
		text: 'Estruturação de cláusulas, prevenção de conflito, negociação e suporte em obrigações civis e empresariais.',
		blog: '/blog/',
	},
	{
		title: 'Responsabilidade Civil e Consumidor',
		text: 'Condução de demandas com análise de prova, risco financeiro e estratégia processual proporcional ao caso.',
		blog: '/blog/',
	},
];
---

<BaseLayout title={title} description={description} canonical="https://blog.pavieadvocacia.com.br/areas/">
	<div class="container-md institutional-page">
		<span class="badge">Áreas de atuação</span>
		<h1>
			Atuação jurídica organizada por cenário real, não por generalismo.
		</h1>
		<p class="institutional-page__lead">
			Cada área abaixo foi estruturada para facilitar entendimento de escopo, reduzir ansiedade de quem procura ajuda
			e orientar o próximo passo com clareza.
		</p>

		<div class="institutional-grid">
			{areas.map((area) => (
				<article class="surface-card institutional-card">
					<h2>{area.title}</h2>
					<p>{area.text}</p>
					<div class="institutional-actions">
						<a class="btn btn-primary" href="/contato/">Solicitar orientação</a>
						<a class="btn btn-ghost" href={area.blog}>Ver conteúdos no blog</a>
					</div>
				</article>
			))}
		</div>
	</div>
</BaseLayout>
