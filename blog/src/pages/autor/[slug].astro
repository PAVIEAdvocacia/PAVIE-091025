---
import Breadcrumbs from '../../components/blog/Breadcrumbs.astro';
import BlogGrid from '../../components/blog/BlogGrid.astro';
import { MAIN_SITE_URL } from '../../consts';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAuthorEntries, getBlogEntries } from '../../lib/blog-content';
import { getAuthorEntryBySlug } from '../../lib/canonical-directory';
import { normalizeCmsImagePath } from '../../lib/content-media';
import { isPublicPost, normalizePosts, sortPostsByDate } from '../../lib/posts';
import { buildBreadcrumbSchema, toAbsoluteUrl } from '../../lib/seo';
import '../../styles/blog.css';
import '../../styles/institutional-pages.css';

export async function getStaticPaths() {
	const authorEntries = await getAuthorEntries();
	return authorEntries.map((entry) => ({ params: { slug: entry.data.slug } }));
}

const [authorEntries, blogEntries] = await Promise.all([getAuthorEntries(), getBlogEntries()]);
const currentAuthor = getAuthorEntryBySlug(authorEntries, Astro.params.slug ?? '');

if (!currentAuthor) {
	throw new Error(`Autor canonico nao encontrado: ${Astro.params.slug}`);
}

const authorImage = normalizeCmsImagePath(currentAuthor.data.image) ?? currentAuthor.data.image;
const posts = sortPostsByDate(normalizePosts(blogEntries, authorEntries))
	.filter(isPublicPost)
	.filter((post) => post.authorSlug === currentAuthor.data.slug);
const canonicalUrl = `${MAIN_SITE_URL}/autor/${currentAuthor.data.slug}/`;
const breadcrumbs = [
	{ label: 'Inicio', href: '/' },
	{ label: 'Autor' },
	{ label: currentAuthor.data.name },
];
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);
const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: currentAuthor.data.name,
	url: canonicalUrl,
	image: toAbsoluteUrl(authorImage),
	description: currentAuthor.data.shortBio,
	jobTitle: 'Advogado',
};
---

<BaseLayout
	title={`${currentAuthor.data.name} | Autor | PAVIE | Advocacia`}
	description={currentAuthor.data.shortBio}
	canonical={canonicalUrl}
	image={authorImage}
>
	<div class="container institutional-page">
		<Breadcrumbs items={breadcrumbs} />
		<section class="surface-card institutional-profile" aria-labelledby="author-title">
			<img src={authorImage} alt={currentAuthor.data.imageAlt} loading="eager" />
			<div>
				<span class="badge">Autor</span>
				<h1 id="author-title">{currentAuthor.data.name}</h1>
				<p>{currentAuthor.data.oab}</p>
				<p>{currentAuthor.data.shortBio}</p>
				<p>{currentAuthor.data.extendedBio}</p>
				<div class="institutional-actions">
					<a class="btn btn-primary" href="/areas/">Conheca as areas</a>
					<a class="btn btn-ghost" href="/blog/categoria/">Explorar categorias do blog</a>
				</div>
			</div>
		</section>

		<section class="institutional-grid" aria-label="Estrutura de autoria">
			<article class="surface-card institutional-card">
				<span class="section-kicker">Producao publica</span>
				<h2>Escrita concentrada no foco atual do escritorio</h2>
				<p>
					Os textos assinados por Fabio Pavie acompanham o eixo institucional da PAVIE e priorizam
					questoes em que patrimonio, familia, sucessao, imoveis, documentos e definicao da via adequada
					tem relevancia pratica.
				</p>
			</article>
			<article class="surface-card institutional-card">
				<span class="section-kicker">Como navegar</span>
				<h2>Conteudos reunidos em uma pagina unica de autoria</h2>
				<p>
					Esta pagina concentra os artigos publicados desta assinatura e evita dispersao entre perfis,
					bios ou referencias publicas concorrentes.
				</p>
			</article>
		</section>

		<BlogGrid
			title="Publicacoes do autor"
			kicker="Autoria"
			posts={posts}
			emptyTitle="Acervo em atualizacao"
			emptyText="A pagina de autor ja esta disponivel. Novos artigos serao reunidos aqui conforme entrarem no acervo publico."
			emptyHref="/blog/categoria/"
			emptyLabel="Explorar categorias"
		/>
	</div>

	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
</BaseLayout>
