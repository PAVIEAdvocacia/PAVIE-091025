---
import BrandLogo from '../components/brand/BrandLogo.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildFaqSchema, LEGAL_SERVICE_BASE_SCHEMA, toAbsoluteUrl } from '../lib/seo';
import { MAIN_SITE_URL } from '../consts';
import { getAreaEntries, getAuthorEntries, getBlogEntries } from '../lib/blog-content';
import { buildCanonicalAreaDirectory } from '../lib/canonical-directory';
import { CANONICAL_CATEGORY_DEFINITIONS } from '../lib/canonical-content';
import { isPublicPost, normalizePosts, sortPostsByDate } from '../lib/posts';
import '../styles/site-home.css';

const title = 'PAVIE | Advocacia | Clareza, técnica e respeito';
const description =
	'Advocacia estratégica e acolhedora para questões de patrimônio, família, curatelas, sucessões, imóveis, contratos, créditos e direitos do consumidor.';

const processSteps = [
	{
		title: 'Análise inicial',
		text: 'Ouvimos você para entender a situação real. Avaliamos a viabilidade com franqueza antes de prometer qualquer resultado.',
	},
	{
		title: 'Leitura documental',
		text: 'Analisamos cuidadosamente os seus documentos, certidões e histórico para garantir que não haja surpresas no caminho.',
	},
	{
		title: 'Estratégia e opções',
		text: 'Apresentamos as rotas disponíveis, os riscos envolvidos e os custos de forma totalmente clara e sem jargões desnecessários.',
	},
	{
		title: 'Execução segura',
		text: 'Atuamos na defesa dos seus direitos, mantendo você atualizado e seguro sobre cada avanço do seu caso.',
	},
];

const faq = [
	{
		q: 'O primeiro contato já significa contratação?',
		a: 'Não. O contato inicial serve para triagem, compreensão do contexto e verificação de aderência. A contratação depende de escopo definido, proposta formal e aceite expresso.',
	},
	{
		q: 'Quais documentos devo separar antes de enviar a situação?',
		a: 'Comece pelos documentos pessoais, contratos, certidões, mensagens, notificações, registros, prazos e qualquer prova que ajude a reconstruir a cronologia do caso.',
	},
	{
		q: 'O atendimento pode ocorrer fora do Rio de Janeiro?',
		a: 'Sim. A análise inicial pode ocorrer online, com avaliação do que pode ser conduzido a distância e do que depende de providência local ou complementar.',
	},
	{
		q: 'Como os honorários são definidos?',
		a: 'Os honorários dependem do tipo de demanda, complexidade, urgência, documentos disponíveis e extensão do acompanhamento. Quando houver aderência, a proposta é apresentada de forma formal e clara.',
	},
];

type HomeAreaCard = {
	code: string;
	title: string;
	description: string;
	href: string;
};

const [areaEntries, authorEntries, blogEntries] = await Promise.all([
	getAreaEntries(),
	getAuthorEntries(),
	getBlogEntries(),
]);
const posts = sortPostsByDate(normalizePosts(blogEntries, authorEntries)).filter(isPublicPost);
const areaDirectory = buildCanonicalAreaDirectory(areaEntries, posts);
const areaByCode = new Map(areaDirectory.map((area) => [area.code, area]));
const areaCards = [...CANONICAL_CATEGORY_DEFINITIONS]
	.sort((a, b) => a.homeOrder - b.homeOrder)
	.map((definition): HomeAreaCard | undefined => {
		const area = areaByCode.get(definition.code);
		if (!area) return undefined;

		return {
			code: definition.code,
			title: definition.homeTitle,
			description: definition.homeDescription,
			href: area.href,
		};
	})
	.filter((card): card is HomeAreaCard => Boolean(card));

const faqSchema = buildFaqSchema(
	faq.map((item) => ({
		question: item.q,
		answer: item.a,
	})),
);

const localBusinessSchema = {
	...LEGAL_SERVICE_BASE_SCHEMA,
	description,
	image: toAbsoluteUrl('/brand/pavie-logo-horizontal.png'),
};
---

<BaseLayout title={title} description={description} canonical={`${MAIN_SITE_URL}/`}>
	<div class="site-home">
		<section class="site-hero" aria-labelledby="hero-title">
			<div class="container site-hero__inner">
				<span class="site-eyebrow">Advocacia estratégica e acolhedora</span>
				<h1 id="hero-title">Clareza, técnica e respeito na condução dos seus direitos.</h1>
				<p class="site-hero__lead">
					Uma advocacia focada na sua segurança. Atuamos desde o planejamento e organização do seu
					patrimônio até questões sensíveis de família, curatelas e recuperação de créditos.
				</p>
				<div class="site-hero__actions">
					<a class="btn btn-primary" href="#contato">Solicitar análise do caso</a>
					<a class="btn btn-secondary" href="/#areas">Ver áreas de atuação</a>
				</div>
				<p class="site-hero__location">Sede no Rio de Janeiro <span aria-hidden="true">•</span> Atendimento em todo o Brasil</p>
			</div>
		</section>

		<section id="advogado" class="site-section professional-section container" aria-labelledby="advogado-title">
			<div class="professional-media">
				<img
					src="/uploads/fabio-pavie-profile.png"
					alt="Foto profissional do advogado Fabio Mathias Pavie"
					loading="lazy"
				/>
				<span>Advogado titular</span>
			</div>

			<div class="professional-copy">
				<span class="site-eyebrow">Condução técnica e humana</span>
				<h2 id="advogado-title">Fabio Mathias Pavie</h2>
				<blockquote>
					“Acredito que a segurança jurídica se constrói com técnica, franqueza e profundo respeito à
					história de cada cliente. O nosso compromisso é organizar os detalhes do seu caso para que
					você possa tomar decisões claras e proteger o que construiu.”
				</blockquote>
				<p>
					Inscrito na OAB/RJ 134.947, dedica-se a soluções jurídicas que envolvem estruturação
					patrimonial, direito de família, curatelas e recuperação de crédito. Prioriza uma advocacia
					próxima, transparente e de alta qualidade técnica.
				</p>
				<a class="text-link" href="/sobre/">Conhecer a trajetória do advogado</a>
			</div>
		</section>

		<section id="metodo" class="site-section site-method" aria-labelledby="metodo-title">
			<div class="container section-title section-title--center">
				<span class="site-eyebrow">Método</span>
				<h2 id="metodo-title">Como conduzimos o seu caso</h2>
				<p>
					A tranquilidade das suas decisões depende de método e clareza. Conduzimos o seu processo com
					total transparência e rigor técnico, oferecendo a previsibilidade necessária desde o primeiro contato.
				</p>
			</div>

			<ol class="container process-list">
				{processSteps.map((step, index) => (
					<li class="process-step">
						<span class="process-step__icon" aria-hidden="true"></span>
						<h3>{index + 1}. {step.title}</h3>
						<p>{step.text}</p>
					</li>
				))}
			</ol>
		</section>

		<section id="areas" class="site-section site-areas" aria-labelledby="areas-title">
			<div class="container section-title section-title--areas">
				<div>
					<h2 id="areas-title">Áreas de Atuação</h2>
					<p>
						A complexidade exige foco. A nossa atuação concentra-se em frentes que demandam
						organização prévia, proteção de ativos, cuidado familiar e reparação técnica de direitos.
					</p>
				</div>
				<span>Escopo institucional PAVIE</span>
			</div>

			<div class="container area-grid">
				{areaCards.map((area) => (
					<article class="area-card">
						<span class="area-card__icon" aria-hidden="true"></span>
						<h3>{area.title}</h3>
						<p>{area.description}</p>
						<a href={area.href}>Conhecer área <span aria-hidden="true">→</span></a>
					</article>
				))}
			</div>
		</section>

		<section id="conteudos" class="editorial-bridge" aria-labelledby="conteudos-title">
			<div class="container editorial-bridge__inner">
				<span class="site-eyebrow">Conteúdo educativo</span>
				<h2 id="conteudos-title">Aprofunde a sua compreensão antes de tomar uma decisão.</h2>
				<p>
					Se o seu momento ainda é de busca por informações, visite os nossos artigos e guias técnicos.
					Eles foram elaborados para traçar um caminho claro e seguro sobre os seus direitos, preparando
					o terreno de forma informativa para quando decidir falar com o advogado.
				</p>
				<a class="btn btn-secondary" href="/blog/">Acessar artigos e guias</a>
			</div>
		</section>

		<section id="faq" class="site-section faq-section container" aria-labelledby="faq-title">
			<div class="section-title section-title--center">
				<span class="site-eyebrow">Primeiro contato</span>
				<h2 id="faq-title">Respostas iniciais para o primeiro contato</h2>
			</div>

			<div class="faq-list">
				{faq.map((item) => (
					<details class="faq-item">
						<summary>{item.q}</summary>
						<p>{item.a}</p>
					</details>
				))}
			</div>
		</section>

		<section id="contato" class="site-contact" aria-labelledby="contato-title">
			<div class="container site-contact__grid">
				<div class="site-contact__copy">
					<BrandLogo variant="horizontal" theme="dark" width={300} />
					<p>
						Segurança jurídica, direção técnica apurada pelo respeito, colaboração e excelência na
						defesa dos seus direitos.
					</p>

					<article class="site-contact__honorarios">
						<h3>Transparência em honorários</h3>
						<p>
							Adotamos critérios coerentes com clareza, previsibilidade e sigilo profissional.
							Os honorários são apresentados antes do início de qualquer atuação, sem promessas ou
							atalhos incompatíveis com a ética jurídica.
						</p>
					</article>

					<ul class="site-contact__links" aria-label="Canais de contato">
						<li><a href="mailto:contato@pavieadvocacia.com.br">contato@pavieadvocacia.com.br</a></li>
						<li><a href="tel:+5521964382263">(21) 96438-2263</a></li>
					</ul>
				</div>

				<form
					id="siteContactForm"
					class="site-contact__form"
					action="/api/contato"
					method="post"
					aria-describedby="site-contact-note"
				>
					<h2 id="contato-title">Solicitar Análise do Caso</h2>
					<p>
						Compartilhe o contexto do seu problema para darmos o primeiro passo. A PAVIE fará
						uma leitura inicial da sua situação, oferecendo um retorno cuidadoso e objetivo sobre a
						viabilidade técnica, sempre sob rigoroso sigilo profissional.
					</p>

					<input id="turnstileToken" name="turnstileToken" type="hidden" />

					<label>
						<span>Nome completo</span>
						<input id="nome" name="nome" autocomplete="name" required type="text" />
					</label>

					<label>
						<span>Telefone, WhatsApp ou E-mail</span>
						<input id="contato_preferencial" name="contato_preferencial" autocomplete="email" required type="text" />
					</label>

					<label>
						<span>Resumo da situação</span>
						<textarea id="mensagem" name="mensagem" required rows="5"></textarea>
					</label>

					<label class="site-contact__consent">
						<input name="consent" required type="checkbox" />
						<span>Autorizo o uso dos dados enviados apenas para retorno do contato, sob sigilo profissional.</span>
					</label>

					<div
						class="cf-turnstile"
						data-sitekey="0x4AAAAAAB6FBS0cTG_7KOYv"
						data-callback="onTsDone"
						data-expired-callback="onTsExpired"
						data-error-callback="onTsError"
					>
					</div>

					<p id="site-contact-status" class="site-contact__status" role="status" aria-live="polite"></p>

					<button class="btn btn-primary" type="submit">Enviar para o Advogado</button>
					<p id="site-contact-note" class="site-contact__note">
						Contato inicial não é contratação automática. A orientação jurídica depende da análise da situação individual.
					</p>
				</form>
			</div>
		</section>
	</div>

	<script is:inline>
		(function () {
			var tokenField = document.getElementById('turnstileToken');
			var form = document.getElementById('siteContactForm');
			var status = document.getElementById('site-contact-status');

			window.onTsDone = function (token) {
				if (tokenField) tokenField.value = token || '';
				if (status) status.textContent = 'Validação de segurança concluída.';
			};
			window.onTsExpired = function () {
				if (tokenField) tokenField.value = '';
				if (status) status.textContent = 'Validação expirada. Aguarde recarregar e tente novamente.';
			};
			window.onTsError = function () {
				if (tokenField) tokenField.value = '';
				if (status) status.textContent = 'Não foi possível carregar a validação de segurança.';
			};

			if (!form || !status) return;

			form.addEventListener('submit', async function (event) {
				event.preventDefault();
				var button = form.querySelector('button[type="submit"]');
				var originalText = button ? button.textContent : '';

				if (tokenField && !tokenField.value) {
					status.textContent = 'Aguarde a validação de segurança antes de enviar.';
					return;
				}

				if (button) {
					button.disabled = true;
					button.textContent = 'Enviando...';
				}
				status.textContent = 'Enviando informações iniciais...';

				try {
					var response = await fetch(form.action, {
						method: 'POST',
						body: new FormData(form),
						headers: { Accept: 'application/json' },
					});
					var data = await response.json().catch(function () { return {}; });
					if (!response.ok || data.ok === false) {
						throw new Error(data.error || 'Falha no envio.');
					}
					status.textContent = 'Solicitação enviada. A PAVIE fará a triagem inicial do contato.';
					form.reset();
					if (tokenField) tokenField.value = '';
					if (window.turnstile && typeof window.turnstile.reset === 'function') {
						window.turnstile.reset();
					}
				} catch (error) {
					status.textContent = error && error.message
						? 'Não foi possível enviar: ' + error.message
						: 'Não foi possível enviar a solicitação.';
				} finally {
					if (button) {
						button.disabled = false;
						button.textContent = originalText;
					}
				}
			});
		})();
	</script>
	<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
	<script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	<script is:inline type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
</BaseLayout>
