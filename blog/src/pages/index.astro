---
import BrandLogo from '../components/brand/BrandLogo.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildFaqSchema, LEGAL_SERVICE_BASE_SCHEMA, toAbsoluteUrl } from '../lib/seo';
import { MAIN_SITE_URL } from '../consts';
import { getAreaEntries, getAuthorEntries, getBlogEntries } from '../lib/blog-content';
import { buildCanonicalAreaDirectory } from '../lib/canonical-directory';
import { isPublicPost, normalizePosts, sortPostsByDate } from '../lib/posts';
import '../styles/site-home.css';

const title = 'PAVIE | Advocacia | Clareza, metodo e responsabilidade';
const description =
	'A PAVIE | Advocacia atua em situacoes que impactam patrimonio, familia, sucessao, imoveis, documentos relevantes e relacoes contratuais seletivas, com analise tecnica, linguagem clara e direcao juridica responsavel.';

const proofItems = [
	{
		title: 'OAB/RJ 134.947',
		text: 'Atuacao identificavel, contratacao formal e responsabilidade tecnica em cada etapa do atendimento.',
	},
	{
		title: 'Atendimento online e presencial',
		text: 'O primeiro formato de contato se ajusta ao contexto do caso e a necessidade pratica da situacao.',
	},
	{
		title: 'Contratacao formal',
		text: 'Escopo, etapas, honorarios e forma de acompanhamento sao apresentados com clareza quando houver aderencia.',
	},
	{
		title: 'Conteudo informativo',
		text: 'A leitura ajuda a organizar o problema, mas a orientacao depende sempre da situacao individual.',
	},
];

const processSteps = [
	{
		title: 'Analise inicial',
		text: 'O primeiro contato organiza a situacao, a urgencia pratica e o objetivo que precisa ser compreendido.',
	},
	{
		title: 'Leitura documental',
		text: 'Documentos, prazos, vinculos e registros relevantes sao identificados antes de qualquer passo mais profundo.',
	},
	{
		title: 'Estrategia e opcoes',
		text: 'Caminhos possiveis, limites, riscos e custos sao apresentados de forma clara e proporcional ao caso.',
	},
	{
		title: 'Execucao segura',
		text: 'Com escopo definido, a conducao segue com registro, comunicacao objetiva e responsabilidade tecnica.',
	},
];

const faq = [
	{
		q: 'O primeiro contato ja significa contratacao?',
		a: 'Nao. O contato inicial serve para triagem, compreensao do contexto e verificacao de aderencia. A contratacao depende de escopo definido, proposta formal e aceite expresso.',
	},
	{
		q: 'Quais documentos devo separar antes de enviar a situacao?',
		a: 'Comece pelos documentos pessoais, contratos, certidoes, mensagens, notificacoes, registros, prazos e qualquer prova que ajude a reconstruir a cronologia do caso.',
	},
	{
		q: 'O atendimento pode ocorrer fora do Rio de Janeiro?',
		a: 'Sim. A analise inicial pode ocorrer online, com avaliacao do que pode ser conduzido a distancia e do que depende de providencia local ou complementar.',
	},
	{
		q: 'Como os honorarios sao definidos?',
		a: 'Os honorarios dependem do tipo de demanda, complexidade, urgencia, documentos disponiveis e extensao do acompanhamento. Quando houver aderencia, a proposta e apresentada de forma formal e clara.',
	},
];

const [areaEntries, authorEntries, blogEntries] = await Promise.all([
	getAreaEntries(),
	getAuthorEntries(),
	getBlogEntries(),
]);
const posts = sortPostsByDate(normalizePosts(blogEntries, authorEntries)).filter(isPublicPost);
const areaDirectory = buildCanonicalAreaDirectory(areaEntries, posts);
const primaryAreaCodes = new Set(['CAT-01', 'CAT-02', 'CAT-03', 'CAT-05']);
const primaryAreas = areaDirectory.filter((area) => primaryAreaCodes.has(area.code));
const secondaryAreas = areaDirectory.filter((area) => !primaryAreaCodes.has(area.code));

const faqSchema = buildFaqSchema(
	faq.map((item) => ({
		question: item.q,
		answer: item.a,
	})),
);

const localBusinessSchema = {
	...LEGAL_SERVICE_BASE_SCHEMA,
	description,
	image: toAbsoluteUrl('/brand/pavie-logo-master.svg'),
};
---

<BaseLayout title={title} description={description} canonical={`${MAIN_SITE_URL}/`}>
	<div class="container site-home">
		<section class="site-hero" aria-labelledby="hero-title">
			<div class="site-hero__content">
				<span class="badge">PAVIE | Advocacia | OAB/RJ 134.947</span>
				<h1 id="hero-title">Advocacia para questoes que exigem clareza, metodo e responsabilidade.</h1>
				<p class="site-hero__lead">
					A PAVIE | Advocacia atua em situacoes que impactam patrimonio, familia, sucessao, imoveis,
					documentos relevantes e relacoes contratuais seletivas, com analise tecnica, linguagem clara
					e direcao juridica responsavel.
				</p>
				<div class="site-hero__cta">
					<a class="btn btn-primary" href="#contato">Enviar informacoes iniciais</a>
					<a class="btn btn-secondary" href="/areas/">Conheca as areas</a>
				</div>
				<p class="site-hero__microcopy">
					O conteudo do site e informativo; a orientacao depende da situacao individual.
				</p>
			</div>

			<aside class="site-hero__panel" aria-labelledby="hero-panel-title">
				<span class="section-kicker">Primeiro passo</span>
				<h2 id="hero-panel-title">O que acontece na etapa inicial</h2>
				<ul class="hero-list">
					<li>Leitura objetiva da situacao apresentada.</li>
					<li>Identificacao de documentos, prazos e pontos de risco.</li>
					<li>Orientacao sobre a via adequada para avancar, quando houver aderencia.</li>
				</ul>
				<p>
					O primeiro contato contextualiza o problema. Ele nao significa promessa de resultado nem
					patrocinio automatico.
				</p>
			</aside>
		</section>

		<section class="proof-strip" aria-label="Barra de prova institucional">
			{proofItems.map((item) => (
				<article class="proof-item">
					<strong>{item.title}</strong>
					<p>{item.text}</p>
				</article>
			))}
		</section>

		<section id="advogado" class="site-section" aria-labelledby="advogado-title">
			<div class="section-title">
				<div>
					<span class="section-kicker">Direcao juridica</span>
					<h2 id="advogado-title">
						Fabio Pavie conduz o atendimento com metodo, clareza de linguagem e responsabilidade profissional.
					</h2>
				</div>
			</div>

			<article class="surface-card professional-section">
				<img
					src="/uploads/fabio-pavie-profile.png"
					alt="Foto profissional do advogado Fabio Mathias Pavie"
					loading="lazy"
				/>
				<div class="professional-copy">
					<p class="professional-meta">Advogado | OAB/RJ 134.947</p>
					<h3>Fabio Mathias Pavie</h3>
					<p>
						Fabio Pavie conduz uma pratica orientada por organizacao, rigor documental,
						clareza de linguagem e responsabilidade estrategica.
					</p>
					<p>
						A proposta da PAVIE nao e ampliar artificialmente areas de atuacao, mas oferecer
						leitura tecnica proporcional para problemas juridicos relevantes.
					</p>
					<div class="site-hero__cta">
						<a class="btn btn-ghost" href="/sobre/">Conheca a direcao juridica</a>
					</div>
				</div>
			</article>
		</section>

		<section id="metodo" class="site-section site-method" aria-labelledby="metodo-title">
			<div class="section-title section-title--center">
				<div>
					<span class="section-kicker">Como funciona</span>
					<h2 id="metodo-title">Como conduzimos o seu caso</h2>
					<p>
						A tranquilidade das decisoes depende de metodo e clareza. O processo parte do
						primeiro contato e avanca conforme a previsibilidade necessaria ao caso concreto.
					</p>
				</div>
			</div>

			<ol class="process-list process-list--four">
				{processSteps.map((step, index) => (
					<li class="surface-card process-step">
						<span class="process-step__number">{index + 1}</span>
						<h3>{step.title}</h3>
						<p>{step.text}</p>
					</li>
				))}
			</ol>
		</section>

		<section id="areas" class="site-section" aria-labelledby="areas-title">
			<div class="section-title">
				<div>
					<span class="section-kicker">Areas de atuacao</span>
					<h2 id="areas-title">Areas de atuacao estrategica</h2>
					<p>
						A atuacao publica da PAVIE esta organizada pelas sete areas canonicas, com destaque
						inicial para os eixos de maior aderencia institucional.
					</p>
				</div>
				<a class="btn btn-ghost" href="/areas/">Ver areas canonicas</a>
			</div>

			<div class="service-cluster-grid service-cluster-grid--primary">
				{primaryAreas.map((area) => (
					<article class="surface-card service-cluster">
						<span class="section-kicker">{area.code}</span>
						<h3>{area.title}</h3>
						<p class="service-cluster__lead">{area.shortDescription}</p>
						<p>{area.headline}</p>
						<div class="site-hero__cta">
							<a class="btn btn-ghost" href={area.href}>Conhecer area</a>
						</div>
					</article>
				))}
			</div>

			{secondaryAreas.length > 0 && (
				<div class="secondary-areas">
					<div class="secondary-areas__intro">
						<span class="section-kicker">Frentes complementares canonicas</span>
						<p>
							Estas frentes permanecem no escopo aprovado, mas aparecem com menor peso na home
							para evitar efeito de catalogo bruto.
						</p>
					</div>
					<div class="service-cluster-grid service-cluster-grid--secondary">
						{secondaryAreas.map((area) => (
							<article class="surface-card service-cluster service-cluster--secondary">
								<span class="section-kicker">{area.code}</span>
								<h3>{area.title}</h3>
								<p>{area.shortDescription}</p>
								<div class="site-hero__cta">
									<a class="btn btn-ghost" href={area.href}>Conhecer area</a>
								</div>
							</article>
						))}
					</div>
				</div>
			)}
		</section>

		<section id="conteudos" class="site-section" aria-labelledby="conteudos-title">
			<article class="surface-card site-bridge">
				<div>
					<span class="section-kicker">Conteudo educativo</span>
					<h2 id="conteudos-title">Aprofunde a compreensao antes de tomar uma decisao.</h2>
					<p>
						O blog juridico funciona como ponte editorial: a leitura ajuda a organizar o tema,
						separar duvida geral de analise individual e chegar ao contato com mais clareza.
					</p>
				</div>
				<div class="site-hero__cta">
					<a class="btn btn-secondary" href="/blog/">Acessar artigos e guias</a>
				</div>
			</article>
		</section>

		<section id="faq" class="site-section" aria-labelledby="faq-title">
			<div class="section-title">
				<div>
					<span class="section-kicker">FAQ curta</span>
					<h2 id="faq-title">Respostas iniciais para o primeiro contato</h2>
				</div>
			</div>

			<div class="faq-list">
				{faq.map((item) => (
					<details class="surface-card">
						<summary>{item.q}</summary>
						<p>{item.a}</p>
					</details>
				))}
			</div>
		</section>

		<section id="contato" class="site-contact" aria-labelledby="contato-title">
			<div class="site-contact__copy">
				<BrandLogo variant="full" theme="dark" width={240} />
				<span class="section-kicker">Contato institucional</span>
				<h2 id="contato-title">Enviar informacoes iniciais para uma leitura responsavel.</h2>
				<p>
					O formulario abaixo ajuda a organizar o ponto de partida. O primeiro retorno serve para
					compreender contexto, documentos e aderencia; nao representa contratacao automatica.
				</p>

				<article class="site-contact__honorarios">
					<h3>Transparencia em honorarios</h3>
					<p>
						Os honorarios dependem de escopo, complexidade, urgencia e acompanhamento necessario.
						Quando houver aderencia, a proposta e apresentada antes de qualquer inicio de trabalho.
					</p>
				</article>

				<ul class="site-contact__links" aria-label="Canais de contato">
					<li><a href="mailto:contato@pavieadvocacia.com.br">contato@pavieadvocacia.com.br</a></li>
					<li><a href="tel:+5521964382263">+55 (21) 96438-2263</a></li>
				</ul>
			</div>

			<form
				id="siteContactForm"
				class="site-contact__form"
				action="/api/contato"
				method="post"
				aria-describedby="site-contact-note"
			>
				<h3>Solicitar analise do caso</h3>
				<p>
					Compartilhe apenas as informacoes iniciais. Documentos sensiveis podem ser enviados depois,
					se forem necessarios para a continuidade da analise.
				</p>

				<input id="turnstileToken" name="turnstileToken" type="hidden" />

				<label>
					<span>Nome completo</span>
					<input id="nome" name="nome" autocomplete="name" required type="text" />
				</label>

				<label>
					<span>E-mail</span>
					<input id="email" name="email" autocomplete="email" required type="email" />
				</label>

				<label>
					<span>Telefone ou WhatsApp</span>
					<input id="telefone_full" name="telefone_full" autocomplete="tel" inputmode="tel" type="tel" />
				</label>

				<label>
					<span>Resumo da situacao</span>
					<textarea id="mensagem" name="mensagem" required rows="5"></textarea>
				</label>

				<label class="site-contact__consent">
					<input name="consent" required type="checkbox" />
					<span>Autorizo o uso dos dados enviados apenas para retorno do contato, sob sigilo profissional.</span>
				</label>

				<div
					class="cf-turnstile"
					data-sitekey="0x4AAAAAAB6FBS0cTG_7KOYv"
					data-callback="onTsDone"
					data-expired-callback="onTsExpired"
					data-error-callback="onTsError"
				>
				</div>

				<p id="site-contact-status" class="site-contact__status" role="status" aria-live="polite"></p>

				<button class="btn btn-primary" type="submit">Enviar informacoes iniciais</button>
				<p id="site-contact-note" class="site-contact__note">
					Contato inicial nao e contratacao automatica. A orientacao juridica depende da analise da situacao individual.
				</p>
			</form>
		</section>
	</div>

	<script is:inline>
		(function () {
			var tokenField = document.getElementById('turnstileToken');
			var form = document.getElementById('siteContactForm');
			var status = document.getElementById('site-contact-status');

			window.onTsDone = function (token) {
				if (tokenField) tokenField.value = token || '';
				if (status) status.textContent = 'Validacao de seguranca concluida.';
			};
			window.onTsExpired = function () {
				if (tokenField) tokenField.value = '';
				if (status) status.textContent = 'Validacao expirada. Aguarde recarregar e tente novamente.';
			};
			window.onTsError = function () {
				if (tokenField) tokenField.value = '';
				if (status) status.textContent = 'Nao foi possivel carregar a validacao de seguranca.';
			};

			if (!form || !status) return;

			form.addEventListener('submit', async function (event) {
				event.preventDefault();
				var button = form.querySelector('button[type="submit"]');
				var originalText = button ? button.textContent : '';

				if (tokenField && !tokenField.value) {
					status.textContent = 'Aguarde a validacao de seguranca antes de enviar.';
					return;
				}

				if (button) {
					button.disabled = true;
					button.textContent = 'Enviando...';
				}
				status.textContent = 'Enviando informacoes iniciais...';

				try {
					var response = await fetch(form.action, {
						method: 'POST',
						body: new FormData(form),
						headers: { Accept: 'application/json' },
					});
					var data = await response.json().catch(function () { return {}; });
					if (!response.ok || data.ok === false) {
						throw new Error(data.error || 'Falha no envio.');
					}
					status.textContent = 'Solicitacao enviada. A PAVIE fara a triagem inicial do contato.';
					form.reset();
					if (tokenField) tokenField.value = '';
					if (window.turnstile && typeof window.turnstile.reset === 'function') {
						window.turnstile.reset();
					}
				} catch (error) {
					status.textContent = error && error.message
						? 'Nao foi possivel enviar: ' + error.message
						: 'Nao foi possivel enviar a solicitacao.';
				} finally {
					if (button) {
						button.disabled = false;
						button.textContent = originalText;
					}
				}
			});
		})();
	</script>
	<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
	<script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	<script is:inline type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
</BaseLayout>
