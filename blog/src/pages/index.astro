---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildFaqSchema, LEGAL_SERVICE_BASE_SCHEMA, toAbsoluteUrl } from '../lib/seo';
import { MAIN_SITE_URL } from '../consts';
import { getAreaEntries, getAuthorEntries, getBlogEntries } from '../lib/blog-content';
import { buildCanonicalAreaDirectory } from '../lib/canonical-directory';
import { isPublicPost, normalizePosts, sortPostsByDate } from '../lib/posts';
import '../styles/site-home.css';

const title = 'PAVIE | Advocacia | Clareza, metodo e responsabilidade';
const description =
	'A PAVIE | Advocacia atua em situacoes que impactam patrimonio, familia, sucessao, imoveis, documentos relevantes e relacoes contratuais seletivas, com analise tecnica, linguagem clara e direcao juridica responsavel.';

const proofItems = [
	{
		title: 'OAB/RJ 134.947',
		text: 'Atuacao identificavel, contratacao formal e responsabilidade tecnica em cada etapa do atendimento.',
	},
	{
		title: 'Atendimento online e presencial',
		text: 'O primeiro formato de contato se ajusta ao contexto do caso e a necessidade pratica da situacao.',
	},
	{
		title: 'Contratacao formal',
		text: 'Escopo, etapas, honorarios e forma de acompanhamento sao apresentados com clareza quando houver aderencia.',
	},
	{
		title: 'Conteudo informativo',
		text: 'A leitura ajuda a organizar o problema, mas a orientacao depende sempre da situacao individual.',
	},
];

const methodPoints = [
	{
		title: 'Clareza antes da estrategia',
		text: 'O atendimento comeca pela leitura do contexto, da urgencia pratica e dos documentos que realmente importam.',
	},
	{
		title: 'Analise juridica responsavel',
		text: 'Riscos, caminhos possiveis e limites do caso sao explicados com linguagem compreensivel e enquadramento tecnico.',
	},
	{
		title: 'Conducao com previsibilidade',
		text: 'Escopo, etapas, honorarios e forma de acompanhamento sao apresentados de modo direto e formal.',
	},
];

const processSteps = [
	{
		title: 'Contato inicial',
		text: 'Voce apresenta a situacao principal, a urgencia pratica e o objetivo do contato.',
	},
	{
		title: 'Triagem e documentos',
		text: 'O escritorio identifica o que precisa ser compreendido antes de avancar para analise mais profunda.',
	},
	{
		title: 'Analise inicial ou consulta',
		text: 'Quando necessario, o caso passa por consulta ou leitura tecnica para enquadramento do caminho adequado.',
	},
	{
		title: 'Proposta e contratacao formal',
		text: 'Escopo, etapas, honorarios e forma de acompanhamento sao apresentados com transparencia.',
	},
	{
		title: 'Conducao juridica',
		text: 'A atuacao segue com comunicacao objetiva, responsabilidade tecnica e registro do que foi definido.',
	},
];

const faq = [
	{
		q: 'Quando vale buscar uma analise juridica inicial?',
		a: 'Quando ha decisao relevante a tomar, risco patrimonial, conflito em curso, duvida documental ou urgencia pratica que nao deve ser tratada no improviso.',
	},
	{
		q: 'A primeira conversa ja significa contratacao?',
		a: 'Nao. O primeiro contato serve para triagem e orientacao inicial. A contratacao so acontece se houver aderencia, escopo definido e proposta formal.',
	},
	{
		q: 'O atendimento pode ser online?',
		a: 'Sim. O atendimento pode ocorrer online ou presencialmente, conforme o caso, a localizacao e a necessidade pratica da situacao.',
	},
	{
		q: 'O que devo informar no primeiro contato?',
		a: 'A situacao principal, desde quando ela ocorre, quem esta envolvido, quais documentos existem e se ha prazo, audiencia ou urgencia concreta.',
	},
	{
		q: 'Como os honorarios sao definidos?',
		a: 'Os honorarios dependem do tipo de demanda, do escopo, da complexidade, da urgencia e da necessidade de acompanhamento. A proposta e sempre formal e clara.',
	},
];

const [areaEntries, authorEntries, blogEntries] = await Promise.all([
	getAreaEntries(),
	getAuthorEntries(),
	getBlogEntries(),
]);
const posts = sortPostsByDate(normalizePosts(blogEntries, authorEntries)).filter(isPublicPost);
const areaDirectory = buildCanonicalAreaDirectory(areaEntries, posts);

const faqSchema = buildFaqSchema(
	faq.map((item) => ({
		question: item.q,
		answer: item.a,
	})),
);

const localBusinessSchema = {
	...LEGAL_SERVICE_BASE_SCHEMA,
	description,
	image: toAbsoluteUrl('/uploads/foto_001-ffundddo-escrit%C3%B3rio.png'),
};
---

<BaseLayout title={title} description={description} canonical={`${MAIN_SITE_URL}/`}>
	<div class="container site-home">
		<section class="site-hero surface-card" aria-labelledby="hero-title">
			<div class="site-hero__content">
				<span class="badge">PAVIE | Advocacia | OAB/RJ 134.947</span>
				<h1 id="hero-title">Advocacia para questoes que exigem clareza, metodo e responsabilidade.</h1>
				<p class="site-hero__lead">
					A PAVIE | Advocacia atua em situacoes que impactam patrimonio, familia, sucessao, imoveis,
					documentos relevantes e relacoes contratuais seletivas, com analise tecnica, linguagem clara
					e direcao juridica responsavel.
				</p>
				<div class="site-hero__cta">
					<a class="btn btn-primary" href="/contato/">Solicitar analise inicial</a>
					<a class="btn btn-secondary" href="/areas/">Conheca as areas</a>
				</div>
				<p class="site-hero__microcopy">
					O conteudo do site e informativo; a orientacao depende da situacao individual.
				</p>
			</div>

			<aside class="site-hero__panel" aria-labelledby="hero-panel-title">
				<span class="section-kicker">Primeiro passo</span>
				<h2 id="hero-panel-title">O que acontece na etapa inicial</h2>
				<ul class="hero-list">
					<li>Leitura objetiva da situacao apresentada.</li>
					<li>Identificacao de documentos, prazos e pontos de risco.</li>
					<li>Orientacao sobre a via mais adequada para avancar.</li>
				</ul>
				<p>
					O primeiro contato serve para contextualizar o problema, e nao para prometer resultado ou
					patrocinio automatico.
				</p>
			</aside>
		</section>

		<section class="proof-strip" aria-label="Barra de prova institucional">
			{proofItems.map((item) => (
				<article class="proof-item">
					<strong>{item.title}</strong>
					<p>{item.text}</p>
				</article>
			))}
		</section>

		<section id="advogado" class="site-section" aria-labelledby="advogado-title">
			<div class="section-title">
				<div>
					<span class="section-kicker">Quem conduz</span>
					<h2 id="advogado-title">
						Fabio Pavie conduz o atendimento com metodo, clareza de linguagem e responsabilidade profissional.
					</h2>
				</div>
			</div>

			<div class="professional-layout">
				<article class="surface-card professional-section">
					<img
						src="/uploads/foto_001-ffundddo-escrit%C3%B3rio.png"
						alt="Foto profissional do advogado Fabio Mathias Pavie"
						loading="lazy"
					/>
					<div class="professional-copy">
						<p class="professional-meta">Advogado | OAB/RJ 134.947</p>
						<h3>Fabio Mathias Pavie</h3>
						<p>
							Fabio Pavie conduz uma pratica orientada por organizacao, rigor documental,
							clareza de linguagem e responsabilidade estrategica.
						</p>
						<p>
							Na proposta atual do escritorio, o foco recai sobre situacoes em que patrimonio,
							familia, sucessao, imoveis, estrutura documental e decisoes preventivas ou litigiosas
							se cruzam de forma relevante.
						</p>
						<ul class="professional-highlights">
							<li>Leitura responsavel do caso concreto.</li>
							<li>Organizacao documental e definicao da via adequada.</li>
							<li>Escopo claro e comunicacao objetiva.</li>
						</ul>
						<div class="site-hero__cta">
							<a class="btn btn-primary" href="/contato/">Solicitar analise inicial</a>
							<a class="btn btn-ghost" href="/sobre/">Conheca o perfil profissional</a>
						</div>
					</div>
				</article>

				<div class="method-grid">
					{methodPoints.map((point) => (
						<article class="surface-card method-card">
							<h3>{point.title}</h3>
							<p>{point.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section id="servicos" class="site-section" aria-labelledby="servicos-title">
			<div class="section-title">
				<div>
					<span class="section-kicker">Areas de atuacao</span>
					<h2 id="servicos-title">
						As areas de atuacao ajudam a localizar a situacao e o ponto de partida adequado.
					</h2>
				</div>
				<a class="btn btn-ghost" href="/areas/">Ver todas as areas</a>
			</div>

			<div class="service-cluster-grid">
				{areaDirectory.map((area) => (
					<article class="surface-card service-cluster">
						<h3>{area.title}</h3>
						<p class="service-cluster__lead">{area.shortDescription}</p>
						<p>{area.headline}</p>
						<ul>
							<li>
								{area.postCount > 0
									? `${area.postCount} artigo${area.postCount > 1 ? 's' : ''} publicado${area.postCount > 1 ? 's' : ''} no blog.`
									: 'Pagina institucional disponivel para esta frente de atuacao.'}
							</li>
							<li>Conexao direta entre a pagina institucional e a categoria correspondente do blog.</li>
						</ul>
						<div class="site-hero__cta">
							<a class="btn btn-primary" href={area.href}>Conheca esta area</a>
							<a class="btn btn-ghost" href={area.categoryHref}>Explorar categoria</a>
						</div>
					</article>
				))}
			</div>

			<p class="coherence-note">
				Se a sua duvida ainda nao esta bem localizada, as categorias do blog ajudam a organizar o tema
				antes do contato.
			</p>

			<article class="surface-card site-bridge">
				<div>
					<span class="section-kicker">Leitura util antes do contato</span>
					<h3>
						Nem toda duvida pede contratacao imediata. Muitas vezes, o melhor primeiro passo e entender o enquadramento da situacao.
					</h3>
					<p>
						O blog reune leituras por categoria para ajudar voce a reconhecer o eixo juridico do problema,
						separar o que e duvida geral do que ja exige analise do caso concreto e chegar ao contato com mais clareza.
					</p>
				</div>
				<div class="site-hero__cta">
					<a class="btn btn-primary" href="/blog/categoria/">Explorar categorias do blog</a>
					<a class="btn btn-secondary" href="/blog/">Ir para o blog</a>
				</div>
			</article>
		</section>

		<section id="como-contratar" class="site-section" aria-labelledby="contratacao-title">
			<div class="section-title">
				<div>
					<span class="section-kicker">Como contratar</span>
					<h2 id="contratacao-title">O processo de contratacao e explicado antes de qualquer decisao</h2>
				</div>
			</div>

			<ol class="process-list">
				{processSteps.map((step, index) => (
					<li class="surface-card process-step">
						<span class="process-step__number">{index + 1}</span>
						<h3>{step.title}</h3>
						<p>{step.text}</p>
					</li>
				))}
			</ol>
		</section>

		<section id="honorarios" class="site-section split" aria-labelledby="honorarios-title">
			<article class="surface-card info-card">
				<span class="section-kicker">Honorarios</span>
				<h2 id="honorarios-title">Como os honorarios sao definidos</h2>
				<p>
					Os honorarios dependem do tipo de demanda, do escopo, da complexidade, da urgencia
					e da necessidade de acompanhamento. Nao ha tabela promocional no site.
				</p>
				<ul class="info-list">
					<li>Analise tecnica do problema apresentado.</li>
					<li>Definicao clara do que sera feito e do que nao esta incluido.</li>
					<li>Proposta formal, compativel com as normas eticas da advocacia.</li>
				</ul>
			</article>

			<article class="surface-card info-card">
				<span class="section-kicker">Contratacao formal</span>
				<h2>O que voce recebe antes de contratar</h2>
				<p>
					Antes de qualquer inicio de trabalho, a PAVIE esclarece escopo, etapas, forma de
					acompanhamento, honorarios e documentos necessarios para a conducao juridica.
				</p>
				<ul class="info-list">
					<li>Escopo e objetivos do trabalho.</li>
					<li>Etapas, prazos praticos e responsabilidades.</li>
					<li>Forma de comunicacao e registro da contratacao.</li>
				</ul>
			</article>
		</section>

		<section id="faq" class="site-section" aria-labelledby="faq-title">
			<div class="section-title">
				<div>
					<span class="section-kicker">Perguntas frequentes</span>
					<h2 id="faq-title">Respostas curtas para atritos reais do primeiro contato</h2>
				</div>
			</div>

			<div class="faq-list">
				{faq.map((item) => (
					<details class="surface-card">
						<summary>{item.q}</summary>
						<p>{item.a}</p>
					</details>
				))}
			</div>
		</section>

		<section id="contato" class="site-contact surface-card" aria-labelledby="contato-title">
			<div>
				<span class="section-kicker">Contato final</span>
				<h2 id="contato-title">
					Tem uma situacao que exige analise juridica? O primeiro passo e entender o problema com clareza.
				</h2>
				<p>
					O contato institucional pode seguir por formulario, e-mail ou WhatsApp. O objetivo do
					primeiro retorno e entender o contexto, e nao prometer desfecho antecipado.
				</p>
			</div>

			<div class="site-contact__grid">
				<article class="site-contact__panel">
					<h3>O que informar</h3>
					<ul>
						<li>Situacao principal e desde quando ela ocorre.</li>
						<li>Pessoas, documentos ou contratos envolvidos.</li>
						<li>Se existe prazo, audiencia ou urgencia pratica.</li>
					</ul>
				</article>

				<article class="site-contact__panel">
					<h3>O que acontece depois</h3>
					<ul>
						<li>A equipe faz a triagem inicial do que foi enviado.</li>
						<li>Se necessario, orienta consulta, envio complementar ou proposta.</li>
						<li>A contratacao so ocorre com escopo definido e aceite formal.</li>
					</ul>
				</article>
			</div>

			<div class="site-contact__actions">
				<a class="btn btn-primary" href="/contato/">Enviar informacoes iniciais</a>
			</div>

			<p class="site-contact__note">
				A PAVIE promete leitura inicial responsavel, confidencialidade e orientacao adequada ao
				contexto apresentado. Nao promete resultado, prazo judicial fechado ou admissao automatica do caso.
			</p>
		</section>
	</div>

	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
</BaseLayout>
