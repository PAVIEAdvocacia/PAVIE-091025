---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Sobre | PAVIE';
const description = 'Página de transição para o perfil institucional da PAVIE Advocacia.';
---

<BaseLayout title={title} description={description} canonical="https://blog.pavieadvocacia.com.br/sobre/" noIndex>
	<div class="container-md" style="padding-top: 2rem; display: grid; gap: 1rem;">
		<span class="badge">Atualização de rota</span>
		<h1 style="font-size: clamp(1.8rem, 1.2rem + 1.6vw, 2.5rem);">Esta página foi reorganizada.</h1>
		<p style="color: var(--text-muted);">
			O conteúdo institucional completo está disponível em <a href="/sobre/">/sobre</a>.
		</p>
		<div>
			<a class="btn btn-primary" href="/sobre/">Ir para Sobre</a>
		</div>
	</div>
</BaseLayout>
