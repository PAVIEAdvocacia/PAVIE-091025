---
import Breadcrumbs from '../../../components/blog/Breadcrumbs.astro';
import BlogGrid from '../../../components/blog/BlogGrid.astro';
import { BLOG_SITE_URL, MAIN_SITE_URL } from '../../../consts';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import { getAuthorEntries, getBlogEntries } from '../../../lib/blog-content';
import { getAuthorEntryBySlug } from '../../../lib/canonical-directory';
import { normalizeCmsImagePath } from '../../../lib/content-media';
import { isPublicPost, normalizePosts, sortPostsByDate } from '../../../lib/posts';
import { buildBreadcrumbSchema, toAbsoluteUrl } from '../../../lib/seo';

export async function getStaticPaths() {
	const authorEntries = await getAuthorEntries();
	return authorEntries.map((entry) => ({ params: { slug: entry.data.slug } }));
}

const [authorEntries, blogEntries] = await Promise.all([getAuthorEntries(), getBlogEntries()]);
const currentAuthor = getAuthorEntryBySlug(authorEntries, Astro.params.slug ?? '');

if (!currentAuthor) {
	throw new Error(`Autor canonico nao encontrado: ${Astro.params.slug}`);
}

const authorImage = normalizeCmsImagePath(currentAuthor.data.image) ?? currentAuthor.data.image;
const posts = sortPostsByDate(normalizePosts(blogEntries, authorEntries))
	.filter(isPublicPost)
	.filter((post) => post.authorSlug === currentAuthor.data.slug);
const canonicalUrl = `${BLOG_SITE_URL}/blog/autor/${currentAuthor.data.slug}/`;
const breadcrumbs = [
	{ label: 'Inicio', href: '/' },
	{ label: 'Publicacoes', href: '/blog/' },
	{ label: 'Autor' },
	{ label: currentAuthor.data.name },
];
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);
const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: currentAuthor.data.name,
	url: canonicalUrl,
	image: toAbsoluteUrl(authorImage),
	description: currentAuthor.data.shortBio,
	jobTitle: 'Advogado',
};
---

<BlogLayout
	title={`${currentAuthor.data.name} | Autor | PAVIE | Advocacia`}
	description={currentAuthor.data.shortBio}
	canonical={canonicalUrl}
	author={currentAuthor.data.name}
>
	<div class="container blog-home author-page">
		<Breadcrumbs items={breadcrumbs} />

		<section class="author-hero" aria-labelledby="author-title">
			<div class="author-hero__media">
				<img src={authorImage} alt={currentAuthor.data.imageAlt} loading="eager" decoding="async" />
			</div>
			<div class="author-hero__copy">
				<span class="badge">Autor</span>
				<h1 id="author-title">{currentAuthor.data.name}</h1>
				<p class="author-hero__oab">{currentAuthor.data.oab}</p>
				<p>{currentAuthor.data.shortBio}</p>
				<div class="blog-hero__actions">
					<a class="btn btn-primary" href="#textos-do-autor">Ver textos</a>
					<a class="btn btn-ghost" href={MAIN_SITE_URL}>Ir ao site</a>
				</div>
			</div>
		</section>

		<section class="author-focus" aria-labelledby="author-focus-title">
			<div class="section-title">
				<div>
					<span class="section-kicker">Foco editorial</span>
					<h2 id="author-focus-title">A assinatura organiza leitura, contexto e limites.</h2>
				</div>
			</div>
			<div class="author-focus__grid">
				<article class="surface-card author-focus__card">
					<span>01</span>
					<h3>Criterios e documentos</h3>
					<p>Os textos priorizam enquadramento, prova, cronologia e riscos praticos antes de qualquer conclusao.</p>
				</article>
				<article class="surface-card author-focus__card">
					<span>02</span>
					<h3>Reconducao responsavel</h3>
					<p>A leitura editorial ajuda a nomear o problema e, quando necessario, remete ao site institucional.</p>
				</article>
			</div>
		</section>

		<BlogGrid
			id="textos-do-autor"
			title="Textos recentes"
			kicker="Publicacoes do autor"
			posts={posts}
			emptyTitle="Acervo em atualizacao"
			emptyText="A pagina de autor ja esta estruturada. Novos artigos entram aqui conforme passam por revisao editorial e juridica."
			emptyHref="/blog/"
			emptyLabel="Voltar ao blog"
		/>

		<section class="author-institutional-link" aria-labelledby="author-institutional-title">
			<span class="section-kicker">Vinculo institucional</span>
			<div>
				<h2 id="author-institutional-title">A pagina do autor sustenta a autoria; o site concentra a relacao institucional.</h2>
				<p>
					Para conhecer areas, metodo e caminhos de contato, siga pela sede institucional da PAVIE.
					Esta pagina permanece como referencia editorial dos textos assinados.
				</p>
			</div>
			<a class="btn btn-ghost" href={MAIN_SITE_URL}>Ir ao site</a>
		</section>
	</div>

	<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	<script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
</BlogLayout>
