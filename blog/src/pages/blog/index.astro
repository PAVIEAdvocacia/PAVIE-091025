---
import BlogGrid from '../../components/blog/BlogGrid.astro';
import FeaturedPost from '../../components/blog/FeaturedPost.astro';
import { BLOG_SITE_URL } from '../../consts';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getAreaEntries, getAuthorEntries, getBlogEntries } from '../../lib/blog-content';
import { buildCanonicalAreaDirectory } from '../../lib/canonical-directory';
import { normalizeCmsImagePath } from '../../lib/content-media';
import { isPublicPost, normalizePosts, sortPostsByDate } from '../../lib/posts';

const [areaEntries, authorEntries, blogEntries] = await Promise.all([
	getAreaEntries(),
	getAuthorEntries(),
	getBlogEntries(),
]);
const posts = sortPostsByDate(normalizePosts(blogEntries, authorEntries)).filter(isPublicPost);
const featured = posts.find((post) => post.featured) ?? (posts.length > 0 ? posts[0] : undefined);
const continuityPosts = posts.filter((post) => post.slug !== featured?.slug).slice(0, 6);
const categoryDirectory = buildCanonicalAreaDirectory(areaEntries, posts);
const hasPublishedPosts = posts.length > 0;
const postCountLabel = hasPublishedPosts
	? `${posts.length} artigo${posts.length === 1 ? '' : 's'} publicado${posts.length === 1 ? '' : 's'} no acervo atual`
	: 'Acervo editorial em preparação';
const blogAuthor =
	authorEntries.find((entry) => entry.data.slug === 'fabio-pavie' || entry.data.id === 'fabio-pavie') ??
	authorEntries[0];
const blogAuthorImage =
	normalizeCmsImagePath(blogAuthor?.data.image) ?? '/uploads/foto_001-ffundddo-escrit%C3%B3rio.png';
const blogAuthorAlt =
	blogAuthor?.data.imageAlt ?? 'Foto profissional do advogado Fabio Mathias Pavie';
const collectionSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'Blog Jurídico PAVIE',
	url: `${BLOG_SITE_URL}/blog/`,
	description:
		'Leituras jurídicas da PAVIE organizadas por categorias do blog e conectadas às áreas públicas correspondentes.',
	mainEntity:
		posts.length > 0
			? {
					'@type': 'ItemList',
					itemListElement: posts.slice(0, 12).map((post, index) => ({
						'@type': 'ListItem',
						position: index + 1,
						url: `${BLOG_SITE_URL}${post.url}`,
						name: post.title,
					})),
				}
			: undefined,
};
---

<BlogLayout
	title="Blog jurídico da PAVIE | Advocacia"
	description="Leitura jurídica organizada por categorias do blog, com conexão direta entre conteúdo, áreas e orientação inicial."
	canonical={`${BLOG_SITE_URL}/blog/`}
>
	<div class="container blog-home">
		<section class="blog-hero" aria-labelledby="blog-hero-title">
			<div class="blog-hero__content">
				<span class="badge">Blog jurídico PAVIE | Advocacia</span>
				<h1 id="blog-hero-title">Comece pela categoria que melhor enquadra a sua situação.</h1>
				<p>
					O blog organiza as leituras por categorias ligadas às áreas do site. Cada texto aprofunda
					critérios, documentos e próximos passos com linguagem clara e foco no caso concreto.
				</p>
				<div class="meta-list" aria-label="Informações do acervo">
					<span><span class="meta-dot" aria-hidden="true"></span>{postCountLabel}</span>
					<span><span class="meta-dot" aria-hidden="true"></span>{categoryDirectory.length} categorias disponíveis</span>
					<span><span class="meta-dot" aria-hidden="true"></span>Ligação direta com as páginas de área</span>
				</div>
				<div class="blog-hero__actions">
					<a class="btn btn-primary" href="/blog/categoria/">Explorar categorias</a>
					<a class="btn btn-ghost" href="/">Voltar ao site institucional</a>
				</div>
			</div>
		</section>

		<section class="taxonomy-index" aria-labelledby="taxonomy-index-title">
			<div class="taxonomy-index__intro">
				<span class="section-kicker">Índice taxonômico</span>
				<h2 id="taxonomy-index-title">Escolha o tema de interesse e avance para a leitura.</h2>
				<p>
					As categorias organizam o acervo por assunto, preservando a ligação entre conteúdo editorial
					e áreas públicas correspondentes.
				</p>
				<div class="blog-actions">
					<a class="btn btn-primary" href="/blog/categoria/">Explorar categorias</a>
					<a class="btn btn-ghost" href="/">Voltar ao site institucional</a>
				</div>
			</div>
			<nav class="taxonomy-index__nav" aria-label="Categorias do blog">
				<ol>
					{categoryDirectory.map((category, index) => (
						<li>
							<a href={category.categoryHref}>
								<span class="taxonomy-index__number">{String(index + 1).padStart(2, '0')}</span>
								<span class="taxonomy-index__label">{category.displayTitle}</span>
								<span class="taxonomy-index__count">
									{category.postCount > 0
										? `${category.postCount} leitura${category.postCount === 1 ? '' : 's'}`
										: 'em preparação'}
								</span>
							</a>
						</li>
					))}
				</ol>
			</nav>
		</section>

		<section class="featured-reading" aria-label="Leitura em destaque">
			{!hasPublishedPosts ? (
				<article class="surface-card empty-state" aria-label="Acervo em organização">
					<h2>Acervo em atualização</h2>
					<p>
						As categorias já organizam a navegação do blog. Novos textos entram conforme avançam a
						revisão editorial e jurídica do acervo público.
					</p>
					<div class="blog-actions">
						<a class="btn btn-primary" href="/blog/categoria/">Explorar categorias</a>
						<a class="btn btn-ghost" href="/">Voltar ao site institucional</a>
					</div>
				</article>
			) : (
				featured && <FeaturedPost post={featured} kicker="Guia em destaque" />
			)}
		</section>

		{continuityPosts.length > 0 && (
			<BlogGrid title="Leituras recentes" kicker="Publicações recentes" posts={continuityPosts} />
		)}

		<section class="surface-card blog-author-spotlight" aria-label="Autor do blog">
			<img
				src={blogAuthorImage}
				alt={blogAuthorAlt}
				loading="eager"
				decoding="async"
			/>
			<div>
				<span class="section-kicker">Autor do blog</span>
				<h2>{blogAuthor?.data.name ?? 'Fabio Mathias Pavie'}</h2>
				<p>{blogAuthor?.data.oab ?? 'Advogado | OAB/RJ 134.947'}</p>
				<p>
					Fabio Pavie organiza leituras do blog a partir das categorias canônicas da PAVIE, com foco em
					critérios, documentos, limites e recondução responsável ao site institucional.
				</p>
				<div class="blog-actions">
					<a class="btn btn-primary" href="/autor/fabio-pavie/">Conheça o autor</a>
					<a class="btn btn-ghost" href="/blog/categoria/">Explorar categorias</a>
				</div>
			</div>
		</section>

		<section class="editorial-cta" aria-label="Retorno ao site institucional">
			<span class="section-kicker">Retorno ao site institucional</span>
			<h2>Quando a leitura já ajudou a organizar o tema, volte ao site para conhecer a área correspondente.</h2>
			<p>
				O blog prepara a compreensão. A sede institucional concentra áreas, método, limites do primeiro contato e
				informações necessárias para uma eventual solicitação.
			</p>
			<div class="blog-actions">
				<a class="btn btn-secondary" href="/#areas">Conheça a área correspondente</a>
				<a class="btn btn-ghost" href="/">Voltar ao site institucional</a>
			</div>
		</section>
	</div>

	<script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
</BlogLayout>
