---
import { getCollection } from 'astro:content';
import BlogGrid from '../../components/blog/BlogGrid.astro';
import FeaturedPost from '../../components/blog/FeaturedPost.astro';
import { BLOG_SITE_URL } from '../../consts';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { buildBlogClusterDirectory } from '../../lib/blog-clusters';
import { isPublicPost, normalizePost, sortPostsByDate } from '../../lib/posts';
import { temaHref } from '../../lib/taxonomy';

const entries = await getCollection('blog');
const posts = sortPostsByDate(entries.map((entry) => normalizePost(entry))).filter(isPublicPost);
const featured = posts.find((post) => post.featured) ?? posts[0];
const continuityPosts = posts.filter((post) => post.slug !== featured?.slug).slice(0, 6);
const clusterDirectory = buildBlogClusterDirectory(posts);
const topThemes = Array.from(
	new Map(
		posts
			.flatMap((post) => post.temas)
			.map((tema) => [tema.toLowerCase(), tema]),
	).values(),
).slice(0, 10);
const editorialGuide = [
	{
		title: 'Identifique a frente juridica',
		text: 'O blog organiza a leitura por clusters para que voce reconheca mais rapidamente o universo juridico da sua situacao.',
	},
	{
		title: 'Aprofunde sem se perder',
		text: 'Cada trilha editorial conecta artigo, area, temas frequentes e continuidade de leitura dentro do mesmo contexto.',
	},
	{
		title: 'Busque orientacao quando fizer sentido',
		text: 'A conversao aparece com contexto: primeiro leitura, depois area correspondente e so entao contato institucional.',
	},
];
const searchIndex = posts.map((post) => ({
	title: post.title,
	excerpt: post.excerpt,
	url: post.url,
	area: post.area,
	tokens: `${post.title} ${post.excerpt} ${post.area} ${post.temas.join(' ')}`.toLowerCase(),
}));
const collectionSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'Blog Juridico PAVIE',
	url: `${BLOG_SITE_URL}/blog/`,
	description: 'Camada editorial da PAVIE para aprofundar temas juridicos, reconhecer a area correspondente e decidir com mais clareza.',
	mainEntity:
		posts.length > 0
			? {
					'@type': 'ItemList',
					itemListElement: posts.slice(0, 12).map((post, index) => ({
						'@type': 'ListItem',
						position: index + 1,
						url: `${BLOG_SITE_URL}${post.url}`,
						name: post.title,
					})),
				}
			: undefined,
};
---

<BlogLayout
	title="Blog juridico da PAVIE"
	description="Leitura juridica para reconhecer o tema, aprofundar a frente correspondente e buscar orientacao com contexto."
	canonical={`${BLOG_SITE_URL}/blog/`}
>
	<div class="container blog-home">
		<section class="blog-hero" aria-labelledby="blog-hero-title">
			<div class="blog-hero__content">
				<span class="badge">Blog Juridico PAVIE</span>
				<h1 id="blog-hero-title">Leitura para entender o tema, reconhecer a area e so depois decidir o proximo passo.</h1>
				<p>
					O blog da PAVIE funciona como camada editorial do ecossistema institucional: ele organiza a leitura
					por frentes juridicas, aprofunda situacoes reais e indica quando faz sentido sair do conteudo para buscar orientacao.
				</p>
				<div class="meta-list" aria-label="Informacoes do acervo">
					<span><span class="meta-dot" aria-hidden="true"></span>{posts.length} artigos no acervo publico</span>
					<span><span class="meta-dot" aria-hidden="true"></span>5 clusters editoriais canonicos</span>
					<span><span class="meta-dot" aria-hidden="true"></span>Mesma estrutura de confianca do site institucional</span>
				</div>
				<div class="blog-hero__actions">
					<a class="btn btn-primary" href="/blog/areas/">Explorar temas</a>
					<a class="btn btn-ghost" href="/blog/contato/">Solicitar orientação inicial</a>
				</div>
				<div class="blog-hero__chips">
					{clusterDirectory.map((cluster) => (
						<a class="blog-chip" href={cluster.href}>{cluster.title}</a>
					))}
				</div>
			</div>
		</section>

		<section class="blog-grid" aria-label="Como usar o blog">
			<div class="section-title">
				<div>
					<span class="section-kicker">Como este blog ajuda</span>
					<h2>Uma navegacao editorial pensada para continuidade, e nao para cronologia bruta</h2>
				</div>
			</div>
			<div class="editorial-guide-grid">
				{editorialGuide.map((item) => (
					<article class="surface-card editorial-guide-card">
						<h3>{item.title}</h3>
						<p>{item.text}</p>
					</article>
				))}
			</div>
		</section>

		{posts.length === 0 ? (
			<section class="surface-card empty-state" aria-label="Acervo em organizacao">
				<h2>O acervo editorial esta em organizacao</h2>
				<p>
					As trilhas por area ja estao estruturadas. Enquanto novas publicacoes entram no ar, voce pode usar o mapa editorial
					para reconhecer a frente correspondente ao seu tema e entender quando faz sentido buscar orientacao inicial.
				</p>
				<div class="blog-actions">
					<a class="btn btn-primary" href="/blog/areas/">Explorar temas</a>
					<a class="btn btn-ghost" href="/blog/contato/">Solicitar orientação inicial</a>
				</div>
			</section>
		) : (
			<>
				<section class="surface-card blog-search" aria-label="Busca interna do blog">
					<div>
						<span class="section-kicker">Busca rapida</span>
						<h2>Encontre conteudo por tema, situacao ou frente juridica</h2>
					</div>
					<label class="sr-only" for="blog-search-input">Buscar no blog</label>
					<input
						id="blog-search-input"
						type="search"
						placeholder="Ex.: inventario, guarda compartilhada, regularizacao de imovel"
						data-blog-search-input
					/>
					<ul class="blog-search__list" data-blog-search-list>
						{posts.slice(0, 8).map((post) => (
							<li>
								<a href={post.url}>
									<strong>{post.title}</strong>
									<span>{post.area}</span>
								</a>
							</li>
						))}
					</ul>
					<p class="text-muted" data-blog-search-empty hidden>Nenhum resultado para esse termo.</p>
				</section>

				{featured && <FeaturedPost post={featured} />}
			</>
		)}

		<section class="blog-grid" aria-label="Mapa editorial por area">
			<div class="section-title">
				<div>
					<span class="section-kicker">Mapa editorial por area</span>
					<h2>Os 5 clusters canonicos ligam tema, leitura e proximo passo</h2>
				</div>
				<a class="btn btn-ghost" href="/areas/">Conheça os Serviços</a>
			</div>
			<div class="cluster-directory-grid">
				{clusterDirectory.map((cluster) => (
					<article class="surface-card cluster-directory-card">
						<span class="section-kicker">Area editorial</span>
						<h3>{cluster.title}</h3>
						<p>{cluster.description}</p>
						<ul class="cluster-directory-list">
							{cluster.typicalSituations.map((item) => (
								<li>{item}</li>
							))}
						</ul>
						<div class="theme-chip-list">
							{cluster.topThemes.map((tema) => (
								<a class="blog-chip blog-chip--theme" href={cluster.hasThemeRoutes ? temaHref(tema) : cluster.href}>{tema}</a>
							))}
						</div>
						{cluster.hasPosts ? (
							<div class="cluster-directory-posts">
								<p class="cluster-directory-meta">{cluster.postCount} publicacoes nesta trilha.</p>
								<ul>
									{cluster.latestPosts.map((post) => (
										<li><a href={post.url}>{post.title}</a></li>
									))}
								</ul>
							</div>
						) : (
							<p class="cluster-directory-empty">
								A trilha editorial desta frente esta em consolidacao. A area ja pode ser explorada e o contato institucional
								permanece disponivel quando o tema sair do plano abstrato.
							</p>
						)}
						<div class="cluster-directory-actions">
							<a class="btn btn-primary" href={cluster.href}>Explorar temas</a>
							<a class="btn btn-ghost" href={cluster.contactHref}>Solicitar orientação inicial</a>
						</div>
					</article>
				))}
			</div>
		</section>

		{continuityPosts.length > 0 && (
			<BlogGrid title="Continue a leitura" kicker="Aprofundamento" posts={continuityPosts} />
		)}

		{topThemes.length > 0 && (
			<section class="blog-grid" aria-label="Temas em foco">
				<div class="section-title">
					<div>
						<span class="section-kicker">Temas em foco</span>
						<h2>Continue por tema quando quiser aprofundar um recorte especifico</h2>
					</div>
					<a class="btn btn-ghost" href="/blog/temas/">Explorar temas</a>
				</div>
				<div class="theme-chip-list">
					{topThemes.map((tema) => (
						<a class="blog-chip blog-chip--theme" href={temaHref(tema)}>{tema}</a>
					))}
				</div>
			</section>
		)}

		<section class="editorial-cta" aria-label="Ponte editorial para contato">
			<span class="section-kicker">Quando a leitura vira decisao</span>
			<h2>Se o tema deixar de ser apenas duvida e passar a exigir leitura aplicada, a ponte de contato do blog organiza esse passo.</h2>
			<p>
				A PAVIE nao promete resposta automatica nem patrocinio imediato. O primeiro movimento e contextualizar o caso,
				entender o que precisa ser informado e explicar como a triagem funciona.
			</p>
			<div class="blog-actions">
				<a class="btn btn-primary" href="/blog/contato/">Solicitar orientação inicial</a>
				<a class="btn btn-ghost" href="/areas/">Conheça os Serviços</a>
			</div>
		</section>

		<section class="surface-card blog-author-spotlight" aria-label="Autor do blog">
			<img
				src="/uploads/foto_001-ffundddo-escrit%C3%B3rio.png"
				alt="Foto profissional do advogado Fabio Mathias Pavie"
				loading="lazy"
			/>
			<div>
				<span class="section-kicker">Autor do blog</span>
				<h2>Fabio Mathias Pavie</h2>
				<p>Advogado | OAB/RJ 134.947</p>
				<p>
					A camada editorial e conduzida para aprofundar temas que aparecem na pratica institucional da PAVIE,
					sem transformar conteudo em promessa de resultado.
				</p>
				<div class="blog-actions">
					<a class="btn btn-primary" href="/areas/">Conheça os Serviços</a>
					<a class="btn btn-ghost" href="/blog/contato/">Solicitar orientação inicial</a>
				</div>
			</div>
		</section>
	</div>

	<script define:vars={{ searchIndex }}>
		const input = document.querySelector('[data-blog-search-input]');
		const list = document.querySelector('[data-blog-search-list]');
		const empty = document.querySelector('[data-blog-search-empty]');
		const safeIndex = Array.isArray(searchIndex) ? searchIndex : [];

		if (input && list && empty) {
			const render = (items) => {
				list.innerHTML = '';
				for (const item of items) {
					const li = document.createElement('li');
					const link = document.createElement('a');
					link.href = item.url;
					const strong = document.createElement('strong');
					strong.textContent = item.title;
					const area = document.createElement('span');
					area.textContent = item.area;
					link.appendChild(strong);
					link.appendChild(area);
					li.appendChild(link);
					list.appendChild(li);
				}
			};

			render(safeIndex.slice(0, 8));
			input.addEventListener('input', () => {
				const term = input.value.trim().toLowerCase();
				if (!term) {
					render(safeIndex.slice(0, 8));
					empty.hidden = true;
					return;
				}
				const filtered = safeIndex.filter((item) => item.tokens.includes(term)).slice(0, 8);
				render(filtered);
				empty.hidden = filtered.length > 0;
			});
		}
	</script>
	<script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
</BlogLayout>
