---
import { getCollection } from 'astro:content';
import BlogGrid from '../../components/blog/BlogGrid.astro';
import BlogHero from '../../components/blog/BlogHero.astro';
import FeaturedPost from '../../components/blog/FeaturedPost.astro';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { groupPostsByArea, isPublicPost, normalizePost, sortPostsByDate } from '../../lib/posts';
import { areaHref, temaHref } from '../../lib/taxonomy';

const entries = await getCollection('blog');
const posts = sortPostsByDate(entries.map((entry) => normalizePost(entry))).filter(isPublicPost);
const featured = posts[0];
const highlights = posts.slice(1, 7);
const groupedByArea = groupPostsByArea(posts).slice(0, 3);

const guidePosts = posts
	.filter(
		(post) =>
			post.contentType.toLowerCase().includes('guia') ||
			post.intent === 'aprofundar' ||
			post.intent === 'informar',
	)
	.slice(0, 4);

const successionPosts = posts
	.filter(
		(post) =>
			post.area.toLowerCase().includes('sucess') ||
			post.temas.some((tema) => tema.toLowerCase().includes('inventario') || tema.toLowerCase().includes('heranca')),
	)
	.slice(0, 4);

const areaNames = groupedByArea.map((group) => group.area);
const topThemes = Array.from(
	new Map(
		posts
			.flatMap((post) => post.temas)
			.map((tema) => [tema.toLowerCase(), tema]),
	).values(),
).slice(0, 8);
---

<BlogLayout
	title="Publicacoes juridicas da PAVIE"
	description="Hub editorial institucional da PAVIE Advocacia para descoberta, aprofundamento e conversao etica."
	canonical="https://blog.pavieadvocacia.com.br/"
>
	<div class="container blog-home">
		<BlogHero totalPosts={posts.length} areas={areaNames} />

		{featured && <FeaturedPost post={featured} />}

		{highlights.length > 0 && (
			<BlogGrid title="Leituras em destaque" kicker="Curadoria principal" posts={highlights} />
		)}

		<section id="areas-editoriais" class="blog-grid" aria-label="Areas editoriais">
			<div class="section-title">
				<div>
					<span class="section-kicker">Clusters editoriais</span>
					<h2>Areas de atuacao e trilhas por tema</h2>
				</div>
			</div>
			<div class="blog-row">
				{groupedByArea.map((group) => (
					<article class="blog-row__item">
						<h3>{group.area}</h3>
						<p>
							{group.posts.length} publicacoes disponiveis para consulta tecnica e aprofundamento.
						</p>
						<a href={areaHref(group.area)}>Abrir trilha editorial</a>
					</article>
				))}
			</div>
		</section>

		{topThemes.length > 0 && (
			<section class="blog-grid" aria-label="Temas em foco">
				<div class="section-title">
					<div>
						<span class="section-kicker">Descoberta por tema</span>
						<h2>Temas em foco</h2>
					</div>
				</div>
				<div class="theme-chip-list">
					{topThemes.map((tema) => (
						<a class="blog-chip blog-chip--theme" href={temaHref(tema)}>
							{tema}
						</a>
					))}
				</div>
			</section>
		)}

		{guidePosts.length > 0 && (
			<BlogGrid title="Guias essenciais" kicker="Base de consulta" posts={guidePosts} compact />
		)}

		{successionPosts.length > 0 && (
			<BlogGrid title="Planejamento sucessorio" kicker="Cluster prioritario" posts={successionPosts} compact />
		)}

		<section class="editorial-cta" aria-label="Chamada institucional">
			<span class="section-kicker">Conversao etica</span>
			<h2>Precisa transformar leitura em estrategia aplicavel?</h2>
			<p>
				Agende uma consultoria para receber orientacao alinhada ao seu contexto,
				com clareza de riscos, prazos e proxima acao juridica.
			</p>
			<div>
				<a class="btn btn-primary" href="https://pavieadvocacia.com.br/#agendar">
					Agendar Consultoria
				</a>
			</div>
		</section>
	</div>
</BlogLayout>
