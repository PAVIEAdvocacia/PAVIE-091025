---
import BlogGrid from '../../components/blog/BlogGrid.astro';
import CategoryGrid from '../../components/blog/CategoryGrid.astro';
import { BLOG_SITE_URL, MAIN_SITE_URL } from '../../consts';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getAreaEntries, getAuthorEntries, getBlogEntries } from '../../lib/blog-content';
import { buildCanonicalAreaDirectory } from '../../lib/canonical-directory';
import { isPublicPost, normalizePosts, sortPostsByDate } from '../../lib/posts';

const [areaEntries, authorEntries, blogEntries] = await Promise.all([
	getAreaEntries(),
	getAuthorEntries(),
	getBlogEntries(),
]);
const posts = sortPostsByDate(normalizePosts(blogEntries, authorEntries)).filter(isPublicPost);
const featuredPosts = posts.filter((post) => post.featured).slice(0, 3);
const editorialHighlights = featuredPosts.length > 0 ? featuredPosts : posts.slice(0, 3);
const latestPosts = posts.slice(0, 6);
const mostReadPosts = [...editorialHighlights, ...posts]
	.filter((post, index, list) => list.findIndex((item) => item.slug === post.slug) === index)
	.slice(0, 5);
const categoryDirectory = buildCanonicalAreaDirectory(areaEntries, posts);
const hasPublishedPosts = posts.length > 0;
const postCountLabel = hasPublishedPosts
	? `${posts.length} artigo${posts.length === 1 ? '' : 's'} publicado${posts.length === 1 ? '' : 's'} no acervo atual`
	: 'Acervo editorial em preparação';
const heroImage = mostReadPosts[0]?.image ?? '/images/site/hero/hero-01.webp';
const heroImageAlt = mostReadPosts[0]?.imageAlt ?? 'Imagem editorial em preto e branco para abertura do blog PAVIE';
const collectionSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'Blog Jurídico PAVIE',
	url: `${BLOG_SITE_URL}/blog/`,
	description:
		'Leituras jurídicas da PAVIE organizadas por categorias do blog e conectadas às áreas públicas correspondentes.',
	mainEntity:
		posts.length > 0
			? {
					'@type': 'ItemList',
					itemListElement: posts.slice(0, 12).map((post, index) => ({
						'@type': 'ListItem',
						position: index + 1,
						url: `${BLOG_SITE_URL}${post.url}`,
						name: post.title,
					})),
				}
			: undefined,
};
---

<BlogLayout
	title="Blog jurídico da PAVIE | Advocacia"
	description="Leitura jurídica organizada por categorias canônicas, com conexão direta entre conteúdo editorial, áreas públicas e retorno ao site institucional."
	canonical={`${BLOG_SITE_URL}/blog/`}
>
	<div class="container blog-home">
		<section class="blog-editorial-header" aria-labelledby="blog-home-title">
			<span class="badge">Blog jurídico PAVIE | Advocacia</span>
			<h1 id="blog-home-title">Leituras para reconhecer o tema, organizar documentos e voltar ao site com mais clareza.</h1>
			<p>
				O blog qualifica a compreensão do problema por categorias canônicas. Cada leitura aprofunda critérios,
				limites e caminhos de retorno à área institucional correspondente.
			</p>
			<div class="blog-hero__actions">
				<a class="btn btn-primary" href="/blog/categoria/">Explorar categorias</a>
				<a class="btn btn-ghost" href={MAIN_SITE_URL}>Voltar ao site institucional</a>
			</div>
			<div class="meta-list" aria-label="Informações do acervo editorial">
				<span><span class="meta-dot" aria-hidden="true"></span>{postCountLabel}</span>
				<span><span class="meta-dot" aria-hidden="true"></span>{categoryDirectory.length} categorias canônicas</span>
				<span><span class="meta-dot" aria-hidden="true"></span>Ponte direta para as áreas do site</span>
			</div>
		</section>

		<section class="blog-editorial-hero" aria-labelledby="most-read-title">
			<figure class="blog-editorial-hero__visual">
				<img src={heroImage} alt={heroImageAlt} loading="eager" decoding="async" />
				<figcaption>Leitura editorial com foco em prova, contexto e via adequada.</figcaption>
			</figure>

			<aside class="most-read-panel" aria-labelledby="most-read-title">
				<span class="section-kicker">Mais lidos</span>
				<h2 id="most-read-title">Pontos de entrada para começar a leitura</h2>
				{mostReadPosts.length > 0 ? (
					<ol class="most-read-list">
						{mostReadPosts.map((post, index) => (
							<li>
								<a href={post.url}>
									<span>{String(index + 1).padStart(2, '0')}</span>
									<strong>{post.title}</strong>
									<small>{post.readingTime} min · {post.area}</small>
								</a>
							</li>
						))}
					</ol>
				) : (
					<div class="empty-state">
						<h3>Acervo em preparação</h3>
						<p>As categorias já estão estruturadas; os textos entram conforme revisão editorial e jurídica.</p>
					</div>
				)}
			</aside>
		</section>

		<CategoryGrid categories={categoryDirectory} />

		<BlogGrid
			title="Artigos em destaque"
			kicker="Seleção editorial"
			posts={editorialHighlights}
			emptyTitle="Destaques em preparação"
			emptyText="Os destaques entram conforme o acervo aprovado cresce dentro das categorias canônicas."
		/>

		<BlogGrid
			title="Últimas publicações"
			kicker="Acervo recente"
			posts={latestPosts}
			emptyTitle="Publicações em preparação"
			emptyText="Novos artigos serão exibidos aqui após revisão editorial e jurídica."
		/>

		<section class="editorial-cta" aria-label="Retorno ao site institucional">
			<span class="section-kicker">Retorno ao site institucional</span>
			<h2>Quando a leitura já ajudou a organizar o tema, volte ao site para conhecer a área correspondente.</h2>
			<p>
				O blog prepara a compreensão. O site institucional concentra áreas, método, limites do primeiro contato e
				informações necessárias para uma eventual análise do caso concreto.
			</p>
			<div class="blog-actions">
				<a class="btn btn-secondary" href={`${MAIN_SITE_URL}/#areas`}>Conheça a área correspondente</a>
				<a class="btn btn-ghost" href={MAIN_SITE_URL}>Voltar ao site institucional</a>
			</div>
		</section>
	</div>

	<script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
</BlogLayout>
