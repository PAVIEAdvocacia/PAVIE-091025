---
import BlogGrid from '../../components/blog/BlogGrid.astro';
import { BLOG_SITE_URL, MAIN_SITE_URL } from '../../consts';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getAreaEntries, getAuthorEntries, getBlogEntries } from '../../lib/blog-content';
import { buildB1Selection } from '../../lib/blog-home-selection';
import { buildCanonicalAreaDirectory } from '../../lib/canonical-directory';
import { normalizeCmsImagePath } from '../../lib/content-media';
import {
	EDITORIAL_ANALYTICS_EVENTS,
	categoryAnalyticsContext,
	editorialAnalyticsAttributes,
	postAnalyticsContext,
} from '../../lib/editorial-analytics';
import { isPublicPost, normalizePosts, sortPostsByDate } from '../../lib/posts';

const [areaEntries, authorEntries, blogEntries] = await Promise.all([
	getAreaEntries(),
	getAuthorEntries(),
	getBlogEntries(),
]);
const posts = sortPostsByDate(normalizePosts(blogEntries, authorEntries)).filter(isPublicPost);
const categoryDirectory = buildCanonicalAreaDirectory(areaEntries, posts);
const b1Selection = buildB1Selection(posts);
const { primaryHighlights, usefulReads, recentReads, schemaPosts } = b1Selection;
const heroImage = primaryHighlights[0]?.image ?? '/images/site/hero/hero-01.webp';
const heroImageAlt = primaryHighlights[0]?.imageAlt ?? 'Imagem editorial em preto e branco para abertura do blog PAVIE';
const blogAuthor =
	authorEntries.find((entry) => entry.data.slug === 'fabio-pavie' || entry.data.id === 'fabio-pavie') ??
	authorEntries[0];
const authorImage =
	normalizeCmsImagePath(blogAuthor?.data.image) ?? '/uploads/fabio-pavie-profile.png';
const collectionSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'Blog Jurídico PAVIE',
	url: `${BLOG_SITE_URL}/blog/`,
	description:
		'Leituras jurídicas da PAVIE organizadas por categorias do blog e conectadas às áreas públicas correspondentes.',
	mainEntity:
		schemaPosts.length > 0
			? {
					'@type': 'ItemList',
					itemListElement: schemaPosts.slice(0, 12).map((post, index) => ({
						'@type': 'ListItem',
						position: index + 1,
						url: `${BLOG_SITE_URL}${post.url}`,
						name: post.title,
					})),
				}
			: undefined,
};
---

<BlogLayout
	title="Blog jurídico da PAVIE | Advocacia"
	description="Leitura jurídica organizada por categorias canônicas, com conexão direta entre conteúdo editorial e áreas públicas correspondentes."
	canonical={`${BLOG_SITE_URL}/blog/`}
>
	<div class="container blog-home">
		<section class="blog-editorial-hero" aria-label="Destaques principais">
			<figure class="blog-editorial-hero__visual">
				<img src={heroImage} alt={heroImageAlt} loading="eager" decoding="async" />
				<figcaption>Leitura editorial com foco em prova, contexto e via adequada.</figcaption>
			</figure>

			<aside class="most-read-panel" aria-label="Destaques principais da seleção editorial">
				<span class="section-kicker">Bloco A | Destaques principais</span>
				{primaryHighlights.length > 0 ? (
					<ol class="most-read-list">
						{primaryHighlights.map((post, index) => (
							<li>
								<div class="most-read-list__item">
									<span>{String(index + 1).padStart(2, '0')}</span>
									<strong>
										<a
											href={post.url}
											data-link-origin="blog-home-primary"
											data-link-target="article"
											{...editorialAnalyticsAttributes({
												eventName: EDITORIAL_ANALYTICS_EVENTS.B1_ARTICLE_CLICK,
												surfaceOrigin: 'B1',
												surfaceTarget: 'B3',
												linkType: 'article-link',
												...postAnalyticsContext(post),
											})}
										>
											{post.title}
										</a>
									</strong>
									<small>
										{post.readingTime} min |{' '}
										{post.categoryUrl ? (
											<a
												href={post.categoryUrl}
												data-link-origin="blog-home-primary"
												data-link-target="category"
												{...editorialAnalyticsAttributes({
													eventName: EDITORIAL_ANALYTICS_EVENTS.B1_CATEGORY_CLICK,
													surfaceOrigin: 'B1',
													surfaceTarget: 'B2',
													linkType: 'category-link',
													...postAnalyticsContext(post),
												})}
											>
												{post.area}
											</a>
										) : (
											post.area
										)}
									</small>
								</div>
							</li>
						))}
					</ol>
				) : (
					<div class="empty-state">
						<h3>Acervo em preparação</h3>
						<p>As categorias já estão estruturadas; os textos entram conforme revisão editorial e jurídica.</p>
					</div>
				)}
			</aside>
		</section>

		<section class="blog-taxonomy-strip" aria-labelledby="blog-taxonomy-title">
			<div class="blog-taxonomy-strip__intro">
				<span class="section-kicker">Mapa editorial</span>
				<h2 id="blog-taxonomy-title">Categorias do blog</h2>
			</div>
			<ol class="blog-taxonomy-strip__list">
				{categoryDirectory.map((category) => (
					<li>
						{category.postCount > 0 ? (
							<a
								href={category.categoryHref}
								data-link-origin="blog-home-taxonomy"
								data-link-target="category"
								{...editorialAnalyticsAttributes({
									eventName: EDITORIAL_ANALYTICS_EVENTS.B1_CATEGORY_CLICK,
									surfaceOrigin: 'B1',
									surfaceTarget: 'B2',
									linkType: 'category-link',
									...categoryAnalyticsContext(category),
								})}
							>
								<span>{category.code}</span>
								<strong>{category.displayTitle}</strong>
								<small>{category.postCount} artigo{category.postCount === 1 ? '' : 's'}</small>
							</a>
						) : (
							<div class="blog-taxonomy-strip__item" data-category-state="preparation">
								<span>{category.code}</span>
								<strong>{category.displayTitle}</strong>
								<small>Em preparacao</small>
							</div>
						)}
					</li>
				))}
			</ol>
		</section>

		<BlogGrid
			title="Leituras úteis para organizar o tema"
			kicker="Bloco B | Utilidade editorial"
			posts={usefulReads}
			analyticsSurfaceOrigin="B1"
			articleEventName={EDITORIAL_ANALYTICS_EVENTS.B1_ARTICLE_CLICK}
			categoryEventName={EDITORIAL_ANALYTICS_EVENTS.B1_CATEGORY_CLICK}
			emptyTitle="Leituras úteis em preparação"
			emptyText="Este bloco será preenchido por guias, checklists e respostas com maior utilidade de leitura conforme o acervo aprovado crescer."
		/>

		<BlogGrid
			title="Publicações recentes selecionadas"
			kicker="Bloco C | Recência subordinada"
			posts={recentReads}
			analyticsSurfaceOrigin="B1"
			articleEventName={EDITORIAL_ANALYTICS_EVENTS.B1_ARTICLE_CLICK}
			categoryEventName={EDITORIAL_ANALYTICS_EVENTS.B1_CATEGORY_CLICK}
			emptyTitle="Publicações em preparação"
			emptyText="A recência aparece como bloco subordinado, sem governar a seleção principal da home."
		/>

		{blogAuthor && (
			<section class="surface-card blog-author-spotlight" aria-label="Autoria editorial do blog">
				<img
					src={authorImage}
					alt={blogAuthor.data.imageAlt}
					loading="lazy"
				/>
				<div>
					<span class="section-kicker">Autoria editorial</span>
					<h2>{blogAuthor.data.name}</h2>
					<p>{blogAuthor.data.shortBio}</p>
					<div class="blog-actions">
						<a
							class="btn btn-primary"
							href={`/blog/autor/${blogAuthor.data.slug}/`}
							data-link-origin="blog-home-author"
							data-link-target="author"
						>
							Ver perfil do autor
						</a>
						<a
							class="btn btn-ghost"
							href={MAIN_SITE_URL}
							data-link-origin="blog-home-author"
							data-link-target="site"
						>
							Ir ao site institucional
						</a>
					</div>
				</div>
			</section>
		)}

		<section class="author-institutional-link" aria-labelledby="blog-site-return-title">
			<span class="section-kicker">Retorno ao site</span>
			<div>
				<h2 id="blog-site-return-title">O blog amadurece a leitura; o site concentra as áreas e o contato institucional.</h2>
				<p>
					Use os artigos para organizar o problema e volte ao site quando precisar entender áreas,
					método e caminhos institucionais da PAVIE.
				</p>
			</div>
			<a
				class="btn btn-ghost"
				href={MAIN_SITE_URL}
				data-link-origin="blog-home-return"
				data-link-target="site"
			>
				Ir ao site
			</a>
		</section>
	</div>

	<script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
</BlogLayout>
