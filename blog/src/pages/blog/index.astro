---
import { getCollection } from 'astro:content';
import BlogGrid from '../../components/blog/BlogGrid.astro';
import BlogHero from '../../components/blog/BlogHero.astro';
import FeaturedPost from '../../components/blog/FeaturedPost.astro';
import { BLOG_SITE_URL } from '../../consts';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { buildHubDirectory } from '../../lib/service-hubs';
import { groupPostsByArea, isPublicPost, normalizePost, sortPostsByDate } from '../../lib/posts';
import { areaHref, temaHref } from '../../lib/taxonomy';

const entries = await getCollection('blog');
const posts = sortPostsByDate(entries.map((entry) => normalizePost(entry))).filter(isPublicPost);
const featured = posts[0];
const latestPosts = posts.slice(1, 7);
const groupedByArea = groupPostsByArea(posts).slice(0, 4);
const hubDirectory = buildHubDirectory(posts);
const activeHubs = hubDirectory.filter((hub) => hub.postCount > 0);

const practicalPosts = posts
	.filter((post) => post.intent === 'diagnosticar' || post.intent === 'comparar' || post.funnelStage === 'fundo')
	.slice(0, 4);

const guidePosts = posts
	.filter((post) => post.contentType.includes('guia') || post.contentType.includes('checklist'))
	.slice(0, 4);

const areaNames = groupedByArea.map((group) => group.area);
const areaClusters = groupedByArea.slice(0, 3).map((group) => ({
	area: group.area,
	areaUrl: areaHref(group.posts[0]?.areaKey || group.area),
	posts: group.posts.slice(0, 3),
}));
const shelfLead = practicalPosts[0] ?? featured;
const shelfSide = posts.filter((post) => post.slug !== shelfLead?.slug).slice(0, 3);
const topThemes = Array.from(
	new Map(
		posts
			.flatMap((post) => post.temas)
			.map((tema) => [tema.toLowerCase(), tema]),
	).values(),
).slice(0, 10);
const searchIndex = posts.map((post) => ({
	title: post.title,
	excerpt: post.excerpt,
	url: post.url,
	area: post.area,
	tokens: `${post.title} ${post.excerpt} ${post.area} ${post.temas.join(' ')}`.toLowerCase(),
}));
const collectionSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'Blog Jurídico PAVIE',
	url: `${BLOG_SITE_URL}/blog/`,
	description: 'Acervo de guias e analises juridicas para decisoes seguras.',
	mainEntity: {
		'@type': 'ItemList',
		itemListElement: posts.slice(0, 12).map((post, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			url: `${BLOG_SITE_URL}${post.url}`,
			name: post.title,
		})),
	},
};
---

<BlogLayout
	title="Blog jurídico da PAVIE"
	description="Leitura jurídica para entender cenários reais, organizar decisões e agir com segurança."
	canonical={`${BLOG_SITE_URL}/blog/`}
>
	<div class="container blog-home">
		<BlogHero totalPosts={posts.length} areas={areaNames} />

		{posts.length === 0 && (
			<section class="surface-card empty-state" aria-label="Sem publicacoes">
				<h2>Nenhuma publicação ativa no momento</h2>
				<p>
					Estamos organizando novos conteúdos para publicação. Em breve, esta área terá guias e análises
					práticas para apoiar sua tomada de decisão.
				</p>
				<a class="btn btn-primary" href="/contato/">Solicitar orientação inicial</a>
			</section>
		)}

		{featured && <FeaturedPost post={featured} />}

		{posts.length > 0 && (
			<section class="surface-card blog-search" aria-label="Busca interna do blog">
				<div>
					<span class="section-kicker">Busca rápida</span>
					<h2>Encontre conteúdo por tema, situação ou área jurídica</h2>
				</div>
				<label class="sr-only" for="blog-search-input">Buscar no blog</label>
				<input
					id="blog-search-input"
					type="search"
					placeholder="Ex.: inventário, guarda compartilhada, regularização de imóvel"
					data-blog-search-input
				/>
				<ul class="blog-search__list" data-blog-search-list>
					{posts.slice(0, 8).map((post) => (
						<li>
							<a href={post.url}>
								<strong>{post.title}</strong>
								<span>{post.area}</span>
							</a>
						</li>
					))}
				</ul>
				<p class="text-muted" data-blog-search-empty hidden>Nenhum resultado para esse termo.</p>
			</section>
		)}

		{shelfLead && shelfSide.length > 0 && (
			<section class="editorial-lane" aria-label="Leituras em foco">
				<article class="surface-card editorial-lane__lead">
					<span class="section-kicker">Guia em foco</span>
					<h2>{shelfLead.title}</h2>
					<p>{shelfLead.excerpt}</p>
					<div class="meta-list">
						<span><span class="meta-dot" aria-hidden="true"></span>{shelfLead.area}</span>
						<span><span class="meta-dot" aria-hidden="true"></span>{shelfLead.readingTime} min</span>
					</div>
					<a class="btn btn-primary" href={shelfLead.url}>Ler guia em foco</a>
				</article>
				<div class="surface-card editorial-lane__side">
					<span class="section-kicker">Leituras complementares</span>
					<ul>
						{shelfSide.map((post) => (
							<li>
								<a href={post.url}>
									<strong>{post.title}</strong>
									<span>{post.area}</span>
								</a>
							</li>
						))}
					</ul>
				</div>
			</section>
		)}

		<section id="hubs-conteudo" class="blog-grid" aria-label="Hubs de conteudo">
			<div class="section-title">
				<div>
					<span class="section-kicker">Mapa por áreas e temas</span>
					<h2>Hubs jurídicos para organizar leitura e decisão</h2>
				</div>
				<a class="btn btn-ghost" href="/blog/areas/">Ver mapa de áreas</a>
			</div>
			<div class="hub-grid">
				{activeHubs.map((hub) => (
					<article class="surface-card hub-card">
						<h3>{hub.title}</h3>
						<p>{hub.summary}</p>
						<div class="hub-tag-list">
							{hub.themes.map((theme) => (
								<a class:list={['hub-tag', { 'is-muted': !theme.available }]} href={theme.href}>
									{theme.label}
								</a>
							))}
						</div>
						<div class="hub-card__meta">
							<span>{hub.postCount} publicações</span>
							<a href={hub.areaUrl}>Abrir hub</a>
						</div>
					</article>
				))}
			</div>
		</section>

		{areaClusters.length > 0 && (
			<section class="blog-grid" aria-label="Clusters por area">
				<div class="section-title">
					<div>
						<span class="section-kicker">Clusters por área</span>
						<h2>Trilhas por problema jurídico</h2>
					</div>
				</div>
				<div class="cluster-grid">
					{areaClusters.map((cluster) => (
						<article class="surface-card cluster-card">
							<h3>{cluster.area}</h3>
							<ul>
								{cluster.posts.map((post) => (
									<li>
										<a href={post.url}>{post.title}</a>
									</li>
								))}
							</ul>
							<a href={cluster.areaUrl}>Ver todos da área</a>
						</article>
					))}
				</div>
			</section>
		)}

		{latestPosts.length > 0 && (
			<BlogGrid title="Leituras recentes" kicker="Atualizações do acervo" posts={latestPosts} />
		)}

		{practicalPosts.length > 0 && (
			<BlogGrid title="Casos práticos e decisão" kicker="Quando o tema pede ação" posts={practicalPosts} compact />
		)}

		{guidePosts.length > 0 && (
			<BlogGrid title="Guias e fundamentos" kicker="Base para consulta" posts={guidePosts} compact />
		)}

		{topThemes.length > 0 && (
			<section class="blog-grid" aria-label="Temas em foco">
				<div class="section-title">
					<div>
						<span class="section-kicker">Navegação por tema</span>
						<h2>Temas em foco</h2>
					</div>
					<a class="btn btn-ghost" href="/blog/temas/">Explorar todos os temas</a>
				</div>
				<div class="theme-chip-list">
					{topThemes.map((tema) => (
						<a class="blog-chip blog-chip--theme" href={temaHref(tema)}>
							{tema}
						</a>
					))}
				</div>
			</section>
		)}

		<section class="editorial-cta" aria-label="Chamada institucional">
			<span class="section-kicker">Leitura com utilidade prática</span>
			<h2>Entender o tema é o primeiro passo. Decidir com segurança é o próximo.</h2>
			<p>
				Se o seu cenário exige orientação aplicada, a equipe da PAVIE pode analisar contexto,
				prioridades e riscos com uma proposta clara de condução.
			</p>
			<div>
				<a class="btn btn-primary" href="/contato/">Solicitar orientação</a>
			</div>
		</section>

		<section class="surface-card blog-author-spotlight" aria-label="Autor do blog">
			<img
				src="/uploads/foto_001-ffundddo-escritório.png"
				alt="Foto profissional do advogado Fabio Mathias Pavie"
				loading="lazy"
			/>
			<div>
				<span class="section-kicker">Autor do blog</span>
				<h2>Fábio Mathias Pavie</h2>
				<p>Advogado · OAB/RJ 134.947</p>
				<p>
					Atuação em direito de família, sucessões, patrimônio e conflitos cíveis. Mais de 20 anos de
					experiência jurídica.
				</p>
				<div class="site-hero__cta">
					<a class="btn btn-primary" href="/areas/">Ver serviços</a>
					<a class="btn btn-ghost" href="/contato/">Solicitar orientação</a>
				</div>
			</div>
		</section>
	</div>

	<script define:vars={{ searchIndex }}>
		const input = document.querySelector('[data-blog-search-input]');
		const list = document.querySelector('[data-blog-search-list]');
		const empty = document.querySelector('[data-blog-search-empty]');
		const safeIndex = Array.isArray(searchIndex) ? searchIndex : [];

		if (input && list && empty) {
			const render = (items) => {
				list.innerHTML = '';
				for (const item of items) {
					const li = document.createElement('li');
					const link = document.createElement('a');
					link.href = item.url;
					const strong = document.createElement('strong');
					strong.textContent = item.title;
					const area = document.createElement('span');
					area.textContent = item.area;
					link.appendChild(strong);
					link.appendChild(area);
					li.appendChild(link);
					list.appendChild(li);
				}
			};

			render(safeIndex.slice(0, 8));
			input.addEventListener('input', () => {
				const term = input.value.trim().toLowerCase();
				if (!term) {
					render(safeIndex.slice(0, 8));
					empty.hidden = true;
					return;
				}
				const filtered = safeIndex.filter((item) => item.tokens.includes(term)).slice(0, 8);
				render(filtered);
				empty.hidden = filtered.length > 0;
			});
		}
	</script>
	<script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
</BlogLayout>
