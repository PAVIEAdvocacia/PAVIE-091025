---
import BlogGrid from '../../components/blog/BlogGrid.astro';
import FeaturedPost from '../../components/blog/FeaturedPost.astro';
import { BLOG_SITE_URL } from '../../consts';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getAreaEntries, getBlogEntries } from '../../lib/blog-content';
import { buildCanonicalAreaDirectory } from '../../lib/canonical-directory';
import { isPublicPost, normalizePost, sortPostsByDate } from '../../lib/posts';

const [areaEntries, blogEntries] = await Promise.all([getAreaEntries(), getBlogEntries()]);
const posts = sortPostsByDate(blogEntries.map((entry) => normalizePost(entry))).filter(isPublicPost);
const featured = posts.find((post) => post.featured) ?? (posts.length > 0 ? posts[0] : undefined);
const continuityPosts = posts.filter((post) => post.slug !== featured?.slug).slice(0, 6);
const categoryDirectory = buildCanonicalAreaDirectory(areaEntries, posts);
const searchIndex = posts.map((post) => ({
	title: post.title,
	excerpt: post.excerpt,
	url: post.url,
	area: post.area,
	tokens: `${post.title} ${post.excerpt} ${post.area} ${post.tags.join(' ')}`.toLowerCase(),
}));
const collectionSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'Blog Juridico PAVIE',
	url: `${BLOG_SITE_URL}/blog/`,
	description:
		'Leituras juridicas da PAVIE organizadas por categorias do blog e conectadas as areas publicas correspondentes.',
	mainEntity:
		posts.length > 0
			? {
					'@type': 'ItemList',
					itemListElement: posts.slice(0, 12).map((post, index) => ({
						'@type': 'ListItem',
						position: index + 1,
						url: `${BLOG_SITE_URL}${post.url}`,
						name: post.title,
					})),
				}
			: undefined,
};
---

<BlogLayout
	title="Blog juridico da PAVIE | Advocacia"
	description="Leitura juridica organizada por categorias do blog, com conexao direta entre conteudo, areas e orientacao inicial."
	canonical={`${BLOG_SITE_URL}/blog/`}
>
	<div class="container blog-home">
		<section class="blog-hero" aria-labelledby="blog-hero-title">
			<div class="blog-hero__content">
				<span class="badge">Blog juridico PAVIE | Advocacia</span>
				<h1 id="blog-hero-title">Comece pela categoria que melhor enquadra a sua situacao.</h1>
				<p>
					O blog organiza as leituras por categorias ligadas as areas do site. Cada texto aprofunda
					criterios, documentos e proximos passos com linguagem clara e foco no caso concreto.
				</p>
				<div class="meta-list" aria-label="Informacoes do acervo">
					<span><span class="meta-dot" aria-hidden="true"></span>{posts.length} artigos publicados no acervo atual</span>
					<span><span class="meta-dot" aria-hidden="true"></span>{categoryDirectory.length} categorias disponiveis</span>
					<span><span class="meta-dot" aria-hidden="true"></span>Ligacao direta com as paginas de area</span>
				</div>
				<div class="blog-hero__actions">
					<a class="btn btn-primary" href="/blog/categoria/">Explorar categorias</a>
					<a class="btn btn-ghost" href="/blog/contato/">Solicitar orientacao inicial</a>
				</div>
				<div class="blog-hero__chips">
					{categoryDirectory.map((category) => (
						<a class="blog-chip" href={category.categoryHref}>{category.title}</a>
					))}
				</div>
			</div>
		</section>

		<section class="blog-grid" aria-labelledby="quick-start-title">
			<div class="section-title">
				<div>
					<span class="section-kicker">Mapa editorial</span>
					<h2 id="quick-start-title">Cada categoria do blog aponta para um eixo publico estavel e facil de localizar.</h2>
				</div>
				<a class="btn btn-ghost" href="/areas/">Conheca as areas</a>
			</div>
			<div class="entry-point-grid">
				{categoryDirectory.map((category) => (
					<article class="surface-card entry-point-card">
						<span class="section-kicker">Categoria do blog</span>
						<h3>{category.title}</h3>
						<p>{category.shortDescription}</p>
						<a class="entry-point-card__link" href={category.categoryHref}>Explorar esta categoria</a>
					</article>
				))}
			</div>
		</section>

		{posts.length === 0 ? (
			<section class="surface-card empty-state" aria-label="Acervo em organizacao">
				<h2>Acervo em atualizacao</h2>
				<p>
					As categorias ja organizam a navegacao do blog. Novos textos entram conforme avancam a
					revisao editorial e juridica do acervo publico.
				</p>
				<div class="blog-actions">
					<a class="btn btn-primary" href="/blog/categoria/">Explorar categorias</a>
					<a class="btn btn-ghost" href="/areas/">Conheca as areas</a>
				</div>
			</section>
		) : (
			<>
				<section class="surface-card blog-search" aria-label="Busca interna do blog">
					<div>
						<span class="section-kicker">Busca rapida</span>
						<h2>Encontre conteudo por categoria, situacao ou titulo</h2>
					</div>
					<label class="sr-only" for="blog-search-input">Buscar no blog</label>
					<input
						id="blog-search-input"
						type="search"
						placeholder="Ex.: inventario, partilha, matricula do imovel"
						data-blog-search-input
					/>
					<ul class="blog-search__list" data-blog-search-list>
						{posts.slice(0, 8).map((post) => (
							<li>
								<a href={post.url}>
									<strong>{post.title}</strong>
									<span>{post.area}</span>
								</a>
							</li>
						))}
					</ul>
					<p class="text-muted" data-blog-search-empty hidden>Nenhum resultado para esse termo.</p>
				</section>

				{featured && <FeaturedPost post={featured} />}
			</>
		)}

		<section class="blog-grid" aria-label="Categorias do blog">
			<div class="section-title">
				<div>
					<span class="section-kicker">Categorias do blog</span>
					<h2>Se a situacao ja esta localizada, siga pela categoria correspondente</h2>
				</div>
				<a class="btn btn-ghost" href="/blog/categoria/">Ver todas as categorias</a>
			</div>
			<div class="cluster-directory-grid">
				{categoryDirectory.map((category) => (
					<article class="surface-card cluster-directory-card">
						<span class="section-kicker">Categoria</span>
						<h3>{category.title}</h3>
						<p>{category.shortDescription}</p>
						{category.latestPosts.length > 0 ? (
							<div class="cluster-directory-posts">
								<p class="cluster-directory-meta">{category.postCount} artigo(s) publicado(s).</p>
								<ul>
									{category.latestPosts.map((post) => (
										<li><a href={post.url}>{post.title}</a></li>
									))}
								</ul>
							</div>
						) : (
							<p class="cluster-directory-empty">
								Esta categoria ja esta disponivel e recebera novos conteudos conforme o acervo publicado crescer.
							</p>
						)}
						<div class="cluster-directory-actions">
							<a class="btn btn-primary" href={category.categoryHref}>Explorar categoria</a>
							<a class="btn btn-ghost" href={category.href}>Conheca a area</a>
						</div>
					</article>
				))}
			</div>
		</section>

		{continuityPosts.length > 0 && (
			<BlogGrid title="Continue a leitura" kicker="Aprofundamento" posts={continuityPosts} />
		)}

		<section class="editorial-cta" aria-label="Primeiro passo para contato">
			<span class="section-kicker">Quando a leitura ajuda a decidir</span>
			<h2>Se o tema deixar de ser apenas duvida, o primeiro passo e descrever sua situacao com clareza.</h2>
			<p>
				A PAVIE nao promete resposta automatica nem patrocinio imediato. O primeiro movimento e contextualizar o
				caso, entender o que precisa ser informado e explicar como funciona o retorno inicial.
			</p>
			<div class="blog-actions">
				<a class="btn btn-primary" href="/blog/contato/">Solicitar orientacao inicial</a>
				<a class="btn btn-ghost" href="/areas/">Conheca as areas</a>
			</div>
		</section>

		<section class="surface-card blog-author-spotlight" aria-label="Autor do blog">
			<img
				src="/uploads/foto_001-ffundddo-escrit%C3%B3rio.png"
				alt="Foto profissional do advogado Fabio Mathias Pavie"
				loading="lazy"
			/>
			<div>
				<span class="section-kicker">Autor do blog</span>
				<h2>Fabio Mathias Pavie</h2>
				<p>Advogado | OAB/RJ 134.947</p>
				<p>
					Fabio Pavie escreve principalmente sobre questoes patrimoniais, familiares, sucessorias,
					imobiliarias e documentais, com rigor documental e linguagem clara.
				</p>
				<div class="blog-actions">
					<a class="btn btn-primary" href="/autor/fabio-pavie/">Conheca o autor</a>
					<a class="btn btn-ghost" href="/blog/categoria/">Explorar categorias</a>
				</div>
			</div>
		</section>
	</div>

	<script define:vars={{ searchIndex }}>
		const input = document.querySelector('[data-blog-search-input]');
		const list = document.querySelector('[data-blog-search-list]');
		const empty = document.querySelector('[data-blog-search-empty]');
		const safeIndex = Array.isArray(searchIndex) ? searchIndex : [];

		if (input && list && empty) {
			const render = (items) => {
				list.innerHTML = '';
				for (const item of items) {
					const li = document.createElement('li');
					const link = document.createElement('a');
					link.href = item.url;
					const strong = document.createElement('strong');
					strong.textContent = item.title;
					const area = document.createElement('span');
					area.textContent = item.area;
					link.appendChild(strong);
					link.appendChild(area);
					li.appendChild(link);
					list.appendChild(li);
				}
			};

			render(safeIndex.slice(0, 8));
			input.addEventListener('input', () => {
				const term = input.value.trim().toLowerCase();
				if (!term) {
					render(safeIndex.slice(0, 8));
					empty.hidden = true;
					return;
				}
				const filtered = safeIndex.filter((item) => item.tokens.includes(term)).slice(0, 8);
				render(filtered);
				empty.hidden = filtered.length > 0;
			});
		}
	</script>
	<script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
</BlogLayout>
