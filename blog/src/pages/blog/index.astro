	mainEntity:
		posts.length > 0
			? {
					'@type': 'ItemList',
					itemListElement: posts.slice(0, 12).map((post, index) => ({
						'@type': 'ListItem',
						position: index + 1,
						url: `${BLOG_SITE_URL}${post.url}`,
						name: post.title,
					})),
				}
			: undefined,
};
