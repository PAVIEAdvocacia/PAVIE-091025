---
import Breadcrumbs from '../../../components/blog/Breadcrumbs.astro';
import BlogGrid from '../../../components/blog/BlogGrid.astro';
import FeaturedPost from '../../../components/blog/FeaturedPost.astro';
import { BLOG_SITE_URL } from '../../../consts';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import { getAreaEntries, getBlogEntries } from '../../../lib/blog-content';
import {
	buildCanonicalAreaDirectory,
	getCanonicalAreaDirectoryItem,
} from '../../../lib/canonical-directory';
import { isPublicPost, normalizePost, sortPostsByDate } from '../../../lib/posts';
import { buildBreadcrumbSchema } from '../../../lib/seo';

export async function getStaticPaths() {
	const areaEntries = await getAreaEntries();
	return areaEntries
		.filter((entry) => entry.data.isActive !== false)
		.map((entry) => ({ params: { category: entry.data.slug } }));
}

const [areaEntries, blogEntries] = await Promise.all([getAreaEntries(), getBlogEntries()]);
const posts = sortPostsByDate(blogEntries.map((entry) => normalizePost(entry))).filter(isPublicPost);
const currentCategory = getCanonicalAreaDirectoryItem(areaEntries, posts, Astro.params.category ?? '');

if (!currentCategory) {
	throw new Error(`Categoria canonica nao encontrada: ${Astro.params.category}`);
}

const remainingPosts = currentCategory.posts.filter((post) => post.slug !== currentCategory.featuredPost?.slug);
const siblingCategories = buildCanonicalAreaDirectory(areaEntries, posts)
	.filter((item) => item.slug !== currentCategory.slug)
	.slice(0, 3);
const canonicalUrl = `${BLOG_SITE_URL}${currentCategory.categoryHref}`;
const breadcrumbs = [
	{ label: 'Inicio', href: '/' },
	{ label: 'Publicacoes', href: '/blog/' },
	{ label: 'Categorias', href: '/blog/categoria/' },
	{ label: currentCategory.title },
];
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);
---

<BlogLayout
	title={`${currentCategory.title} | Categoria do blog`}
	description={currentCategory.shortDescription}
	canonical={canonicalUrl}
>
	<div class="container blog-home">
		<Breadcrumbs items={breadcrumbs} />
		<section class="surface-card blog-map-hero" aria-labelledby="blog-category-title">
			<span class="badge">Categoria canonica</span>
			<h1 id="blog-category-title">{currentCategory.title}</h1>
			<p>{currentCategory.headline}</p>
			<div class="meta-list">
				<span><span class="meta-dot" aria-hidden="true"></span>{currentCategory.postCount} publicacoes homologadas</span>
				<span><span class="meta-dot" aria-hidden="true"></span>Interlinking operando apenas na taxonomia aprovada</span>
				<span><span class="meta-dot" aria-hidden="true"></span>Ligacao direta com a pagina de area correspondente</span>
			</div>
			<div class="blog-actions">
				<a class="btn btn-primary" href={currentCategory.href}>Conheca a area</a>
				<a class="btn btn-ghost" href="/blog/contato/">Solicitar orientacao inicial</a>
			</div>
		</section>

		{currentCategory.featuredPost ? (
			<FeaturedPost post={currentCategory.featuredPost} />
		) : (
			<section class="surface-card empty-state" aria-label="Acervo em atualizacao">
				<h2>Acervo em atualizacao</h2>
				<p>
					A categoria ja esta pronta para o Sprint 2, mas ainda nao ha publicacoes homologadas suficientes para
					compor a listagem principal.
				</p>
				<div class="blog-actions">
					<a class="btn btn-primary" href={currentCategory.href}>Conheca a area</a>
					<a class="btn btn-ghost" href="/blog/categoria/">Ver outras categorias</a>
				</div>
			</section>
		)}

		<BlogGrid
			title="Leituras desta categoria"
			kicker="Categoria canonica"
			posts={remainingPosts}
			emptyTitle="Sem outras publicacoes homologadas"
			emptyText="A categoria ja integra a camada canonica e acumulara autoridade conforme o acervo for homologado."
			emptyHref={currentCategory.href}
			emptyLabel="Conheca a area"
		/>

		{siblingCategories.length > 0 && (
			<section class="blog-grid" aria-label="Outras categorias">
				<div class="section-title">
					<div>
						<span class="section-kicker">Outras categorias</span>
						<h2>Se a leitura atual nao for o melhor eixo, continue por outra categoria canonica</h2>
					</div>
					<a class="btn btn-ghost" href="/blog/categoria/">Ver todas as categorias</a>
				</div>
				<div class="cluster-directory-grid">
					{siblingCategories.map((category) => (
						<article class="surface-card cluster-directory-card">
							<h3>{category.title}</h3>
							<p>{category.shortDescription}</p>
							<p class="cluster-directory-meta">{category.postCount} publicacoes homologadas.</p>
							<div class="cluster-directory-actions">
								<a class="btn btn-primary" href={category.categoryHref}>Explorar categoria</a>
								<a class="btn btn-ghost" href={category.href}>Conheca a area</a>
							</div>
						</article>
					))}
				</div>
			</section>
		)}
	</div>

	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BlogLayout>
