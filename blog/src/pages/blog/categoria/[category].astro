---
import Breadcrumbs from '../../../components/blog/Breadcrumbs.astro';
import BlogGrid from '../../../components/blog/BlogGrid.astro';
import FeaturedPost from '../../../components/blog/FeaturedPost.astro';
import { BLOG_SITE_URL } from '../../../consts';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import { getAreaEntries, getAuthorEntries, getBlogEntries } from '../../../lib/blog-content';
import {
	buildCanonicalAreaDirectory,
	getCanonicalAreaDirectoryItem,
} from '../../../lib/canonical-directory';
import { isPublicPost, normalizePosts, sortPostsByDate } from '../../../lib/posts';
import { buildBreadcrumbSchema } from '../../../lib/seo';

export async function getStaticPaths() {
	const areaEntries = await getAreaEntries();
	return areaEntries
		.filter((entry) => entry.data.isActive !== false)
		.map((entry) => ({ params: { category: entry.data.slug } }));
}

const [areaEntries, authorEntries, blogEntries] = await Promise.all([
	getAreaEntries(),
	getAuthorEntries(),
	getBlogEntries(),
]);
const posts = sortPostsByDate(normalizePosts(blogEntries, authorEntries)).filter(isPublicPost);
const currentCategory = getCanonicalAreaDirectoryItem(areaEntries, posts, Astro.params.category ?? '');

if (!currentCategory) {
	throw new Error(`Categoria canônica não encontrada: ${Astro.params.category}`);
}

const remainingPosts = currentCategory.posts.filter((post) => post.slug !== currentCategory.featuredPost?.slug);
const hasCategoryPosts = currentCategory.postCount > 0;
const categoryCountLabel = hasCategoryPosts
	? `${currentCategory.postCount} artigo${currentCategory.postCount === 1 ? '' : 's'} publicado${currentCategory.postCount === 1 ? '' : 's'}`
	: 'Acervo em preparação nesta categoria';
const siblingCategories = buildCanonicalAreaDirectory(areaEntries, posts)
	.filter((item) => item.slug !== currentCategory.slug)
	.slice(0, 3);
const canonicalUrl = `${BLOG_SITE_URL}${currentCategory.categoryHref}`;
const breadcrumbs = [
	{ label: 'Início', href: '/' },
	{ label: 'Publicações', href: '/blog/' },
	{ label: 'Categorias', href: '/blog/categoria/' },
	{ label: currentCategory.title },
];
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);
---

<BlogLayout
	title={`${currentCategory.title} | Categoria do blog`}
	description={currentCategory.shortDescription}
	canonical={canonicalUrl}
>
	<div class="container blog-home">
		<Breadcrumbs items={breadcrumbs} />
		<section class="surface-card blog-map-hero" aria-labelledby="blog-category-title">
			<span class="badge">Categoria do blog</span>
			<h1 id="blog-category-title">{currentCategory.title}</h1>
			<p>{currentCategory.headline}</p>
			<div class="meta-list">
				<span><span class="meta-dot" aria-hidden="true"></span>{categoryCountLabel}</span>
				<span><span class="meta-dot" aria-hidden="true"></span>Leituras relacionadas pela mesma categoria</span>
				<span><span class="meta-dot" aria-hidden="true"></span>Ligação com a área correspondente</span>
			</div>
			<div class="blog-actions">
				<a class="btn btn-primary" href="#leituras-categoria">
					{hasCategoryPosts ? 'Ver leituras da categoria' : 'Ver acervo em preparação'}
				</a>
				<a class="btn btn-ghost" href={currentCategory.href}>Conhecer área</a>
			</div>
		</section>

		{currentCategory.featuredPost ? (
			<FeaturedPost post={currentCategory.featuredPost} />
		) : (
			<section class="surface-card empty-state" aria-label="Acervo em atualização">
				<h2>Acervo em atualização</h2>
				<p>
					Esta categoria já está estruturada no mapa editorial. Os textos serão exibidos aqui
					conforme avançarem por revisão editorial e jurídica.
				</p>
				<div class="blog-actions">
					<a class="btn btn-primary" href="/blog/categoria/">Ver outras categorias</a>
					<a class="btn btn-ghost" href={currentCategory.href}>Conheça a área</a>
				</div>
			</section>
		)}

		<BlogGrid
			id="leituras-categoria"
			title="Leituras desta categoria"
			kicker="Categoria"
			posts={remainingPosts}
			emptyTitle={hasCategoryPosts ? 'Sem outras publicações nesta categoria' : 'Acervo em preparação'}
			emptyText={
				hasCategoryPosts
					? 'A categoria receberá novos textos conforme o acervo publicado crescer.'
					: 'A categoria já está estruturada e os textos serão exibidos aqui conforme avançarem por revisão editorial e jurídica.'
			}
			emptyHref="/blog/categoria/"
			emptyLabel="Ver outras categorias"
		/>

		{siblingCategories.length > 0 && (
			<section class="blog-grid" aria-label="Outras categorias">
				<div class="section-title">
					<div>
						<span class="section-kicker">Outras categorias</span>
						<h2>Se a leitura atual não for o melhor eixo, continue por outra categoria</h2>
					</div>
					<a class="btn btn-ghost" href="/blog/categoria/">Ver todas as categorias</a>
				</div>
				<div class="cluster-directory-grid">
					{siblingCategories.map((category) => (
						<article class="surface-card cluster-directory-card">
							<h3>{category.title}</h3>
							<p>{category.shortDescription}</p>
							<p class="cluster-directory-meta">
								{category.postCount > 0
									? `${category.postCount} artigo${category.postCount === 1 ? '' : 's'} publicado${category.postCount === 1 ? '' : 's'}.`
									: 'Acervo em preparação.'}
							</p>
							<div class="cluster-directory-actions">
								<a class="btn btn-primary" href={category.categoryHref}>Explorar categoria</a>
								<a class="btn btn-ghost" href={category.href}>Conhecer área</a>
							</div>
						</article>
					))}
				</div>
			</section>
		)}
	</div>

	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BlogLayout>
