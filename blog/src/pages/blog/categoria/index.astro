---
import Breadcrumbs from '../../../components/blog/Breadcrumbs.astro';
import { BLOG_SITE_URL } from '../../../consts';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import { getAreaEntries, getAuthorEntries, getBlogEntries } from '../../../lib/blog-content';
import { buildCanonicalAreaDirectory } from '../../../lib/canonical-directory';
import { isPublicPost, normalizePosts, sortPostsByDate } from '../../../lib/posts';
import { buildBreadcrumbSchema } from '../../../lib/seo';

const [areaEntries, authorEntries, blogEntries] = await Promise.all([
	getAreaEntries(),
	getAuthorEntries(),
	getBlogEntries(),
]);
const posts = sortPostsByDate(normalizePosts(blogEntries, authorEntries)).filter(isPublicPost);
const categoryDirectory = buildCanonicalAreaDirectory(areaEntries, posts);
const hasPublishedPosts = posts.length > 0;
const postCountLabel = hasPublishedPosts
	? `${posts.length} artigo${posts.length === 1 ? '' : 's'} publicado${posts.length === 1 ? '' : 's'}`
	: 'Acervo editorial em preparacao';
const canonicalUrl = `${BLOG_SITE_URL}/blog/categoria/`;
const breadcrumbs = [
	{ label: 'Inicio', href: '/' },
	{ label: 'Publicacoes', href: '/blog/' },
	{ label: 'Categorias' },
];
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);
---

<BlogLayout
	title="Categorias do blog | PAVIE | Advocacia"
	description="Categorias do blog juridico da PAVIE, conectadas as areas do site e ao acervo publicado."
	canonical={canonicalUrl}
>
	<div class="container blog-home">
		<Breadcrumbs items={breadcrumbs} />
		<section class="surface-card blog-map-hero" aria-labelledby="blog-categories-title">
			<span class="badge">Categorias do blog</span>
			<h1 id="blog-categories-title">O blog organiza a leitura por categorias alinhadas as areas do site.</h1>
			<p>
				Cada categoria aponta para uma pagina de area correspondente e para leituras relacionadas,
				ajudando a localizar o tema sem reabrir estruturas paralelas de navegacao.
			</p>
			<div class="meta-list">
				<span><span class="meta-dot" aria-hidden="true"></span>{categoryDirectory.length} categorias ativas</span>
				<span><span class="meta-dot" aria-hidden="true"></span>{postCountLabel}</span>
				<span><span class="meta-dot" aria-hidden="true"></span>Ligacao direta com as paginas de area</span>
			</div>
			<div class="blog-actions">
				<a class="btn btn-primary" href="/#areas">Ver areas no site institucional</a>
				<a class="btn btn-ghost" href="/blog/">Voltar ao blog</a>
			</div>
		</section>

		<section class="blog-grid" aria-label="Categorias do blog">
			<div class="section-title">
				<div>
					<span class="section-kicker">Mapa editorial</span>
					<h2>Cada categoria aponta para uma area do site e para leituras relacionadas</h2>
				</div>
			</div>
			<div class="cluster-directory-grid cluster-directory-grid--wide">
				{categoryDirectory.map((category) => (
					<article class="surface-card cluster-directory-card">
						<span class="section-kicker">Categoria</span>
						<h2>{category.title}</h2>
						<p>{category.shortDescription}</p>
						<ul class="cluster-directory-list">
							<li>{category.headline}</li>
							<li>
									{category.postCount > 0
										? `${category.postCount} artigo${category.postCount > 1 ? 's' : ''} publicado${category.postCount > 1 ? 's' : ''}.`
										: 'Acervo em preparacao nesta categoria. Textos revisados serao incorporados conforme o plano editorial.'}
							</li>
						</ul>
						{category.latestPosts.length > 0 && (
							<div class="cluster-directory-posts">
								<p class="cluster-directory-meta">Leituras recentes</p>
								<ul>
									{category.latestPosts.map((post) => (
										<li><a href={post.url}>{post.title}</a></li>
									))}
								</ul>
							</div>
						)}
						<div class="cluster-directory-actions">
							<a class="btn btn-primary" href={category.categoryHref}>Explorar categoria</a>
							<a class="btn btn-ghost" href={category.href}>Conheca a area</a>
						</div>
					</article>
				))}
			</div>
		</section>
	</div>

	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BlogLayout>
