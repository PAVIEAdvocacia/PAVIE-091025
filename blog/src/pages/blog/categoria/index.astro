---
import Breadcrumbs from '../../../components/blog/Breadcrumbs.astro';
import { BLOG_SITE_URL } from '../../../consts';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import { getAreaEntries, getBlogEntries } from '../../../lib/blog-content';
import { buildCanonicalAreaDirectory } from '../../../lib/canonical-directory';
import { isPublicPost, normalizePost, sortPostsByDate } from '../../../lib/posts';
import { buildBreadcrumbSchema } from '../../../lib/seo';

const [areaEntries, blogEntries] = await Promise.all([getAreaEntries(), getBlogEntries()]);
const posts = sortPostsByDate(blogEntries.map((entry) => normalizePost(entry))).filter(isPublicPost);
const categoryDirectory = buildCanonicalAreaDirectory(areaEntries, posts);
const canonicalUrl = `${BLOG_SITE_URL}/blog/categoria/`;
const breadcrumbs = [
	{ label: 'Inicio', href: '/' },
	{ label: 'Publicacoes', href: '/blog/' },
	{ label: 'Categorias' },
];
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);
---

<BlogLayout
	title="Categorias do blog | PAVIE | Advocacia"
	description="Categorias canonicas do blog juridico da PAVIE, conectadas as areas aprovadas e ao acervo homologado."
	canonical={canonicalUrl}
>
	<div class="container blog-home">
		<Breadcrumbs items={breadcrumbs} />
		<section class="surface-card blog-map-hero" aria-labelledby="blog-categories-title">
			<span class="badge">Categorias canonicas</span>
			<h1 id="blog-categories-title">O blog organiza a navegacao editorial apenas pelas categorias canonicas aprovadas.</h1>
			<p>
				Esta pagina substitui a dependencia da taxonomia legada como eixo de descoberta. Cada categoria aponta para
				sua pagina de area correspondente e para o acervo homologado compativel.
			</p>
			<div class="meta-list">
				<span><span class="meta-dot" aria-hidden="true"></span>{categoryDirectory.length} categorias ativas</span>
				<span><span class="meta-dot" aria-hidden="true"></span>{posts.length} publicacoes homologadas</span>
				<span><span class="meta-dot" aria-hidden="true"></span>Sem fallback por clusters legados</span>
			</div>
			<div class="blog-actions">
				<a class="btn btn-primary" href="/blog/contato/">Solicitar orientacao inicial</a>
				<a class="btn btn-ghost" href="/areas/">Conheca as areas</a>
			</div>
		</section>

		<section class="blog-grid" aria-label="Categorias do blog">
			<div class="section-title">
				<div>
					<span class="section-kicker">Mapa editorial</span>
					<h2>Cada categoria reforca uma area canonica e um destino publico estavel</h2>
				</div>
			</div>
			<div class="cluster-directory-grid cluster-directory-grid--wide">
				{categoryDirectory.map((category) => (
					<article class="surface-card cluster-directory-card">
						<span class="section-kicker">Categoria</span>
						<h2>{category.title}</h2>
						<p>{category.shortDescription}</p>
						<ul class="cluster-directory-list">
							<li>{category.headline}</li>
							<li>
								{category.postCount > 0
									? `${category.postCount} publicacao${category.postCount > 1 ? 'oes' : ''} homologada${category.postCount > 1 ? 's' : ''}.`
									: 'A estrutura da categoria esta pronta e aguarda expansao homologada do acervo.'}
							</li>
						</ul>
						{category.latestPosts.length > 0 && (
							<div class="cluster-directory-posts">
								<p class="cluster-directory-meta">Leituras recentes</p>
								<ul>
									{category.latestPosts.map((post) => (
										<li><a href={post.url}>{post.title}</a></li>
									))}
								</ul>
							</div>
						)}
						<div class="cluster-directory-actions">
							<a class="btn btn-primary" href={category.categoryHref}>Explorar categoria</a>
							<a class="btn btn-ghost" href={category.href}>Conheca a area</a>
						</div>
					</article>
				))}
			</div>
		</section>
	</div>

	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BlogLayout>
