---
import Breadcrumbs from '../../../../components/blog/Breadcrumbs.astro';
import CategoryHero from '../../../../components/blog/CategoryHero.astro';
import FeaturedPost from '../../../../components/blog/FeaturedPost.astro';
import { BLOG_SITE_URL, MAIN_SITE_URL } from '../../../../consts';
import BlogLayout from '../../../../layouts/BlogLayout.astro';
import { getAreaEntries, getAuthorEntries, getBlogEntries } from '../../../../lib/blog-content';
import { getCanonicalAreaDirectoryItem, buildCanonicalAreaDirectory } from '../../../../lib/canonical-directory';
import { CATEGORY_PAGE_SIZE, getCategoryPageCount, getCategoryPageState } from '../../../../lib/category-pagination';
import {
	EDITORIAL_ANALYTICS_EVENTS,
	categoryAnalyticsContext,
	editorialAnalyticsAttributes,
} from '../../../../lib/editorial-analytics';
import { isPublicPost, normalizePosts, sortPostsByDate } from '../../../../lib/posts';
import { buildBreadcrumbSchema } from '../../../../lib/seo';

export async function getStaticPaths() {
	const [areaEntries, authorEntries, blogEntries] = await Promise.all([
		getAreaEntries(),
		getAuthorEntries(),
		getBlogEntries(),
	]);
	const posts = sortPostsByDate(normalizePosts(blogEntries, authorEntries)).filter(isPublicPost);
	const categories = buildCanonicalAreaDirectory(areaEntries, posts);

	return categories.flatMap((category) => {
		const pageCount = getCategoryPageCount(category.posts, category.featuredPost, CATEGORY_PAGE_SIZE);

		return Array.from({ length: pageCount }, (_, index) => ({
			params: {
				slug: category.slug,
				page: index === 0 ? undefined : String(index + 1),
			},
			props: {
				categorySlug: category.slug,
				pageNumber: index + 1,
			},
		}));
	});
}

const [areaEntries, authorEntries, blogEntries] = await Promise.all([
	getAreaEntries(),
	getAuthorEntries(),
	getBlogEntries(),
]);
const posts = sortPostsByDate(normalizePosts(blogEntries, authorEntries)).filter(isPublicPost);
const currentCategory = getCanonicalAreaDirectoryItem(areaEntries, posts, Astro.props.categorySlug ?? Astro.params.slug ?? '');

if (!currentCategory) {
	throw new Error(`Categoria canonica nao encontrada: ${Astro.params.slug}`);
}

const pageNumber = Number(Astro.props.pageNumber ?? 1);
const featuredPost = currentCategory.featuredPost;
const pagination = getCategoryPageState(currentCategory.posts, featuredPost, pageNumber, CATEGORY_PAGE_SIZE);
const { pageCount, listPosts, firstItemNumber, hasPagination } = pagination;
const hasCategoryPosts = currentCategory.postCount > 0;
const categoryAnalyticsContextValue = categoryAnalyticsContext(currentCategory);
const categoryAuthor =
	authorEntries.find((entry) => entry.data.slug === 'fabio-pavie' || entry.data.id === 'fabio-pavie') ??
	authorEntries[0];
const categoryCountLabel = hasCategoryPosts
	? `${currentCategory.postCount} artigo${currentCategory.postCount === 1 ? '' : 's'} publicado${currentCategory.postCount === 1 ? '' : 's'}`
	: 'Acervo em preparacao nesta categoria';
const pagePath = pageNumber > 1 ? `${currentCategory.categoryHref}${pageNumber}/` : currentCategory.categoryHref;
const canonicalUrl = `${BLOG_SITE_URL}${pagePath}`;
const previousPageHref =
	pageNumber > 1
		? pageNumber === 2
			? currentCategory.categoryHref
			: `${currentCategory.categoryHref}${pageNumber - 1}/`
		: undefined;
const nextPageHref =
	pageNumber < pageCount ? `${currentCategory.categoryHref}${pageNumber + 1}/` : undefined;
const breadcrumbs = [
	{ label: 'Início', href: '/' },
	{ label: 'Blog', href: '/blog/' },
	{ label: currentCategory.title },
	...(pageNumber > 1 ? [{ label: `Página ${pageNumber}` }] : []),
];
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);
const pageTitle = pageNumber > 1
	? `${currentCategory.title} | Categoria do blog | Pagina ${pageNumber}`
	: `${currentCategory.title} | Categoria do blog`;
---

<BlogLayout
	title={pageTitle}
	description={currentCategory.shortDescription}
	canonical={canonicalUrl}
>
	<div class="container blog-home blog-category-page">
		<Breadcrumbs items={breadcrumbs} />

		<CategoryHero category={currentCategory} countLabel={categoryCountLabel} hasPosts={hasCategoryPosts} />

		<section class="category-area-link" aria-labelledby="category-area-title">
			<div class="category-area-link__copy">
				<span class="section-kicker">Relacao area-categoria</span>
				<h2 id="category-area-title">Esta categoria amadurece a leitura antes do retorno ao site.</h2>
				<p>{currentCategory.headline}</p>
			</div>
			<ul class="category-area-link__facts" aria-label="Vinculo editorial da categoria">
				<li>
					<span>Categoria editorial</span>
					<strong>{currentCategory.displayTitle}</strong>
				</li>
				<li>
					<span>Area correspondente</span>
					<strong>{currentCategory.canonicalTitle}</strong>
				</li>
				<li>
					<span>Acervo publicado</span>
					<strong>{categoryCountLabel}</strong>
				</li>
				<li>
					<span>Destino institucional</span>
					<strong>{currentCategory.href}</strong>
				</li>
			</ul>
		</section>

		<section class="category-archive-summary" aria-labelledby="category-archive-title">
			<div>
				<span class="section-kicker">Acervo da categoria</span>
				<h2 id="category-archive-title">{categoryCountLabel}</h2>
			</div>
			<p>
				A contagem usa apenas textos publicados, revisados e liberados para superficie publica nesta categoria.
			</p>
		</section>

		{pageNumber === 1 && (
			<section class="category-featured" aria-labelledby="category-featured-title">
				<div class="section-title">
					<div>
						<span class="section-kicker">Leitura em destaque</span>
						<h2 id="category-featured-title">Comece por uma leitura central da categoria</h2>
					</div>
				</div>
				{featuredPost ? (
					<FeaturedPost post={featuredPost} />
				) : (
					<div class="surface-card empty-state" aria-label="Acervo em preparacao">
						<h3>Acervo em preparacao</h3>
						<p>
							Esta categoria ja esta estruturada no registry e recebera textos conforme avancarem por revisao editorial e juridica.
						</p>
					</div>
				)}
			</section>
		)}

		<section id="leituras-categoria" class="category-reading-list" aria-labelledby="category-reading-list-title">
			<div class="section-title">
				<div>
					<span class="section-kicker">Artigos da categoria</span>
					<h2 id="category-reading-list-title">Leituras uteis para maturar o tema</h2>
				</div>
			</div>

			{listPosts.length > 0 ? (
				<ol class="category-reading-list__items">
					{listPosts.map((post, index) => (
						<li>
							<article class="category-reading-item">
								<span class="category-reading-item__number">{String(firstItemNumber + index).padStart(2, '0')}</span>
								<div>
									<p class="category-reading-item__meta">
										{post.readingTime} min de leitura
										{post.publishedAt && ` - ${post.publishedAt.toLocaleDateString('pt-BR', { dateStyle: 'medium' })}`}
									</p>
									<h3>
										<a
											href={post.url}
											data-link-origin="category-reading-list"
											data-link-target="article"
										>
											{post.title}
										</a>
									</h3>
									<p>{post.excerpt}</p>
								</div>
							</article>
						</li>
					))}
				</ol>
			) : (
				<div class="surface-card empty-state" aria-label="Sem leituras complementares nesta categoria">
					<h3>{hasCategoryPosts ? 'Leitura central ja disponivel' : 'Acervo em preparacao'}</h3>
					<p>
						{hasCategoryPosts
							? 'A categoria ja possui uma leitura central em destaque. Novos textos complementares entram conforme forem revisados.'
							: 'A categoria ja esta estruturada no registry e recebera artigos conforme o acervo for aprovado.'}
					</p>
				</div>
			)}

			{hasPagination && (
				<nav class="blog-actions" aria-label="Paginacao da categoria">
					{previousPageHref && (
						<a
							class="btn btn-ghost"
							href={previousPageHref}
							data-link-origin="category-pagination"
							data-link-target="category-page"
						>
							Pagina anterior
						</a>
					)}
					<span class="section-kicker">Pagina {pageNumber} de {pageCount}</span>
					{nextPageHref && (
						<a
							class="btn btn-ghost"
							href={nextPageHref}
							data-link-origin="category-pagination"
							data-link-target="category-page"
						>
							Proxima pagina
						</a>
					)}
				</nav>
			)}
		</section>

		<section class="category-final-cta" aria-labelledby="category-final-title">
			<span class="section-kicker">Transicao para o site</span>
			<h2 id="category-final-title">Quando o tema ja estiver mais claro, volte a area correspondente.</h2>
			<p>
				A categoria organiza a leitura por interesse. A pagina institucional concentra o enquadramento da area,
				os limites do primeiro contato e o caminho adequado para uma analise responsavel.
			</p>
			<div class="blog-actions">
				<a
					class="btn btn-primary"
					href={`${MAIN_SITE_URL}${currentCategory.href}`}
					data-link-origin="category-final"
					data-link-target="area"
					{...editorialAnalyticsAttributes({
						eventName: EDITORIAL_ANALYTICS_EVENTS.B2_S2_CLICK,
						surfaceOrigin: 'B2',
						surfaceTarget: 'S2',
						linkType: 'final-cta',
						...categoryAnalyticsContextValue,
					})}
				>
					Conhecer área correspondente
				</a>
			</div>
		</section>

		{categoryAuthor && (
			<section class="category-author-strip" aria-labelledby="category-author-title">
				<span class="section-kicker">Autoria editorial</span>
				<div>
					<h2 id="category-author-title">{categoryAuthor.data.name}</h2>
					<p>
						A curadoria da categoria privilegia contexto, criterios documentais e limites da leitura editorial,
						sem substituir analise juridica individual.
					</p>
				</div>
				<a
					class="btn btn-ghost"
					href={`/blog/autor/${categoryAuthor.data.slug}/`}
					data-link-origin="category-author"
					data-link-target="author"
				>
					Ver perfil do autor
				</a>
			</section>
		)}
	</div>

	<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BlogLayout>
