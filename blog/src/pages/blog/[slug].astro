---
import { render } from 'astro:content';
import ReadingLayout from '../../layouts/ReadingLayout.astro';
import { getAuthorEntries, getBlogEntries } from '../../lib/blog-content';
import { getRelatedPosts } from '../../lib/related';
import { isPublicPost, isPublishedPost, normalizePost, normalizePosts, sortPostsByDate } from '../../lib/posts';
import { buildToc } from '../../lib/toc';

export async function getStaticPaths() {
	const [entries, authorEntries] = await Promise.all([getBlogEntries(), getAuthorEntries()]);
	const paths: Array<{ params: { slug: string }; props: { entryId: string } }> = [];
	const seen = new Set<string>();

	for (const entry of entries) {
		const post = normalizePost(entry, authorEntries);
		if (!isPublishedPost(post)) continue;

		const primarySlug = post.slug;
		if (!seen.has(primarySlug)) {
			paths.push({
				params: { slug: primarySlug },
				props: { entryId: entry.id },
			});
			seen.add(primarySlug);
		}
	}

	return paths;
}

const [entries, authorEntries] = await Promise.all([getBlogEntries(), getAuthorEntries()]);
const currentEntry = entries.find((entry) => entry.id === Astro.props.entryId);

if (!currentEntry) {
	throw new Error(`Post nao encontrado: ${Astro.props.entryId}`);
}

const currentPost = normalizePost(currentEntry, authorEntries);
const publicPosts = sortPostsByDate(normalizePosts(entries, authorEntries)).filter(isPublicPost);
const related = getRelatedPosts(publicPosts, currentPost, 3);
const { Content, headings } = await render(currentEntry);
const toc = buildToc(headings);
const noIndex = !isPublicPost(currentPost);
---

<ReadingLayout post={currentPost} toc={toc} related={related} allPosts={publicPosts} noIndex={noIndex}>
	<Content />
</ReadingLayout>
