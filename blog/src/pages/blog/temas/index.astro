---
import Breadcrumbs from '../../../components/blog/Breadcrumbs.astro';
import { BLOG_SITE_URL } from '../../../consts';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import { getBlogEntries } from '../../../lib/blog-content';
import { buildBreadcrumbSchema } from '../../../lib/seo';
import { isPublicPost, normalizePost, sortPostsByDate } from '../../../lib/posts';
import { normalizeTemaKey, temaHref, temaLabel } from '../../../lib/taxonomy';

const entries = await getBlogEntries();
const posts = sortPostsByDate(entries.map((entry) => normalizePost(entry))).filter(isPublicPost);

const temaMap = new Map<string, { key: string; label: string; count: number }>();
for (const post of posts) {
	for (const tema of post.temas) {
		const key = normalizeTemaKey(tema);
		const item = temaMap.get(key);
		if (item) {
			item.count += 1;
			continue;
		}
		temaMap.set(key, { key, label: temaLabel(tema), count: 1 });
	}
}

const temas = [...temaMap.values()].sort((a, b) => b.count - a.count);
const canonicalUrl = `${BLOG_SITE_URL}/blog/temas/`;
const breadcrumbs = [
	{ label: 'Inicio', href: '/' },
	{ label: 'Publicacoes', href: '/blog/' },
	{ label: 'Temas' },
];
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);
---

<BlogLayout
	title="Temas do blog | PAVIE | Advocacia"
	description="Superficie secundaria do blog mantida apenas para exploracao auxiliar de temas."
	canonical={canonicalUrl}
	noIndex={true}
>
	<div class="container blog-home">
		<Breadcrumbs items={breadcrumbs} />
		<section class="blog-grid" aria-label="Temas do blog">
			<div class="section-title">
				<div>
					<span class="section-kicker">Temas secundarios</span>
					<h1>Temas do blog</h1>
				</div>
			</div>
			<p class="text-muted">
				Os temas continuam disponiveis como apoio de leitura, mas a navegacao primaria do blog opera pelas
				categorias canonicas.
			</p>
			{temas.length === 0 ? (
				<article class="surface-card empty-state">
					<h2>Nenhum tema ativo</h2>
					<p>Os temas serao listados automaticamente conforme novas publicacoes forem adicionadas.</p>
					<div class="blog-actions">
						<a class="btn btn-primary" href="/blog/categoria/">Explorar categorias</a>
						<a class="btn btn-ghost" href="/blog/contato/">Solicitar orientacao inicial</a>
					</div>
				</article>
			) : (
				<div class="theme-chip-list">
					{temas.map((tema) => (
						<a class="blog-chip blog-chip--theme" href={temaHref(tema.key)}>
							{tema.label} ({tema.count})
						</a>
					))}
				</div>
			)}
		</section>
	</div>

	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BlogLayout>
