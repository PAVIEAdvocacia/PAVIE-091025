---
import Breadcrumbs from '../../components/blog/Breadcrumbs.astro';
import { BLOG_SITE_URL } from '../../consts';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { buildBreadcrumbSchema } from '../../lib/seo';

const title = 'Sobre o autor | Blog PAVIE | Advocacia';
const description =
	'Perfil profissional de Fabio Mathias Pavie, advogado responsavel pelos conteudos juridicos do blog da PAVIE | Advocacia.';
const canonicalUrl = `${BLOG_SITE_URL}/autor/fabio-pavie/`;
const breadcrumbs = [
	{ label: 'Inicio', href: '/' },
	{ label: 'Publicacoes', href: '/blog/' },
	{ label: 'Sobre o autor' },
];
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);
---

<BlogLayout title={title} description={description} canonical={canonicalUrl} noIndex={true}>
	<div class="container blog-home">
		<Breadcrumbs items={breadcrumbs} />
		<section class="surface-card blog-author-spotlight" aria-label="Perfil do autor do blog">
			<img
				src="/uploads/foto_001-ffundddo-escrit%C3%B3rio.png"
				alt="Foto profissional do advogado Fabio Mathias Pavie"
				loading="eager"
			/>
			<div>
				<span class="section-kicker">Superficie duplicada controlada</span>
				<h1>Fabio Mathias Pavie</h1>
				<p>Advogado | OAB/RJ 134.947</p>
				<p>
					O destino primario de autoria do ecossistema agora e a pagina canonica de autor. Esta rota permanece
					apenas para continuidade de navegacao e nao deve concentrar sinal de SEO.
				</p>
				<div class="site-hero__cta">
					<a class="btn btn-primary" href="/autor/fabio-pavie/">Conheca o autor</a>
					<a class="btn btn-ghost" href="/blog/categoria/">Explorar categorias</a>
				</div>
			</div>
		</section>
	</div>

	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BlogLayout>
