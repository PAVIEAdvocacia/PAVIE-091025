---
import { BLOG_SITE_URL } from '../../consts';
import BlogLayout from '../../layouts/BlogLayout.astro';

const title = 'Sobre o Autor | Blog PAVIE';
const description =
	'Perfil profissional de Fabio Mathias Pavie, advogado responsavel pelos conteudos juridicos do blog da PAVIE Advocacia.';
---

<BlogLayout title={title} description={description} canonical={`${BLOG_SITE_URL}/blog/sobre/`}>
	<div class="container blog-home">
		<section class="surface-card blog-author-spotlight" aria-label="Perfil do autor do blog">
			<img
				src="/uploads/foto_001-ffundddo-escritório.png"
				alt="Foto profissional do advogado Fabio Mathias Pavie"
				loading="eager"
			/>
			<div>
				<span class="section-kicker">Autor do blog</span>
				<h1>Fábio Mathias Pavie</h1>
				<p>Advogado · OAB/RJ 134.947</p>
				<p>
					Atuação em direito de família, sucessões, patrimônio e conflitos cíveis, com foco em clareza
					jurídica, prevenção de risco e condução responsável.
				</p>
				<p>Mais de 20 anos de experiência jurídica.</p>
				<div class="site-hero__cta">
					<a class="btn btn-primary" href="/areas/">Ver serviços</a>
					<a class="btn btn-ghost" href="/blog/">Ver conteúdos do blog</a>
				</div>
			</div>
		</section>
	</div>
</BlogLayout>
