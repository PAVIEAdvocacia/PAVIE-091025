---
import Breadcrumbs from '../../components/blog/Breadcrumbs.astro';
import { BLOG_SITE_URL } from '../../consts';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getAuthorEntries } from '../../lib/blog-content';
import { normalizeCmsImagePath } from '../../lib/content-media';
import { buildBreadcrumbSchema } from '../../lib/seo';

const title = 'Sobre o autor | Blog PAVIE | Advocacia';
const description =
	'Perfil profissional de Fabio Mathias Pavie, advogado responsável pelos conteúdos jurídicos do blog da PAVIE | Advocacia.';
const canonicalUrl = `${BLOG_SITE_URL}/autor/fabio-pavie/`;
const breadcrumbs = [
	{ label: 'Início', href: '/' },
	{ label: 'Publicações', href: '/blog/' },
	{ label: 'Sobre o autor' },
];
const authorEntries = await getAuthorEntries();
const blogAuthor =
	authorEntries.find((entry) => entry.data.slug === 'fabio-pavie' || entry.data.id === 'fabio-pavie') ??
	authorEntries[0];
const authorImage =
	normalizeCmsImagePath(blogAuthor?.data.image) ?? '/uploads/foto_001-ffundddo-escrit%C3%B3rio.png';
const authorImageAlt =
	blogAuthor?.data.imageAlt ?? 'Foto profissional do advogado Fabio Mathias Pavie';
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);
---

<BlogLayout title={title} description={description} canonical={canonicalUrl} noIndex={true}>
	<div class="container blog-home">
		<Breadcrumbs items={breadcrumbs} />
		<section class="surface-card blog-author-spotlight" aria-label="Perfil do autor do blog">
			<img
				src={authorImage}
				alt={authorImageAlt}
				loading="eager"
			/>
			<div>
				<span class="section-kicker">Superfície duplicada controlada</span>
				<h1>Fabio Mathias Pavie</h1>
				<p>Advogado | OAB/RJ 134.947</p>
				<p>
					O destino primário de autoria do ecossistema agora é a página canônica de autor. Esta rota permanece
					apenas para continuidade de navegação e não deve concentrar sinal de SEO.
				</p>
				<div class="site-hero__cta">
					<a class="btn btn-primary" href="/autor/fabio-pavie/">Conheça o autor</a>
					<a class="btn btn-ghost" href="/blog/categoria/">Explorar categorias</a>
				</div>
			</div>
		</section>
	</div>

	<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BlogLayout>
