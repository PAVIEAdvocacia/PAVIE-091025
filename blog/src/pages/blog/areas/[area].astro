---
import Breadcrumbs from '../../../components/blog/Breadcrumbs.astro';
import { BLOG_SITE_URL } from '../../../consts';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import { getAreaEntries, getBlogEntries } from '../../../lib/blog-content';
import { getCanonicalAreaDirectoryItem } from '../../../lib/canonical-directory';
import {
	canonicalCategoryHref,
	getLegacyAreaMigrationDefinition,
	getLegacyAreaRouteStaticKeys,
	resolveApprovedCategoryCodeFromLegacyArea,
	resolveLegacyAreaRouteKey,
} from '../../../lib/canonical-content';
import { isPublicPost, normalizePost, sortPostsByDate } from '../../../lib/posts';
import { buildBreadcrumbSchema } from '../../../lib/seo';

export async function getStaticPaths() {
	return getLegacyAreaRouteStaticKeys().map((area) => ({ params: { area } }));
}

const [areaEntries, blogEntries] = await Promise.all([getAreaEntries(), getBlogEntries()]);
const posts = sortPostsByDate(blogEntries.map((entry) => normalizePost(entry))).filter(isPublicPost);
const legacyKey = resolveLegacyAreaRouteKey(Astro.params.area ?? '');
const migration = getLegacyAreaMigrationDefinition(legacyKey);

if (!migration) {
	throw new Error(`Rota legada nao reconhecida: ${Astro.params.area}`);
}

const approvedCategoryCode = resolveApprovedCategoryCodeFromLegacyArea(legacyKey);
const targetCategoryHref = approvedCategoryCode ? canonicalCategoryHref(approvedCategoryCode) : '/blog/categoria/';
const targetCategory = approvedCategoryCode
	? getCanonicalAreaDirectoryItem(
			areaEntries,
			posts,
			targetCategoryHref.replace('/blog/categoria/', '').replace(/\//g, ''),
		)
	: undefined;
const canonicalUrl = approvedCategoryCode
	? `${BLOG_SITE_URL}${targetCategoryHref}`
	: `${BLOG_SITE_URL}/blog/categoria/`;
const breadcrumbs = [
	{ label: 'Inicio', href: '/' },
	{ label: 'Publicacoes', href: '/blog/' },
	{ label: 'Mapa legado de areas', href: '/blog/areas/' },
	{ label: migration.legacyAreaLabel },
];
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);
const hasDirectApprovedTarget = Boolean(approvedCategoryCode && targetCategory);
---

<BlogLayout
	title={`${migration.legacyAreaLabel} | Superficie legada do blog`}
	description="URL legada mantida apenas para continuidade de navegacao. O destino principal do blog passou a operar com categorias canonicas."
	canonical={canonicalUrl}
	noIndex={true}
>
	<div class="container blog-home">
		<Breadcrumbs items={breadcrumbs} />
		<section class="surface-card blog-map-hero" aria-labelledby="legacy-area-title">
			<span class="badge">Superficie legada</span>
			<h1 id="legacy-area-title">{migration.legacyAreaLabel}</h1>
			<p>{migration.migrationRule}</p>
			<div class="blog-actions">
				<a class="btn btn-primary" href={targetCategoryHref}>
					{hasDirectApprovedTarget ? 'Ir para a categoria canonica' : 'Explorar categorias canonicas'}
				</a>
				<a class="btn btn-ghost" href="/areas/">Conheca as areas</a>
			</div>
		</section>

		{hasDirectApprovedTarget ? (
			<section class="surface-card editorial-guide-card" aria-label="Destino canonico aprovado">
				<span class="section-kicker">Destino canonico</span>
				<h2>{targetCategory?.title}</h2>
				<p>{targetCategory?.shortDescription}</p>
				<div class="blog-actions">
					<a class="btn btn-primary" href={targetCategory?.categoryHref}>Explorar categoria</a>
					<a class="btn btn-ghost" href={targetCategory?.href}>Conheca a area</a>
				</div>
			</section>
		) : (
			<section class="surface-card empty-state" aria-label="Sem correspondencia canonica direta">
				<h2>Sem correspondencia canonica direta aprovada</h2>
				<p>
					Esta rota legada nao aponta para uma categoria publica homologada. O tratamento correto depende de triagem
					humana para reclassificar, migrar de forma extraordinaria ou arquivar o material relacionado.
				</p>
				<div class="blog-actions">
					<a class="btn btn-primary" href="/blog/categoria/">Explorar categorias canonicas</a>
					<a class="btn btn-ghost" href="/areas/">Conheca as areas</a>
				</div>
			</section>
		)}
	</div>

	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BlogLayout>
