---
import Breadcrumbs from '../../../components/blog/Breadcrumbs.astro';
import { BLOG_SITE_URL } from '../../../consts';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import { getBlogEntries } from '../../../lib/blog-content';
import { buildBreadcrumbSchema } from '../../../lib/seo';
import { buildBlogClusterDirectory } from '../../../lib/blog-clusters';
import { isPublicPost, normalizePost, sortPostsByDate } from '../../../lib/posts';
import { temaHref } from '../../../lib/taxonomy';

const entries = await getBlogEntries();
const posts = sortPostsByDate(entries.map((entry) => normalizePost(entry))).filter(isPublicPost);
const clusterDirectory = buildBlogClusterDirectory(posts);
const canonicalUrl = `${BLOG_SITE_URL}/blog/areas/`;
const breadcrumbs = [
	{ label: 'Início', href: '/' },
	{ label: 'Publicações', href: '/blog/' },
	{ label: 'Áreas jurídicas' },
];
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);
---

<BlogLayout
	title="Áreas jurídicas do blog | PAVIE | Advocacia"
	description="Conteúdos do blog da PAVIE organizados por área jurídica, com ligação natural entre leitura, serviços e contato."
	canonical={canonicalUrl}
>
	<div class="container blog-home">
		<Breadcrumbs items={breadcrumbs} />
		<section class="surface-card blog-map-hero" aria-labelledby="blog-areas-title">
			<span class="badge">Conteúdos por área</span>
			<h1 id="blog-areas-title">As áreas do blog organizam o caminho entre tema, leitura e orientação.</h1>
			<p>
				Aqui, o visitante não encontra uma listagem solta. Encontra 5 áreas jurídicas que ajudam a reconhecer
				qual universo jurídico está em jogo, o que já existe para leitura e quando vale seguir para a página de serviços da PAVIE.
			</p>
			<div class="blog-actions">
				<a class="btn btn-primary" href="/blog/contato/">Solicitar orientação inicial</a>
				<a class="btn btn-ghost" href="/areas/">Conheça os Serviços</a>
			</div>
		</section>

		<section class="blog-grid" aria-label="Áreas jurídicas do blog">
			<div class="section-title">
				<div>
					<span class="section-kicker">5 áreas jurídicas</span>
					<h2>Cada área aproxima aprofundamento por assunto, serviço correspondente e contato contextualizado</h2>
				</div>
			</div>
			<div class="cluster-directory-grid cluster-directory-grid--wide">
				{clusterDirectory.map((cluster) => (
					<article class="surface-card cluster-directory-card">
						<span class="section-kicker">Área jurídica</span>
						<h2>{cluster.title}</h2>
						<p>{cluster.editorialSummary}</p>
						<ul class="cluster-directory-list">
							{cluster.typicalSituations.map((item) => (
								<li>{item}</li>
							))}
						</ul>
						<div class="theme-chip-list">
							{cluster.topThemes.map((tema) => (
								<a class="blog-chip blog-chip--theme" href={cluster.hasThemeRoutes ? temaHref(tema) : cluster.href}>{tema}</a>
							))}
						</div>
						{cluster.hasPosts ? (
							<div class="cluster-directory-posts">
								<p class="cluster-directory-meta">{cluster.postCount} artigos nesta área.</p>
								<ul>
									{cluster.latestPosts.map((post) => (
										<li><a href={post.url}>{post.title}</a></li>
									))}
								</ul>
							</div>
						) : (
							<p class="cluster-directory-empty">
								Novos artigos em breve. Você pode falar diretamente sobre sua situação enquanto o acervo desta área cresce.
							</p>
						)}
						<div class="cluster-directory-actions">
							<a class="btn btn-primary" href={cluster.href}>Explorar temas</a>
							<a class="btn btn-ghost" href={cluster.institutionalHref}>Conheça os Serviços</a>
						</div>
					</article>
				))}
			</div>
		</section>

		<section class="editorial-cta" aria-label="Continuidade institucional">
			<span class="section-kicker">Continuidade institucional</span>
			<h2>Quando a leitura já delimitou a área jurídica, o próximo passo não precisa ser brusco.</h2>
			<p>
				O primeiro passo é descrever sua situação. A página de contato explica o que informar,
				o que acontece depois do envio e quais limites existem na etapa inicial.
			</p>
			<div class="blog-actions">
				<a class="btn btn-primary" href="/blog/contato/">Solicitar orientação inicial</a>
				<a class="btn btn-ghost" href="/blog/">Explorar temas</a>
			</div>
		</section>
	</div>

	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BlogLayout>
