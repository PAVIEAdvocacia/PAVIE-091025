---
import Breadcrumbs from '../../../components/blog/Breadcrumbs.astro';
import { BLOG_SITE_URL } from '../../../consts';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import { getAreaEntries, getBlogEntries } from '../../../lib/blog-content';
import { buildCanonicalAreaDirectory } from '../../../lib/canonical-directory';
import { isPublicPost, normalizePost, sortPostsByDate } from '../../../lib/posts';
import { buildBreadcrumbSchema } from '../../../lib/seo';

const [areaEntries, blogEntries] = await Promise.all([getAreaEntries(), getBlogEntries()]);
const posts = sortPostsByDate(blogEntries.map((entry) => normalizePost(entry))).filter(isPublicPost);
const categoryDirectory = buildCanonicalAreaDirectory(areaEntries, posts);
const canonicalUrl = `${BLOG_SITE_URL}/blog/categoria/`;
const breadcrumbs = [
	{ label: 'Inicio', href: '/' },
	{ label: 'Publicacoes', href: '/blog/' },
	{ label: 'Mapa legado de areas' },
];
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);
---

<BlogLayout
	title="Mapa legado de areas do blog | PAVIE | Advocacia"
	description="Superficie legada mantida apenas para continuidade de URL. A navegacao primaria do blog passou a usar categorias canonicas."
	canonical={canonicalUrl}
	noIndex={true}
>
	<div class="container blog-home">
		<Breadcrumbs items={breadcrumbs} />
		<section class="surface-card blog-map-hero" aria-labelledby="legacy-blog-areas-title">
			<span class="badge">Superficie legada</span>
			<h1 id="legacy-blog-areas-title">A navegacao principal do blog foi consolidada nas categorias canonicas.</h1>
			<p>
				Esta URL permanece ativa apenas como ponte controlada. Para descoberta editorial e interlinking publico,
				use a pagina de categorias e as paginas de area correspondentes.
			</p>
			<div class="blog-actions">
				<a class="btn btn-primary" href="/blog/categoria/">Explorar categorias</a>
				<a class="btn btn-ghost" href="/areas/">Conheca as areas</a>
			</div>
		</section>

		<section class="blog-grid" aria-label="Categorias canonicas disponiveis">
			<div class="section-title">
				<div>
					<span class="section-kicker">Destino canonico</span>
					<h2>Use estes destinos estaveis em vez das antigas areas do blog</h2>
				</div>
			</div>
			<div class="cluster-directory-grid cluster-directory-grid--wide">
				{categoryDirectory.map((category) => (
					<article class="surface-card cluster-directory-card">
						<h2>{category.title}</h2>
						<p>{category.shortDescription}</p>
						<div class="cluster-directory-actions">
							<a class="btn btn-primary" href={category.categoryHref}>Explorar categoria</a>
							<a class="btn btn-ghost" href={category.href}>Conheca a area</a>
						</div>
					</article>
				))}
			</div>
		</section>
	</div>

	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BlogLayout>
