---
import Breadcrumbs from '../../components/blog/Breadcrumbs.astro';
import { MAIN_SITE_URL } from '../../consts';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAreaEntries, getAuthorEntries, getBlogEntries } from '../../lib/blog-content';
import { getCanonicalAreaDirectoryItem } from '../../lib/canonical-directory';
import { isPublicPost, normalizePosts, sortPostsByDate } from '../../lib/posts';
import { buildBreadcrumbSchema, buildFaqSchema, LEGAL_SERVICE_BASE_SCHEMA } from '../../lib/seo';
import '../../styles/institutional-pages.css';

export async function getStaticPaths() {
	const areaEntries = await getAreaEntries();
	return areaEntries
		.filter((entry) => entry.data.isActive !== false)
		.map((entry) => ({ params: { slug: entry.data.slug } }));
}

const [areaEntries, authorEntries, blogEntries] = await Promise.all([
	getAreaEntries(),
	getAuthorEntries(),
	getBlogEntries(),
]);
const posts = sortPostsByDate(normalizePosts(blogEntries, authorEntries)).filter(isPublicPost);
const currentArea = getCanonicalAreaDirectoryItem(areaEntries, posts, Astro.params.slug ?? '');

if (!currentArea) {
	throw new Error(`Área canônica não encontrada: ${Astro.params.slug}`);
}

const area = currentArea.entry.data;
const canonicalUrl = `${MAIN_SITE_URL}${currentArea.href}`;
const breadcrumbs = [
	{ label: 'Início', href: '/' },
	{ label: 'Áreas', href: '/#areas' },
	{ label: area.displayTitle ?? currentArea.displayTitle },
];
const heroTitle = area.heroTitle ?? area.title;
const heroDescription = area.heroDescription ?? area.headline;
const framingText = area.framingText.length > 0 ? area.framingText : [area.description];
const documentsTitle = area.documentsTitle ?? 'Documentação típica';
const documentsNote = area.documentsNote ?? 'Orientação inicial para triagem, não exaustiva.';
const cautionsTitle = area.cautionsTitle ?? 'Limites e cautelas';
const cautionsIntro =
	area.cautionsIntro ?? 'A transparência é a base do nosso método. Veja o que precisa ser delimitado antes de qualquer providência.';
const faqTitle = area.faqTitle ?? 'Dúvidas comuns da área';
const readingTitle = area.readingTitle ?? 'Leitura útil antes do contato';
const readingDescription =
	area.readingDescription ??
	'Se a sua situação ainda está em fase de reconhecimento, recomendamos as análises técnicas da categoria correspondente.';
const finalTitle = area.finalTitle ?? 'Avançar com segurança';
const finalText =
	area.finalText ??
	'O enquadramento correto evita decisões precipitadas. Se o seu contexto já está maduro para avaliação, inicie a análise técnica.';
const finalCtaLabel = area.finalCtaLabel ?? 'Solicitar análise inicial';
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs, canonicalUrl);
const faqSchema = area.faqItems.length > 0 ? buildFaqSchema(area.faqItems) : undefined;
const legalServiceSchema = {
	...LEGAL_SERVICE_BASE_SCHEMA,
	'@id': `${canonicalUrl}#area`,
	name: `${area.title} | PAVIE | Advocacia`,
	url: canonicalUrl,
	description: area.description,
	serviceType: area.title,
};
---

<BaseLayout
	title={area.seoTitle}
	description={area.description}
	canonical={canonicalUrl}
>
	<div class="container institutional-page s2-area-page">
		<Breadcrumbs items={breadcrumbs} />

		<section class="s2-hero" aria-labelledby="area-title">
			<div>
				<span class="badge">Área de atuação</span>
				<h1 id="area-title">{heroTitle}</h1>
				<p>{heroDescription}</p>
				<div class="institutional-actions">
					<a class="btn btn-primary" href="/#contato">Solicitar análise inicial</a>
					<a class="btn btn-ghost" href="#leitura-util">Explorar categoria</a>
				</div>
			</div>
			<div class="s2-hero__panel" aria-label="Eixo da área">
				<span>{area.categoryCode}</span>
				<strong>{area.displayTitle ?? currentArea.displayTitle}</strong>
				<p>Página institucional de área, conectada à categoria editorial correspondente.</p>
			</div>
		</section>

		<section class="s2-section s2-framing" aria-labelledby="area-framing-title">
			<span class="section-kicker">Enquadramento da área</span>
			<h2 id="area-framing-title">{area.framingTitle ?? 'Enquadramento da área'}</h2>
			{framingText.map((paragraph) => <p>{paragraph}</p>)}
		</section>

		<section class="s2-section" aria-labelledby="area-criteria-title">
			<div class="s2-section__title">
				<span class="section-kicker">Critérios de atuação técnica</span>
				<h2 id="area-criteria-title">Como esta frente é analisada</h2>
			</div>
			<div class="s2-card-grid">
				{area.criteria.map((item, index) => (
					<article class="s2-mini-card">
						<span>{String(index + 1).padStart(2, '0')}</span>
						<p>{item}</p>
					</article>
				))}
			</div>
		</section>

		<section class="s2-section s2-split" aria-labelledby="area-documents-title">
			<div>
				<span class="section-kicker">Prova mínima</span>
				<h2 id="area-documents-title">{documentsTitle}</h2>
				<p>{documentsNote}</p>
			</div>
			<ul class="s2-checklist">
				{area.documents.map((item) => <li>{item}</li>)}
			</ul>
		</section>

		<section class="s2-section s2-cautions" aria-labelledby="area-cautions-title">
			<span class="section-kicker">Contenção de expectativa</span>
			<h2 id="area-cautions-title">{cautionsTitle}</h2>
			<p>{cautionsIntro}</p>
			<ul>
				{area.cautions.map((item) => <li>{item}</li>)}
			</ul>
		</section>

		<section class="s2-section s2-faq" aria-labelledby="area-faq-title">
			<div class="s2-section__title">
				<span class="section-kicker">FAQ específica</span>
				<h2 id="area-faq-title">{faqTitle}</h2>
			</div>
			<div class="faq-list">
				{area.faqItems.map((item) => (
					<details class="faq-item">
						<summary>{item.question}</summary>
						<p>{item.answer}</p>
					</details>
				))}
			</div>
		</section>

		<section id="leitura-util" class="s2-section s2-reading" aria-labelledby="area-reading-title">
			<div>
				<span class="section-kicker">Leitura útil antes do contato</span>
				<h2 id="area-reading-title">{readingTitle}</h2>
				<p>{readingDescription}</p>
			</div>
			<article class="s2-reading__card">
				<span>Categoria correspondente</span>
				<h3>{area.readingCategoryLabel ?? area.displayTitle ?? currentArea.displayTitle}</h3>
				<p>
					{currentArea.postCount > 0
						? `${currentArea.postCount} artigo${currentArea.postCount === 1 ? '' : 's'} publicado${currentArea.postCount === 1 ? '' : 's'} nesta categoria.`
						: 'Categoria editorial estruturada para receber artigos, guias e checklists desta frente.'}
				</p>
				<a class="btn btn-secondary" href={currentArea.categoryHref}>Explorar categoria</a>
			</article>
		</section>

		<section class="s2-final-cta" aria-labelledby="area-final-title">
			<div>
				<span class="section-kicker">Próximo passo</span>
				<h2 id="area-final-title">{finalTitle}</h2>
				<p>{finalText}</p>
			</div>
			<a class="btn btn-primary" href="/#contato">{finalCtaLabel}</a>
		</section>
	</div>

	<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	<script is:inline type="application/ld+json" set:html={JSON.stringify(legalServiceSchema)} />
	{faqSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</BaseLayout>
